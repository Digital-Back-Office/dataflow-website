---
const { updatedposts } = Astro.props
---

<div class='grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8'>
  {
    updatedposts.map((post) => (
      <article class='group bg-white rounded-2xl overflow-hidden border border-gray-100 hover:border-primary/30 hover:shadow-xl transition-all duration-300'>
        {post.data.image && (
          <a href={`/blog/${post.slug}`} class='block overflow-hidden' title={post.data.title}>
            <img
              src={post.data.image}
              alt={post.data.title}
              class='w-full h-56 object-cover group-hover:scale-105 transition-transform duration-300'
            />
          </a>
        )}
        
        <div class='p-6'>
          {/* Date and Tags */}
          <div class='flex items-center gap-3 mb-4 text-sm text-gray-500'>
            <time datetime={post.data.date}>{post.data.date}</time>
            {post.data.tags && post.data.tags.length > 0 && (
              <>
                <span class='text-gray-300'>|</span>
                <span class='px-2 py-1 bg-primary/10 text-primary rounded-md text-xs font-medium'>
                  {post.data.tags[0]}
                </span>
              </>
            )}
          </div>

          {/* Title */}
          <h3 class='text-xl font-bold text-textblack mb-3 line-clamp-2 group-hover:text-primary transition-colors'>
            <a href={`/blog/${post.slug}`} title={post.data.title}>{post.data.title}</a>
          </h3>

          {/* Description */}
          <p class='text-gray-600 text-sm line-clamp-3 mb-4'>
            {post.data.description}
          </p>

          {/* Read More Link */}
          <a
            href={`/blog/${post.slug}`}
            title={`Read ${post.data.title}`}
            class='inline-flex items-center text-primary font-semibold text-sm hover:gap-2 transition-all group/link'
          >
            Read More
            <svg
              class='w-4 h-4 ml-1 group-hover/link:translate-x-1 transition-transform'
              fill='none'
              stroke='currentColor'
              viewBox='0 0 24 24'
            >
              <path
                stroke-linecap='round'
                stroke-linejoin='round'
                stroke-width='2'
                d='M9 5l7 7-7 7'
              />
            </svg>
          </a>
        </div>
      </article>
    ))
  }
</div>
