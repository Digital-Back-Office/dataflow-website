---
const { title, url, description, image } = Astro.props

const displayTitle = title.length > 60 ? title.substring(0, 60).trim() + '...' : title
const displayDesc = description.length > 120 ? description.substring(0, 120).trim() + '...' : description
---

<article class='group flex flex-col md:flex-row gap-0 bg-white rounded-2xl overflow-hidden border border-gray-100 hover:border-primary/30 hover:shadow-xl transition-all duration-300 mb-6'>
  <a
    href={url}
    class='md:w-2/5 block overflow-hidden bg-gray-100'
    title={displayTitle}
  >
    <img
      src={image}
      alt={title}
      class='w-full h-56 md:h-full object-cover group-hover:scale-105 transition-transform duration-300'
    />
  </a>
  
  <div class='md:w-3/5 p-6 flex flex-col justify-between'>
    <div>
      <h3 class='text-xl md:text-2xl font-bold text-textblack mb-3 group-hover:text-primary transition-colors'>
        <a href={url} title={displayTitle}>{displayTitle}</a>
      </h3>
      
      <p class='text-gray-600 text-sm mb-4 line-clamp-3 max-md:hidden'>
        {displayDesc}
      </p>
    </div>
    
    <div class='flex items-center justify-between mt-4'>
      <span class='inline-flex items-center px-3 py-1 bg-primary/10 text-primary rounded-lg text-xs font-medium'>
        Business
      </span>
      
      <a
        href={url}
        title={`Read ${displayTitle}`}
        class='inline-flex items-center text-primary font-semibold text-sm hover:gap-2 transition-all group/link'
      >
        Read More
        <svg
          class='w-4 h-4 ml-1 group-hover/link:translate-x-1 transition-transform'
          fill='none'
          stroke='currentColor'
          viewBox='0 0 24 24'
        >
          <path
            stroke-linecap='round'
            stroke-linejoin='round'
            stroke-width='2'
            d='M9 5l7 7-7 7'
          />
        </svg>
      </a>
    </div>
  </div>
</article>
