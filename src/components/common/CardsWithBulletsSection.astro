---
interface CardItem {
  title: string
  bullets: string[]
}

interface Props {
  title?: string
  cards: CardItem[]
  calloutText?: string
  bg?: 'white' | 'F8FAFC'
}

const { title, cards, calloutText, bg = 'white' } = Astro.props as Props
const bgClass = bg === 'F8FAFC' ? 'bg-[#F8FAFC]' : 'bg-white'
---

<section class={`px-[5%] py-16 md:py-20 ${bgClass}`}>
  <div class="max-w-7xl mx-auto">
    {title && (
      <div class="max-w-4xl mb-10 md:mb-12" data-aos="fade-up" data-aos-duration="700" data-aos-offset="180">
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-primary mb-3">Compliance</p>
        <h2 class="text-3xl md:text-4xl font-bold text-textblack leading-tight">
          {title}
        </h2>
      </div>
    )}
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-7">
      {cards.map((card, index) => (
        <article
          class="group rounded-2xl border border-gray-200 bg-white p-6 md:p-6 shadow-[0_1px_0_rgba(15,23,42,0.02)] transition-all duration-300 hover:border-primary/30"
          data-aos="fade-up"
          data-aos-duration="700"
          data-aos-offset="180"
          data-aos-delay={index * 80}
        >
          <div class="flex items-start gap-4 mb-5">
            <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-full bg-primary/10 text-primary font-semibold ring-1 ring-primary/10">
              {index + 1}
            </div>
            <div class="min-w-0">
              <h3 class="text-2xl font-bold text-textblack leading-tight">{card.title}</h3>
              <div class="mt-3 h-px w-12 bg-primary/30"></div>
            </div>
          </div>
          <ul class="space-y-3 text-gray-700 leading-relaxed">
            {card.bullets.map((item) => (
              <li class="flex gap-3">
                <span class="mt-2 h-2 w-2 rounded-full bg-primary shrink-0"></span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </article>
      ))}
    </div>
    {calloutText && (
      <div
        class="mt-10 rounded-3xl border border-primary/20 bg-gradient-to-br from-primary/5 via-white to-primary/10 p-6 md:p-7"
        data-aos="fade-up"
        data-aos-duration="700"
        data-aos-offset="180"
        data-aos-delay="120"
      >
        <p class="text-lg text-gray-700 leading-relaxed">{calloutText}</p>
      </div>
    )}
  </div>
</section>
