---
interface Props {
    label: string
    href?: string
    target?: '_self' | '_blank'
    rel?: string
    type?: 'button' | 'submit' | 'reset'
    iconSrc?: string
    iconAlt?: string
    variant?: 'primary' | 'ghost' | 'outlined'
    className?: string
}

const {
    label,
    href,
    target = '_self',
    rel = target === '_blank' ? 'noreferrer noopener' : undefined,
    type = 'button',
    iconSrc = '/assets/icons/icon-right-angular-arrow-white.svg',
    iconAlt = 'Arrow icon',
    variant = 'primary',
    className = '',
} = Astro.props

const baseClasses =
    'w-max inline-flex hover:cursor-pointer items-center gap-x-2 px-4 py-3 rounded-lg text-base font-medium transition duration-200 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary group'
const variantClasses =
    variant === 'ghost'
        ? 'bg-transparent text-primary hover:bg-primary/10 shadow-none'
        : variant === 'outlined'
        ? 'bg-white hover:bg-gray-50 text-gray-900 border-2 border-gray-200 hover:border-primary shadow-none'
        : 'bg-primary text-white shadow-md hover:bg-primary'
const classes = `${baseClasses} ${variantClasses} ${className}`.trim()
---

{href ? (
    <a href={href} target={target} rel={rel} class={classes} aria-label={label}>
        {label}
        {iconSrc && (
            <img
                class={variant === 'outlined' ? 'size-[20px] transition-transform group-hover:translate-x-1' : `size-[20px] transition-transform group-hover:translate-x-1`}
                src={iconSrc}
                alt={iconAlt}
                loading='lazy'
            />
        )}
    </a>
) : (
    <button type={type} class={classes} aria-label={label}>
        {label}
        {iconSrc && (
            <img
                class={variant === 'outlined' ? 'size-[20px] transition-transform group-hover:translate-x-1' : 'invert brightness-0 size-[20px] transition-transform group-hover:translate-x-1'}
                src={iconSrc}
                alt={iconAlt}
                loading='lazy'
            />
        )}
    </button>
)}