---
interface TableRow {
  label: string
  values: string[]
  highlight?: boolean
  striped?: boolean
}

interface Props {
  title: string
  description?: string
  intro?: string
  columns: string[]
  rows: TableRow[]
  bg?: 'white' | 'F8FAFC'
  minWidthClass?: string
}

const {
  title,
  description,
  intro,
  columns,
  rows,
  bg = 'white',
  minWidthClass = 'min-w-[760px]'
} = Astro.props as Props

const bgClass = bg === 'F8FAFC' ? 'bg-[#F8FAFC]' : 'bg-white'
---

<section class={`px-[5%] py-16 ${bgClass}`}>
  <div class="max-w-7xl mx-auto">
    <div data-aos="fade-up" data-aos-duration="700" data-aos-offset="180">
      <h2 class="text-3xl md:text-4xl font-bold text-textblack mb-5">{title}</h2>
      {description && <p class="text-lg text-gray-700 mb-4 leading-relaxed">{description}</p>}
      {intro && <p class="text-lg text-gray-700 mb-10 leading-relaxed">{intro}</p>}
    </div>

    <div class="overflow-x-auto rounded-2xl border border-gray-200 bg-white" data-aos="fade-up" data-aos-duration="700" data-aos-delay="80" data-aos-offset="180">
      <table class={`w-full ${minWidthClass} border-collapse`}>
        <thead>
          <tr class="bg-gray-50 text-left">
            <th class="px-5 py-4 text-sm font-semibold text-gray-700">{columns[0]}</th>
            {columns.slice(1).map((column) => (
              <th class="px-5 py-4 text-sm font-semibold text-gray-700">{column}</th>
            ))}
          </tr>
        </thead>
        <tbody>
          {rows.map((row) => {
            const rowClass = row.highlight
              ? 'bg-primary/10'
              : row.striped
                ? 'bg-gray-50/40'
                : ''
            return (
              <tr class={`border-t border-gray-200 ${rowClass}`}>
                <td class={`px-5 py-4 text-textblack ${row.highlight ? 'font-semibold' : 'font-medium'}`}>{row.label}</td>
                {row.values.map((value) => (
                  <td class="px-5 py-4 text-gray-700">{value}</td>
                ))}
              </tr>
            )
          })}
        </tbody>
      </table>
    </div>
  </div>
</section>
