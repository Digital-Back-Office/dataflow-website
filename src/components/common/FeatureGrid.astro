---
import Card from '../features/run-data-on-any-cloud/Card.astro'
import CustomButton from './CustomButton.astro'

interface Props {
  title: string
  description: string
  features: Array<{
    title: string
    description: string
    image: string
  }>
  button?: {
    label: string
    href: string
    target?: "_blank" | "_self"
  }
  bg?: string
  className?: string
}

const { title, description, features, button, bg = 'F8FAFC', className = '' } = Astro.props
---

<section class={`w-full py-20 px-[6%] ${className} bg-[#${bg}]`}>
  <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-[1fr_1.2fr] gap-12 items-start">
    <div class='text-container' data-aos="fade-right" data-aos-duration="850" data-aos-offset="200">
      <h2 class='text-4xl md:text-5xl font-bold mb-6 text-textblack'>{title}</h2>
      <p class='text-lg text-gray-600'>{description}</p>
      {button && (
        <CustomButton 
          label={button.label}
          href={button.href}
          target={button.target ?? "_self"}
          className="mt-8"
        />
      )}
    </div>
    <div
      class='img-container'
      data-aos="fade-left" data-aos-duration="850" data-aos-offset="200"
    >
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        {
          features.map((feature) => (
            <Card
              image={feature.image}
              title={feature.title}
              description={feature.description}
            />
          ))
        }
      </div>
    </div>
  </div>
</section>
<style>
  @media (max-width: 440px) {
    .container-top {
      width: 100%;
      height: auto;
      padding-left: 15px;
      padding-right: 15px;
      padding-top: 30px;
      padding-bottom: 30px;
      flex-direction: column;
    }
    .text-container {
      width: 100%;
      margin-bottom: 40px;
    }
    .img-container {
      width: 100%;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      row-gap: 20px;
      height: auto;
    }
  }
</style>
