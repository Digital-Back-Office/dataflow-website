---
import { getEntry } from "astro:content";
const Data = await getEntry("common", "header-footer");
const footer = Data.data.footer;
const docsUrl = import.meta.env.VITE_DOCS_URL;
---

<footer class="bg-gradient-to-b from-[#0F1419] to-[#1a1f26] text-white" style="font-family: Plus Jakarta Sans, sans-serif;">
  <div class="max-w-7xl mx-auto px-6 lg:px-12 py-16 lg:py-20">
    
    <!-- Main Footer Content -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 pb-12 border-b border-gray-800">
      
      <!-- Brand Section -->
      <div class="lg:col-span-4 space-y-6">
        <a href="/" class="inline-block group">
          <img
            src="/assets/images/dataflow-logo-green.svg"
            alt="Dataflow Logo"
            class="h-12"
          />
        </a>
        <p class="text-sm leading-relaxed text-gray-400 max-w-sm">
          {footer.description}
        </p>
        
        <!-- Social Links -->
        <div class="flex items-center gap-3">
          {
            footer.social_links &&
              footer.social_links.map((social) => (
                <a
                  href={social.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="group size-10 rounded-lg bg-gray-800/50 hover:bg-primary/20 border border-gray-700/50 hover:border-primary/50 flex items-center justify-center transition-all duration-300"
                  aria-label={social.platform}
                >
                  <img 
                    src={social.icon} 
                    alt={social.platform} 
                    class="size-5" 
                  />
                </a>
              ))
          }
        </div>
      </div>

      <!-- Links Grid -->
      <div class="lg:col-span-8 grid grid-cols-2 md:grid-cols-4 gap-8 lg:gap-12">
        {
          footer.sections &&
            footer.sections.map((section) => (
              <div class="space-y-4">
                <h3 class="text-sm font-semibold text-white uppercase tracking-wider">
                  {section.heading}
                </h3>
                <ul class="space-y-3">
                  {section.links &&
                    section.links.map((link) => (
                      <li>
                        <a 
                          href={link.href} 
                          class="text-sm text-gray-400 hover:text-primary transition-colors duration-200 inline-block relative group"
                        >
                          <span class="relative">
                            {link.label}
                            <span class="absolute bottom-0 left-0 w-0 h-px bg-primary group-hover:w-full transition-all duration-300"></span>
                          </span>
                        </a>
                      </li>
                    ))}
                </ul>
              </div>
            ))
        }
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="pt-8 flex flex-col md:flex-row items-center justify-between gap-4">
      <p class="text-sm text-gray-500">
        {footer.copyrights}
      </p>
      <div class="flex items-center gap-6">
        {
          footer.bottom_bar.links.map((link) => (
            <a 
              href={link.href} 
              class="text-sm text-gray-500 hover:text-primary transition-colors duration-200"
            >
              {link.label}
            </a>
          ))
        }
      </div>
    </div>
  </div>
</footer>

<style>
  footer {
    position: relative;
  }
  
  footer::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(48, 186, 186, 0.5), transparent);
  }
</style>
