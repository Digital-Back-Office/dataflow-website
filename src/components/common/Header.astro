---
import { getEntry } from 'astro:content'
const Data = await getEntry('common', 'header-footer')
const header = Data.data.header
const { pagename } = Astro.props

const { pathname } = Astro.url
const docsUrl = import.meta.env.VITE_DOCS_URL
---

<header
  class='h-16 w-full flex items-center justify-between bg-[#FFF] px-[22px] z-50'
>
  <div class='flex items-center gap-16 p-[5px] pt-[9px] z-50'>
    <a href='/' class=''>
      <img src='/assets/images/dataflow-logo-green.svg' class='h-12' />
    </a>
    <nav class='hidden md:flex h-12 items-baseline mt-[5px]'>
      <div
        class='flex items-center justify-between tracking-wide h-full gap-[6px]'
      >
      {
        header.nav_items.map((item, index) => {

          if (item.label === "Blogs") return null;

          return (
          <a
            href={item.href}
            id={item.href.split('/')[1] || 'dataflow'}
            class='h-full border-b-[3px] mb-[2px] border-transparent px-[18px] flex items-center hover:border-primary hover:border-opacity-70'
          >
            <p class='text-primary text-sm font-semibold'>
              {item.label}
            </p>
          </a>
        )
        })
      }
      </div>
    </nav>
  </div>

  <div class='hidden md:flex items-center gap-[8px] z-50'>
    <a href='https://app.dataflow.zone/' target="_blank">
      <button
        class='px-[16px] py-[8px] text-nowrap bg-[#3AC4C4] text-white rounded-md text-sm font-bold tracking-wide'
        >{header.button_1}</button
      >
    </a>
    <a href='/book-demo'>
      <button
        class='px-[16px] py-[8px] text-nowrap bg-white hover:bg-[#f9f9f9] rounded-md text-sm font-bold tracking-wide shadow-md text-[#30BABA]'
        >{header.button_2}</button
      >
    </a>
  </div>

  <div class='md:hidden flex items-center z-50'>
    <button id='burgerMenuButton' class='text-primary focus:outline-none'>
      <svg
        class='w-8 h-8'
        fill='none'
        stroke='currentColor'
        viewBox='0 0 24 24'
        xmlns='http://www.w3.org/2000/svg'
      >
        <path
          stroke-linecap='round'
          stroke-linejoin='round'
          stroke-width='2'
          d='M4 6h16M4 12h16m-7 6h7'></path>
      </svg>
    </button>
  </div>

  <p id='pathname' class='bg-black text-white hidden'>{pathname.split('/')}</p>
</header>

<!-- Mobile Menu -->
<div
  id='mobileMenu'
  class='bg-white fixed top-0 left-0 w-full h-full transform -translate-x-full transition-transform duration-300 ease-in-out z-50'
>
  <div class='h-20 w-full flex items-center justify-between px-4'>
    <a href='/'>
      <img src='/assets/images/dataflow-logo-green.svg' class='h-12' />
    </a>
    <button id='closeMenuButton' class='text-primary focus:outline-none'>
      <svg
        class='w-8 h-8'
        fill='none'
        stroke='currentColor'
        viewBox='0 0 24 24'
        xmlns='http://www.w3.org/2000/svg'
      >
        <path
          stroke-linecap='round'
          stroke-linejoin='round'
          stroke-width='2'
          d='M6 18L18 6M6 6l12 12'></path>
      </svg>
    </button>
  </div>
  <nav class='bg-white flex flex-col items-center mt-10'>
      {
        header?.nav_items.map((item, index) => {

          if (item.label === "Blogs") return null;

          return (
          <a
            href={item.href}
            id={item.label}
            class='text-primary text-base font-bold py-2'
            style='font-family: Arial, Helvetica, sans-serif'>
              {item.label}
          </a> )}
        )
      }
    <div class='flex flex-col mt-14 items-center gap-4'>
      <a href='https://app.dataflow.zone/'>
        <button
          class='px-[20px] py-[8px] bg-primary text-white rounded-md text-base font-bold tracking-wide'
          >{header.button_1}</button
        >
      </a>
      <a href='/book-demo'>
        <button
          class='px-[20px] py-[8px] bg-white rounded-md text-base font-bold tracking-wide shadow-md text-primary'
          >{header.button_2}</button
        >
      </a>
    </div>
  </nav>
  <p id='helper' class='hidden'>{pagename}</p>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const burgerMenuButton = document.getElementById('burgerMenuButton')
    const mobileMenu = document.getElementById('mobileMenu')
    const closeMenuButton = document.getElementById('closeMenuButton')
    const pathname = document.getElementById('pathname').innerText.trim()
    const navElement = document.querySelector(`#${pathname || 'dataflow'}`)

    if (navElement) {
      navElement.classList.remove('border-transparent')
      navElement.classList.remove('hover:border-[#EFFFFF]')
      navElement.classList.remove('hover:border-opacity-70')
      navElement.classList.add('border-primary')
    }

    burgerMenuButton.addEventListener('click', () => {
      mobileMenu.classList.remove('-translate-x-full')
      mobileMenu.classList.add('translate-x-0')
    })

    closeMenuButton.addEventListener('click', () => {
      mobileMenu.classList.remove('translate-x-0')
      mobileMenu.classList.add('-translate-x-full')
    })
  })
</script>

<style>
  @media (max-width: 470px) {
    .md\\:hidden {
      display: block;
    }
  }
</style>
