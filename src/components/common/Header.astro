---
import { getEntry } from 'astro:content'
import NavIcon from './NavIcon.astro'

const data = await getEntry('common', 'header-footer')
const header = data.data.header ?? {}
const logo = header.logo ?? { href: '/', image: '/assets/images/dataflow-logo-green.svg' }
const desktopNav = header.nav?.desktop ?? []
const desktopCtas = header.ctas ?? {}
const { pagename } = Astro.props

const isExternal = (href?: string) => Boolean(href?.startsWith('http'))

// Convert desktop nav to mobile sections
const mobileSections = desktopNav.map((navItem) => {
  if (navItem.type === 'link') {
    return {
      heading: navItem.label,
      items: [{ label: navItem.label, href: navItem.href }]
    }
  }
  
  const items: any[] = []
  
  if (navItem.type === 'mega' && navItem.columns) {
    navItem.columns.forEach((column: any) => {
      column.items?.forEach((item: any) => {
        items.push({
          label: item.title,
          href: item.href,
          action: item.action
        })
      })
    })
  } else if (navItem.type === 'list' && navItem.items) {
    navItem.items.forEach((item: any) => {
      items.push({
        label: item.title,
        href: item.href
      })
    })
  }
  
  return {
    heading: navItem.label,
    items
  }
})

const mobileCtas = desktopCtas
---

<header
  class='h-20 w-full flex items-center justify-between bg-white px-[10%] max-xl:px-[5%] z-50 sticky top-0'
  
>
  <div class='flex items-center gap-10  max-xl:gap-12 z-50'>
    <a href={logo.href ?? '/'} class='flex items-center'>
      <img src={logo.image ?? '/assets/images/dataflow-logo-green.svg'} class='h-12' alt={logo.alt ?? ''} />
    </a>
    <nav class='hidden lg:flex items-center gap-10 max-xl:gap-8'>
      {desktopNav.map((navItem) => (
        navItem.type === 'link' ? (
          <a
            class='text-sm font-medium text-gray-700 hover:text-gray-900 transition-colors'
            href={navItem.href}
            target={isExternal(navItem.href) ? '_blank' : undefined}
            rel={isExternal(navItem.href) ? 'noreferrer' : undefined}
          >
            {navItem.label}
          </a>
        ) : (
          <div class='relative group'>
            <button class='text-sm font-medium text-gray-700 hover:text-gray-900 transition-colors flex items-center gap-1 py-2'>
              {navItem.label}
              <svg class='w-4 h-4' fill='none' stroke='currentColor' viewBox='0 0 24 24'>
                <path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M19 9l-7 7-7-7'></path>
              </svg>
            </button>
            <div class='absolute left-0 top-full pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200'>
              {navItem.type === 'mega' && (
                <div class={`bg-white rounded-lg shadow-lg border border-gray-100 p-8 ${navItem.width ?? (navItem.columns && navItem.columns.length > 1 ? 'w-[560px]' : 'w-[420px]')}`}>
                  {navItem.columns && navItem.columns.length > 1 ? (
                    <div class='grid grid-cols-3 gap-8'>
                      {navItem.columns.map((column) => (
                        <div class={`space-y-4 ${column.span === 2 ? 'col-span-2' : ''}`}>
                          <p class='text-xs font-semibold text-gray-500 uppercase tracking-wider'>{column.heading}</p>
                          {column.items?.map((item) => (
                            item.action ? (
                              <button
                                class='w-full flex items-start gap-3 p-3 rounded-lg hover:bg-gray-50 transition-colors group/item text-left'
                                onclick="document.getElementById('arcadeModal').classList.remove('hidden')"
                              >
                                <div class='p-2 bg-primary/10 rounded-lg shrink-0 flex items-center justify-center'>
                                  <NavIcon title={item.title} size='small' />
                                </div>
                                <div>
                                  <p class='text-base font-medium text-gray-900 group-hover/item:text-primary mb-1'>{item.title}</p>
                                  <p class='text-sm text-gray-600'>{item.description}</p>
                                </div>
                              </button>
                            ) : (
                              <a
                                href={item.href}
                                class='flex items-start gap-3 p-3 rounded-lg hover:bg-gray-50 transition-colors group/item'
                                target={isExternal(item.href) ? '_blank' : undefined}
                                rel={isExternal(item.href) ? 'noreferrer' : undefined}
                              >
                                <div class='p-2 bg-primary/10 rounded-lg shrink-0 flex items-center justify-center'>
                                  <NavIcon title={item.title} size='small' />
                                </div>
                                <div>
                                  <p class='text-base font-medium text-gray-900 group-hover/item:text-primary mb-1'>{item.title}</p>
                                  <p class='text-sm text-gray-600'>{item.description}</p>
                                </div>
                              </a>
                            )
                          ))}
                        </div>
                      ))}
                    </div>
                  ) : (
                    navItem.columns?.map((column) => (
                      <div class='space-y-4'>
                        <p class='text-xs font-semibold text-gray-500 uppercase tracking-wider'>{column.heading}</p>
                        {column.items?.map((item) => (
                          <a
                            href={item.href}
                            class='flex items-start gap-4 p-3 rounded-lg hover:bg-gray-50 transition-colors group/item'
                            target={isExternal(item.href) ? '_blank' : undefined}
                            rel={isExternal(item.href) ? 'noreferrer' : undefined}
                          >
                            <div class='p-2.5 bg-primary/10 rounded-lg shrink-0 flex items-center justify-center'>
                              <NavIcon title={item.title} size='large' />
                            </div>
                            <div>
                              <p class='text-base font-semibold text-gray-900 group-hover/item:text-primary mb-1'>{item.title}</p>
                              <p class='text-sm text-gray-600'>{item.description}</p>
                            </div>
                          </a>
                        ))}
                      </div>
                    ))
                  )}
                </div>
              )}

              {navItem.type === 'list' && (
                <div class={`bg-white rounded-lg shadow-lg border border-gray-100 p-6 ${navItem.width ?? 'w-72'}`}>
                  {navItem.items?.map((item) => (
                    <a
                      href={item.href}
                      class='flex items-start gap-4 p-3 rounded-lg hover:bg-gray-50 transition-colors group/item'
                      target={isExternal(item.href) ? '_blank' : undefined}
                      rel={isExternal(item.href) ? 'noreferrer' : undefined}
                    >
                      <div class='p-2.5 bg-primary/10 rounded-lg shrink-0 flex items-center justify-center'>
                        <NavIcon title={item.title} size='large' />
                      </div>
                      <div>
                        <p class='text-base font-semibold text-gray-900 group-hover/item:text-primary mb-1'>{item.title}</p>
                        <p class='text-sm text-gray-600'>{item.description}</p>
                      </div>
                    </a>
                  ))}
                </div>
              )}
            </div>
          </div>
        )
      ))}
    </nav>
  </div>

  <div class='hidden lg:flex items-center gap-3 z-50'>
    {desktopCtas?.primary && (
      <a href={desktopCtas.primary.href} target={desktopCtas.primary}>
        <button
          class='px-5 py-2 text-sm font-medium text-primary border border-primary rounded-md hover:bg-primary/5 transition-all duration-200'
        >
          {desktopCtas.primary.label}
        </button>
      </a>
    )}
    {desktopCtas?.secondary && (
      <a href={desktopCtas.secondary.href}>
        <button
          class='px-5 py-2 bg-primary hover:bg-primaryHover text-white rounded-md text-sm font-medium transition-all duration-200'
        >
          {desktopCtas.secondary.label}
        </button>
      </a>
    )}
  </div>

  <div class='lg:hidden flex items-center z-50'>
    <button id='burgerMenuButton' class='text-gray-700 focus:outline-none'>
      <svg
        class='w-6 h-6'
        fill='none'
        stroke='currentColor'
        viewBox='0 0 24 24'
      >
        <path
          stroke-linecap='round'
          stroke-linejoin='round'
          stroke-width='2'
          d='M4 6h16M4 12h16M4 18h16'></path>
      </svg>
    </button>
  </div>
</header>

<!-- Mobile Menu -->
<div
  id='mobileMenu'
  class='bg-white fixed top-0 left-0 w-full h-full transform -translate-x-full transition-transform duration-300 ease-in-out z-50 overflow-y-auto'
  
>
  <div class='h-16 w-full flex items-center justify-between px-6 border-b border-gray-100'>
    <a href='/'>
      <img src='/assets/images/dataflow-logo-green.svg' class='h-9' />
    </a>
    <button id='closeMenuButton' class='text-gray-700 focus:outline-none'>
      <svg
        class='w-6 h-6'
        fill='none'
        stroke='currentColor'
        viewBox='0 0 24 24'
      >
        <path
          stroke-linecap='round'
          stroke-linejoin='round'
          stroke-width='2'
          d='M6 18L18 6M6 6l12 12'></path>
      </svg>
    </button>
  </div>
  
  <nav class='bg-white px-6 py-6'>
    {mobileSections.map((section) => (
      <div class='mb-6'>
        <p class='text-xs font-semibold text-gray-500 uppercase tracking-wider mb-3'>{section.heading}</p>
        <div class='space-y-1'>
          {section.items?.map((item) => (
            item.action ? (
              <button
                onclick="document.getElementById('arcadeModal').classList.remove('hidden'); document.getElementById('mobileMenu').classList.remove('translate-x-0'); document.getElementById('mobileMenu').classList.add('-translate-x-full')"
                class='block w-full text-left px-3 py-2 text-sm text-gray-700 hover:bg-gray-50 rounded-md'
              >
                {item.label}
              </button>
            ) : (
              <a
                href={item.href}
                class='block px-3 py-2 text-sm text-gray-700 hover:bg-gray-50 rounded-md'
                target={isExternal(item.href) ? '_blank' : undefined}
                rel={isExternal(item.href) ? 'noreferrer' : undefined}
              >
                {item.label}
              </a>
            )
          ))}
        </div>
      </div>
    ))}

    {mobileCtas && (
      <div class='flex flex-col gap-3 mt-8'>
        {mobileCtas.primary && (
          <a href={mobileCtas.primary.href}>
            <button class='w-full px-5 py-3 text-primary border border-primary rounded-md font-medium hover:bg-primary/5 transition-all'>
              {mobileCtas.primary.label}
            </button>
          </a>
        )}
        {mobileCtas.secondary && (
          <a href={mobileCtas.secondary.href}>
            <button class='w-full px-5 py-3 bg-primary hover:bg-primaryHover text-white rounded-md font-medium transition-all'>
              {mobileCtas.secondary.label}
            </button>
          </a>
        )}
      </div>
    )}
  </nav>
</div>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const burgerMenuButton = document.getElementById('burgerMenuButton')
    const mobileMenu = document.getElementById('mobileMenu')
    const closeMenuButton = document.getElementById('closeMenuButton')

    burgerMenuButton.addEventListener('click', () => {
      mobileMenu.classList.remove('-translate-x-full')
      mobileMenu.classList.add('translate-x-0')
    })

    closeMenuButton.addEventListener('click', () => {
      mobileMenu.classList.remove('translate-x-0')
      mobileMenu.classList.add('-translate-x-full')
    })
  })
</script>
