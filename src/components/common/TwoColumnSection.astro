---
interface Props {
  title: string
  description?: string
  image?: string
  imageAlt?: string
  buttonText?: string
  buttonHref?: string
  imageSide?: 'left' | 'right'
  bg?: 'white' | 'F8FAFC'
}

const {
  title,
  description = '',
  image = '',
  imageAlt = title ?? 'image',
  buttonText,
  buttonHref = '#',
  imageSide = 'right',
  bg = 'white'
} = Astro.props as Props

const bgClass = bg === 'F8FAFC' ? 'bg-[#F8FAFC]' : 'bg-white'
const reverseOnMobile = imageSide === 'left' ? 'md:flex-row-reverse' : 'md:flex-row'
---
<section class={`w-full ${bgClass} py-20 lg:h-screen flex items-center justify-center`}>
  <div class="">
    <div class={`flex flex-col md:flex ${reverseOnMobile} items-center gap-10 lg:gap-20`}>
      <!-- Text Column -->
      <div class="md:min-w-[700px] max-sm:w-[90%] flex flex-col justify-center">
        <h2 class="w-full text-4xl md:text-5xl max-sm:text-3xl font-bold text-textblack leading-tight mb-6">
          {title}
        </h2>
        {description && (
          <p class="text-lg text-gray-600 mb-8 max-w-[680px]">
            {description}
          </p>
        )}
        {buttonText && (
          <a href={buttonHref}>
            <button
                class='custom-button bg-primary hover:bg-primary px-4 py-3 duration-700 text-white rounded-lg shadow-md flex text-base items-center gap-x-2'
            >
                {buttonText}
                <img
                    class='filter brightness-0 invert'
                    src='/assets/images/arrowright.svg'
                    alt='Arrow right'
                />
            </button>
            </a>
        )}
      </div>

      <!-- Image Column -->
      <div class="md:w-1/2 w-full flex justify-center md:justify-end max-md:w-[90%]">
        {image ? (
          <img src={image} alt={imageAlt} loading="lazy" class="lg:min-w-[750px] lg:max-w-[750px] rounded-xl shadow-lg object-contain"/>
        ) : null}
      </div>
    </div>
  </div>
</section>