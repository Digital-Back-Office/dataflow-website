---
import CustomButton from './CustomButton.astro';

interface Props {
  title: string;
  description?: string;
  image?: string;
  imageAlt?: string;
  buttonText?: string;
  buttonHref?: string;
  imageSide?: "left" | "right";
  bg?: "white" | "F8FAFC";
}

const {
  title,
  description = "",
  image = "",
  imageAlt = title ?? "image",
  buttonText,
  buttonHref = "#",
  imageSide = "right",
  bg = "white",
} = Astro.props as Props;

const bgClass = bg === "F8FAFC" ? "bg-[#F8FAFC]" : "bg-white";
const reverseOnMobile =
  imageSide === "left" ? "md:flex-row-reverse" : "md:flex-row";
---

<section
  class={`w-full ${bgClass} py-20 lg:h-screen flex items-center justify-center max-sm:px-4`}
>
  <div class="">
    <div
      class={`flex flex-col md:flex ${reverseOnMobile} items-center gap-10 lg:gap-20`}
    >
      <!-- Text Column -->
      <div class="md:min-w-[700px] max-sm:w-[90%] flex flex-col justify-center"  data-aos="fade-up" data-aos-duration="700" data-aos-offset="200">
        <h2
          class="w-full text-4xl md:text-5xl max-sm:text-3xl font-bold text-textblack leading-tight mb-6"
        >
          {title}
        </h2>
        {
          description && (
            <p class="text-lg text-gray-600 mb-8 max-w-[680px]">
              {description}
            </p>
          )
        }
        {
          buttonText && (
            <CustomButton href={buttonHref} label={buttonText} />
          )
        }
      </div>

      <!-- Image Column -->
      <div
        class="md:w-1/2 w-full flex justify-center md:justify-end max-md:w-[90%]"
        
      >
        {
          image ? (
            <img
              src={image}
              alt={imageAlt}
              loading="lazy"
              class="lg:min-w-[750px] lg:max-w-[750px] rounded-xl shadow-lg object-contain"
              data-aos="fade-up" data-aos-duration="600" data-aos-offset="300"
            />
          ) : null
        }
      </div>
    </div>
  </div>
</section>
