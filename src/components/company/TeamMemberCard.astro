---
const { photo, name, position, bio } = Astro.props
---

<div class='min-w-[350px] max-w-[380px] max-sm:w-[260px] rounded-2xl shadow-sm border-[#EAEBEC] duration-300 overflow-hidden'>
    <img
        class='w-full aspect-[3/2] object-cover rounded-t-2xl'
        src={photo}
        alt={name}
    />
    <div class='p-6 max-sm:p-3'>
        <p class='text-lg font-semibold text-textblack:'>{name}</p>
        <p class='text-sm text-primary mt-1'>{position}</p>
        <p class='text-sm text-textblack mt-3'>{bio}</p>
    </div>
</div>