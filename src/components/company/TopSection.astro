---
import { getEntry } from "astro:content";

const Data = await getEntry("company", "company");
const data = Data.data.Topsection;
const tagline = data.tagline;
---

<div
  class="min-h-[900px] overflow-hidden max-md:min-h-[500px] max-sm:min-h-[600px] w-full pt-[7%] max-sm:pt-20 overflow-x-hidden"
>
  <div class="w-[1000px] pl-[15%] max-md:pl-6 max-md:w-full" data-aos="fade-in" data-aos-duration="700" data-aos-offset="200">
    <h1 class="text-6xl tracking-wide font-bold w-full mb-10 max-md:text-4xl ">
      {data.title}
    </h1>
    <p class="text-2xl text-textblack max-md:text-xl">
      {data.description}
    </p>
  </div>
  <div class="w-full max-sm:scale-[150%] max-md:mt-10">
    <img
      loading="eager"
      src="/assets/images/company-illustration.svg"
      alt="Simplify Data Processing "
      class="w-full max-sm:-ml-6"
    />
  </div>
</div>

  <p
    class="text-6xl max-md:text-4xl max-sm:text-3xl font-bold text-textblack tracking-wide text-center"
    data-aos="fade-up" data-aos-duration="700" data-aos-offset="200"
  >
   {
    tagline.map((part) => {
      if (part.isHighlighted) {
        return <span class="text-primary">{part.text}{" "}</span>;
      } else {
        return <span>{part.text}{" "}</span>;
      }
    })
   }
  </p>
