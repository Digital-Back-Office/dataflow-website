---
import { getEntry } from 'astro:content'
import EmailCTA from '../common/EmailCTA.astro'

const Data = await getEntry('enterprise', 'enterprise')
const ctaSection = Data?.data?.cta_section || {}
---

<section 
  class="relative py-24 max-sm:py-16 flex flex-col gap-10 items-center justify-center bg-gradient-to-b from-white from-5% via-primary/85 via-50% to-white to-95% min-h-[800px]" 
  style="font-family: Plus Jakarta Sans, sans-serif;"
>
  <!-- Decorative blur elements -->
  <div class="absolute top-10 right-10 w-64 h-64 bg-white/20 rounded-full blur-3xl"></div>
  <div class="absolute bottom-10 left-10 w-64 h-64 bg-white/10 rounded-full blur-3xl"></div>
  
  <div class="relative max-w-5xl mx-auto px-[5%] text-center w-full">
    <div class="mb-8" data-aos="fade-up">
      <h2 class="text-6xl max-md:text-5xl max-sm:text-3xl text-textPrimary font-extrabold mb-6 leading-tight drop-shadow-lg">
        {ctaSection.title}
      </h2>
      <p class="text-2xl max-md:text-xl max-sm:text-lg text-white/95 max-w-3xl mx-auto leading-relaxed">
        {ctaSection.description}
      </p>
    </div>
    
    <div class="max-w-2xl mx-auto" data-aos="fade-up" data-aos-delay="100">
      <EmailCTA 
        formId="enterpriseCtaForm" 
        pageSource="enterprise-cta" 
        buttonText={ctaSection.button?.text || "Get Started"}
      />
    </div>
    
    {ctaSection.note && (
      <p class="mt-6 text-sm text-white/80" data-aos="fade-up" data-aos-delay="200">
        {ctaSection.note}
      </p>
    )}
  </div>
</section>