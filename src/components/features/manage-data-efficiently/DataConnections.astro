---
import { getEntry } from 'astro:content'
import CustomButton from '../../common/CustomButton.astro'

const Data = await getEntry('features', 'manage-your-data-connections')
const data = Data.data.grow_together_managing_connections
const button = Data.data.button
---

<div
  class='w-full py-24 flex items-center justify-center gap-20 max-sm:gap-10 max-sm:flex-col max-sm:px-[20px] max-sm:py-[30px]'
>
  <div class='w-[30%] img-container'>
    <img src='/assets/images/ManageAcross.svg' class='img-container' />
  </div>
  <div class='text-container w-[40%]'>
    <h1 class='text-2calc font-bold mb-8 text-textblack'>{data.title}</h1>
    <p class='text-lg w-11/12 text-textblack'>{data.description}</p>
    <CustomButton 
      label={button}
      href="/start-free-trail"
      className="mt-14"
    />
  </div>
</div>
<style>
  @media (max-width: 440px) {
    .text-container {
      width: 100%;
      margin-bottom: 20px;
    }
    .img-container {
      width: 100%;
      height: auto;
    }
  }
</style>
