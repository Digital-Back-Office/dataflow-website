---
import { getEntry } from "astro:content";
import Card from "./Card.astro";

const Data = await getEntry("features", "run-data-on-any-cloud");
const data = Data.data.benefits;
const features = data.features || [];
---

<div
  class="flex flex-col gap-8 w-full min-h-screen bg-[#F8FAFC] items-center justify-center max-md:mt-10 max-sm:py-[30px] max-sm:px-[20px] max-sm:items-start"
>
  <h2 class="text-calc font-bold text-black text-center max-sm:text-left">
    {data.title}
  </h2>
  <p
    class="w-[65%] max-sm:w-full tracking-wide text-lg text-center max-sm:text-left text-textblack"
  >
    {data.description}
  </p>
  <div
    class="flex flex-wrap w-full min-h-[300px] justify-center items-center gap-8 max-sm:gap-4"
  >
    {
      features.map((feature) => (
        <Card
          image={feature.image}
          title={feature.title}
          description={feature.description}
        />
      ))
    }
  </div>
</div>
<style>
  .card:hover .image-container {
    filter: brightness(0) invert(1);
  }
  @media (max-width: 440px) {
    .container-top {
      width: 100%;
      padding-left: 15px;
      padding-right: 15px;
      padding-top: 30px;
      padding-bottom: 30px;
      flex-direction: column;
      height: auto;
    }
  }
</style>
