---
import CustomButton from "../../common/CustomButton.astro"

const { title, image, logo, link, mirror } = Astro.props
---

<style>
  [data-aos='fade-bounce'] {
    transform: translateY(200px);
    opacity: 0;
    transition-property: transform, opacity;
    transition-timing-function: cubic-bezier(0.1, -0.6, 0.1, 1);

    transition-duration: 1s;
    transition-delay: 0.5s;
  }

  [data-aos='fade-bounce'].aos-animate {
    transform: translateY(0);
    opacity: 1;
  }
</style>

<div
  class={`min-h-screen px-[10%] ${mirror ? 'bg-white' : 'bg-[#F8FAFC]'} flex ${!mirror && 'flex-row-reverse'} items-center justify-center max-sm:flex-col`}
  style="font-family: Plus Jakarta Sans, sans-serif;"
>
  <div
    data-aos='fade-bounce'
    class='flex-[0.5] flex justify-center items-center max-sm:py-10'
  >
    <img src={image} alt='' class='w-max max-h-[500px] max-sm:h-max' />
  </div>
  <div
    class={`flex-[0.5] max-sm:py-10 h-full flex flex-col max-sm:items-center gap-10 max-sm:gap-6 ${!mirror && 'pl-[7%] max-sm:pl-0'}`}
  >
    <img src={logo} alt='airflow' class='h-[60px] max-sm:h-[40px] w-max' />
    <p
      class='text-3xl max-sm:text-2xl font-bold  max-sm:w-full leading-tight text-[#303030]'
    >
      {title}
    </p>
     <CustomButton
        label="Learn More"
        href={link}
        variant="primary"
        className="font-semibold"
      />
  </div>
</div>
