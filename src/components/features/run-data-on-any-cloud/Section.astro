---
import CustomButton from "../../common/CustomButton.astro"

const { description, image, logo, link, mirror } = Astro.props
---

<style>
  [data-aos='fade-bounce'] {
    transform: translateY(200px);
    opacity: 0;
    transition-property: transform, opacity;
    transition-timing-function: cubic-bezier(0.1, -0.6, 0.1, 1);

    transition-duration: 1s;
    transition-delay: 0.5s;
  }

  [data-aos='fade-bounce'].aos-animate {
    transform: translateY(0);
    opacity: 1;
  }
</style>

<div class={`w-full ${mirror ? 'bg-white' : 'bg-[#F8FAFC]'}`}>
  <div class={`max-w-7xl mx-auto min-h-[80vh] w-full  py-16 flex items-center justify-center max-sm:flex-col`}>
    <div class={`flex gap-28 max-md:gap-20 ${!mirror && 'flex-row-reverse'} max-md:flex-col max-md:items-center`}>
    <img data-aos='fade-bounce' src={image} alt={`${description} screenshot`} class='w-max max-h-[500px] max-sm:h-auto max-sm:max-w-full object-contain' />
    <div
      class={`max-sm:py-10 h-full flex flex-col max-sm:items-center gap-10 max-sm:gap-6 ${!mirror && ''}`}
    >
      <img src={logo} alt={`${description} logo`} class='h-[60px] max-sm:h-[40px] w-max' />
      <p
        class='text-lg max-sm:text-base leading-tight text-[#303030]'
        set:html={description.replace(/\*\*(.+?)\*\*/g, '<strong class="font-bold">$1</strong>')}
      ></p>
      <CustomButton
          label="Learn More"
          href={link}
          target="_blank"
          variant="primary"
          className="font-semibold"
        />
    </div>
  </div>
</div>
