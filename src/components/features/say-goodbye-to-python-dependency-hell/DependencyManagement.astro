---
import { getEntry } from 'astro:content'
const Data = await getEntry('features', 'python-dependency-hell')
const data = Data.data
const button = Data.data.button
import ImageCard from '../manage-data-efficiently/ImageCard.astro'
import Card from '../run-data-on-any-cloud/Card.astro'

const features = data.features || [] 
---

<div
  class='min-h-screen w-full py-24 flex items-center justify-center max-md:flex-col  max-sm:px-[20px] max-sm:py-[30px] bg-[#F8FAFC]'
>
  <div class='text-container max-md:w-4/5 w-2/5'>
    <h1 class='text-2calc font-bold mb-8 text-textblack'>{data.title3}</h1>
    <p class='text-lg w-10/12 text-textblack'>{data.description3}</p>
    <a href='/start-free-trail'>
      <button
        class='custom-button bg-primary hover:bg-[#30baba] px-4 py-3 text-white rounded-lg shadow-md flex text-base items-center gap-x-2 mt-10'
        style='font-family: Roboto;'
      >
        {button}
        <img
          class='button-img'
          src='/assets/images/arrowright.svg'
          alt='Arrow right'
        />
      </button>
    </a>
  </div>
  <div
    class='w-2/5 img-container flex flex-row flex-wrap items-between justify-between max-md:my-10'
  >
    <div class="img-container grid grid-cols-2 max-md:grid-cols-1 gap-8 w-[620px]">
      {
        features.map((feature) => (
          <Card
            image={feature.image}
            title={feature.title}
            description={feature.description}
          />
        ))
      }
    </div>
  </div>
</div>
<style>
  .custom-button:hover {
    background-color: #30baba;
  }

  .button-img {
    filter: brightness(0) invert(1);
  }
  @media (max-width: 440px) {
    .container-top {
      width: 100%;
      height: auto;
      padding-left: 15px;
      padding-right: 15px;
      padding-top: 30px;
      padding-bottom: 30px;
      flex-direction: column;
    }
    .text-container {
      width: 100%;
      margin-bottom: 40px;
    }
    .img-container {
      width: 100%;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      row-gap: 20px;
      height: auto;
    }
  }
</style>
