---
import Card from '../run-data-on-any-cloud/Card.astro'
import CustomButton from '../../common/CustomButton.astro'
import { getEntry } from 'astro:content'

const Data = await getEntry('features', 'python-dependency-hell')
const data = Data.data.simplify_dependency_management;
const button = data.button
const features = data.features || [] 
---

<div
  class='min-h-screen w-full py-24 px-[10%] flex items-center justify-center max-md:flex-col max-sm:py-16 bg-[#F8FAFC]'
>
  <div class='text-container max-md:w-4/5 w-2/5' data-aos="fade-right" data-aos-duration="850" data-aos-offset="200">
    <h1 class='text-2calc font-bold mb-8 text-textblack'>{data.title}</h1>
    <p class='text-lg w-10/12 text-textblack'>{data.description}</p>
    <CustomButton 
      label={button.label}
      href={button.href}
      className="mt-10"
    />
  </div>
  <div
    class='w-2/5 img-container flex flex-row flex-wrap items-between justify-between max-md:my-10'
    data-aos="fade-left" data-aos-duration="850" data-aos-offset="200"
  >
    <div class="img-container grid grid-cols-2 max-md:grid-cols-1 gap-8 w-[620px]">
      {
        features.map((feature) => (
          <Card
            image={feature.image}
            title={feature.title}
            description={feature.description}
          />
        ))
      }
    </div>
  </div>
</div>
<style>
  @media (max-width: 440px) {
    .container-top {
      width: 100%;
      height: auto;
      padding-left: 15px;
      padding-right: 15px;
      padding-top: 30px;
      padding-bottom: 30px;
      flex-direction: column;
    }
    .text-container {
      width: 100%;
      margin-bottom: 40px;
    }
    .img-container {
      width: 100%;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      row-gap: 20px;
      height: auto;
    }
  }
</style>
