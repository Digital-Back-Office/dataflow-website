---
import { getEntry } from 'astro:content'

const Data = await getEntry('features', 'shared-foundation')
const comparison = Data?.data?.comparison ?? {
  heading: 'Without vs. With Shared Foundation',
  leftHeading: 'Separate Configurations',
  rightHeading: 'Shared Foundation',
  rows: []
}

const leftHeading = comparison.leftHeading ?? 'Separate Configurations'
const rightHeading = comparison.rightHeading ?? 'Shared Foundation'
---

<section class="py-20 px-[10%]">
  <div class="max-w-7xl mx-auto">
    <h2 class="text-4xl md:text-5xl font-bold text-center mb-8 lg:mb-16 text-textblack">{comparison.heading}</h2>

    <div class="bg-white shadow-md rounded-[50px] overflow-hidden border max-sm:rounded-[20px]">
      <div class="grid grid-cols-2 gap-0">
        <div class="bg-[#EEF2F6] p-6 md:p-8 text-center md:text-left max-sm:p-4">
          <h3 class="text-xl md:text-2xl font-semibold max-sm:text-lg text-center">{leftHeading}</h3>
        </div>
        <div class="bg-[#EEF2F6] p-6 md:p-8 text-center md:text-left max-sm:p-4">
          <h3 class="text-xl md:text-2xl font-semibold max-sm:text-lg text-center">{rightHeading}</h3>
        </div>
      </div>

      <div>
        {comparison.rows && comparison.rows.map((row, idx) => (
          <div class="grid grid-cols-2 first:rounded-t-none border-t border-gray-100">
            <div class="p-4 md:p-8">
              <p class="font-semibold text-sm md:text-base">{row.leftTitle}</p>
              <p class="text-sm text-gray-600 mt-2">{row.leftText}</p>
            </div>
            <div class="p-4 md:p-8">
              <p class="text-[#14B8A6] font-semibold text-sm md:text-base">{row.rightTitle}</p>
              <p class="text-sm text-gray-600 mt-2">{row.rightText}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
