---
import { getEntry } from 'astro:content'

const Data = await getEntry('home', 'home')
const data = Data.data?.enterprise || null

const cards = data?.cards || [
  {
    title: 'Scale Operations',
    description: 'Run thousands of jobs on auto-scaled infrastructure. No DevOps team needed to manage Kubernetes or cloud resources.',
    icon: '/assets/icons/scale.svg'
  },
  {
    title: 'Audit-Ready',
    description: 'Complete audit logs for compliance. Track who changed what, when—from code deployments to data access.',
    icon: '/assets/icons/audit.svg'
  },
  {
    title: 'Secure Access',
    description: 'RBAC permissions, SSO integration, secret encryption. Share environments without exposing credentials.',
    icon: '/assets/icons/secure-access.svg'
  }
]
---

<section class='px-[5%] py-20 max-sm:py-12' style='font-family: Plus Jakarta Sans, sans-serif;'>
  <div class='max-w-7xl mx-auto text-center'>
    <h2 class='text-4xl max-sm:text-3xl font-bold text-gray-900 mb-4' data-aos='fade-up'>
      {data?.title || "Enterprise-Ready from Day One"}
    </h2>
    <p class='text-xl text-gray-600 mb-16 max-w-3xl mx-auto' data-aos='fade-up' data-aos-delay='100'>
      {data?.description || "Security, compliance, and reliability built into every layer—so you can trust your data ops at scale."}
    </p>

    <div class='grid md:grid-cols-3 gap-8'>
      <div class='text-left bg-white rounded-2xl p-8 shadow-sm' data-aos='fade-right' data-aos-delay='200'>
        <div class='w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center mb-4'>
          <svg class='w-6 h-6 text-primary' fill='none' stroke='currentColor' viewBox='0 0 24 24'>
            <path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M13 7h8m0 0v8m0-8l-8 8-4-4-6 6'></path>
          </svg>
        </div>
        <h3 class='text-2xl font-bold text-gray-900 mb-3'>{cards[0].title}</h3>
        <p class='text-gray-600'>
          {cards[0].description}
        </p>
      </div>

      <div class='text-left bg-white rounded-2xl p-8 shadow-sm' data-aos='fade-up' data-aos-delay='300'>
        <div class='w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center mb-4'>
          <svg class='w-6 h-6 text-primary' fill='none' stroke='currentColor' viewBox='0 0 24 24'>
            <path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z'></path>
          </svg>
        </div>
        <h3 class='text-2xl font-bold text-gray-900 mb-3'>{cards[1].title}</h3>
        <p class='text-gray-600'>
          {cards[1].description}
        </p>
      </div>

      <div class='text-left bg-white rounded-2xl p-8 shadow-sm' data-aos='fade-left' data-aos-delay='400'>
        <div class='w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center mb-4'>
          <svg class='w-6 h-6 text-primary' fill='none' stroke='currentColor' viewBox='0 0 24 24'>
            <path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z'></path>
          </svg>
        </div>
        <h3 class='text-2xl font-bold text-gray-900 mb-3'>{cards[2].title}</h3>
        <p class='text-gray-600'>
          {cards[2].description}
        </p>
      </div>
    </div>
  </div>
</section>
