---
import { getEntry } from 'astro:content'

const Data = await getEntry('home', 'home')
const cta = Data.data?.cta || { title1: '', title2: '', description: '', button: '', cta_button: '' }

---

<section class='px-[5%] py-20 bg-gradient-to-br from-primary/5 to-primary/10 max-sm:py-16' style='font-family: Plus Jakarta Sans, sans-serif;'>
  <div class='max-w-4xl mx-auto text-center'>
    <h2 class='text-4xl max-sm:text-3xl font-bold text-gray-900 mb-6' data-aos='fade-up'>
      {cta.title1} {cta.title2}
    </h2>
    <p class='text-xl text-gray-600 mb-8' data-aos='fade-up' data-aos-delay='100'>
      {cta.description}
    </p>
    <div class='flex items-center justify-center gap-4 max-sm:flex-col' data-aos='fade-up' data-aos-delay='200'>
      <a
        href='/start-free-trail'
        class='px-8 py-3 bg-primary hover:bg-primaryHover text-white rounded-lg font-semibold transition-all duration-300 hover:scale-105'
      >
        {cta.button || 'Try it free'}
      </a>
      <a
        href='/book-demo'
        class='px-8 py-3 bg-white hover:bg-gray-50 text-gray-900 rounded-lg font-semibold transition-all duration-300 border-2 border-gray-200 hover:scale-105'
      >
        Talk to us
      </a>
    </div>
  </div>
</section>
