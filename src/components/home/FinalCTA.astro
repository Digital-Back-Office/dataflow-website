---
import { getEntry } from 'astro:content'
import EmailCTA from '../common/EmailCTA.astro'

const Data = await getEntry('home', 'home')
const cta = Data.data?.cta || { title: '', description: '', cta_button_1: '', cta_button_2: '' }
---

<section class='relative overflow-hidden py-24 lg:py-32 max-sm:py-20' style='font-family: Plus Jakarta Sans, sans-serif;'>
  <!-- Gradient Background -->
  <div class='absolute inset-0 bg-gradient-to-br from-primary/10 via-primary/5 to-transparent'></div>
  <div class='absolute inset-0 bg-[radial-gradient(circle_at_30%_50%,rgba(48,186,186,0.1),transparent_50%)]'></div>
  
  <!-- Decorative Elements -->
  <div class='absolute top-0 right-0 w-96 h-96 bg-primary/5 rounded-full blur-3xl'></div>
  <div class='absolute bottom-0 left-0 w-96 h-96 bg-secondary/5 rounded-full blur-3xl'></div>
  
  <div class='relative max-w-5xl mx-auto px-6 lg:px-12 text-center'>
    <!-- Title -->
    <h2 
      class='text-5xl lg:text-6xl max-sm:text-4xl font-bold text-textblack mb-6 leading-tight' 
      data-aos='fade-up'
    >
      {cta.title}
    </h2>
    
    <!-- Description -->
    <p 
      class='text-xl lg:text-2xl text-gray-600 mb-12 max-w-3xl mx-auto leading-relaxed' 
      data-aos='fade-up' 
      data-aos-delay='100'
    >
      {cta.description}
    </p>
    
    <!-- Email CTA Form -->
    <div data-aos="fade-up" data-aos-delay="200" class="mb-4">
      <EmailCTA formId="finalCtaEmailForm" pageSource="homepage-final-cta" />
    </div>
    
    <!-- Trust Indicators -->
    <div class='mt-12 flex items-center justify-center gap-8 text-sm text-gray-500 max-sm:flex-col' data-aos='fade-up' data-aos-delay='300'>
      <div class='flex items-center gap-2'>
        <svg class='w-5 h-5 text-primary' fill='currentColor' viewBox='0 0 20 20'>
          <path fill-rule='evenodd' d='M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z' clip-rule='evenodd'/>
        </svg>
        <span>No credit card required</span>
      </div>
      <div class='flex items-center gap-2'>
        <svg class='w-5 h-5 text-primary' fill='currentColor' viewBox='0 0 20 20'>
          <path fill-rule='evenodd' d='M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z' clip-rule='evenodd'/>
        </svg>
        <span>Free consultation</span>
      </div>
    </div>
  </div>
</section>
