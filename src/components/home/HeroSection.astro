---
interface Props {
  hero: {
    description: string;
  };
}

const { hero } = Astro.props;
const badges = ["No card required", "Free consultation"];
const supportedBy = [
  { name: "Google Cloud", logo: "/assets/images/googlecloudlogo.png" },
  { name: "AWS", logo: "/assets/images/aws-logo.png" },
  { name: "NatWest", logo: "/assets/images/nat-west-logo.png" },
  { name: "NVIDIA", logo: "/assets/images/nvidia-logo.png" },
  { name: "Barclays", logo: "/assets/images/barclays-logo.png" },
];
---

<section
  class="relative px-[5%] pt-32 pb-20 max-sm:pt-24 max-sm:pb-16 flex items-center overflow-hidden"
  style="font-family: Plus Jakarta Sans, sans-serif;"
>
  <!-- Background Pattern with Dataflow Animation -->
  <div class="absolute inset-0 -z-10 overflow-hidden">
    <div
      class="absolute top-0 left-1/4 w-96 h-96 bg-primary/5 rounded-full blur-3xl"
    >
    </div>
    <div
      class="absolute top-20 right-1/4 w-96 h-96 bg-blue-500/5 rounded-full blur-3xl"
    >
    </div>
    <div
      class="absolute bottom-0 left-1/2 w-96 h-96 bg-primary/3 rounded-full blur-3xl"
    >
    </div>
    <!-- Grid Pattern -->
    <div
      class="absolute inset-0"
      style="background-image: radial-gradient(circle at 1px 1px, rgb(203 213 225 / 0.15) 1px, transparent 0); background-size: 40px 40px;"
    >
    </div>

    <!-- Animated Data Flow Nodes -->
    <svg
      id="dataflowSvg"
      class="absolute inset-0 w-full h-full opacity-40 pointer-events-auto"
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 1000 800"
      preserveAspectRatio="xMidYMid slice"
    >
      <!-- Connection Lines -->
      <line
        id="line1"
        x1="200"
        y1="250"
        x2="350"
        y2="400"
        stroke="url(#gradient1)"
        stroke-width="1.5"
        class="flow-line"
        opacity="0"></line>
      <line
        id="line2"
        x1="350"
        y1="400"
        x2="650"
        y2="350"
        stroke="url(#gradient2)"
        stroke-width="1.5"
        class="flow-line"
        opacity="0"></line>
      <line
        id="line3"
        x1="650"
        y1="350"
        x2="800"
        y2="500"
        stroke="url(#gradient3)"
        stroke-width="1.5"
        class="flow-line"
        opacity="0"></line>
      <line
        id="line4"
        x1="350"
        y1="400"
        x2="500"
        y2="550"
        stroke="url(#gradient1)"
        stroke-width="1.5"
        class="flow-line"
        opacity="0"></line>
      <line
        id="line5"
        x1="350"
        y1="400"
        x2="250"
        y2="530"
        stroke="url(#gradient2)"
        stroke-width="1.5"
        class="flow-line"
        opacity="0"></line>
      <line
        id="line6"
        x1="500"
        y1="550"
        x2="700"
        y2="580"
        stroke="url(#gradient3)"
        stroke-width="1.5"
        class="flow-line"
        opacity="0"></line>
      <line
        id="line7"
        x1="650"
        y1="350"
        x2="500"
        y2="270"
        stroke="url(#gradient1)"
        stroke-width="1.5"
        class="flow-line"
        opacity="0"></line>

      <!-- Gradient Definitions -->
      <defs>
        <linearGradient id="gradient1" x1="0%" y1="0%" x2="100%" y2="0%">
          <stop offset="0%" style="stop-color:rgb(48 186 186);stop-opacity:0"
          ></stop>
          <stop offset="50%" style="stop-color:rgb(48 186 186);stop-opacity:0.7"
          ></stop>
          <stop offset="100%" style="stop-color:rgb(48 186 186);stop-opacity:0"
          ></stop>
        </linearGradient>
        <linearGradient id="gradient2" x1="0%" y1="0%" x2="100%" y2="0%">
          <stop offset="0%" style="stop-color:rgb(48 186 186);stop-opacity:0"
          ></stop>
          <stop offset="50%" style="stop-color:rgb(48 186 186);stop-opacity:0.7"
          ></stop>
          <stop offset="100%" style="stop-color:rgb(48 186 186);stop-opacity:0"
          ></stop>
        </linearGradient>
        <linearGradient id="gradient3" x1="0%" y1="0%" x2="100%" y2="0%">
          <stop offset="0%" style="stop-color:rgb(48 186 186);stop-opacity:0"
          ></stop>
          <stop offset="50%" style="stop-color:rgb(48 186 186);stop-opacity:0.7"
          ></stop>
          <stop offset="100%" style="stop-color:rgb(48 186 186);stop-opacity:0"
          ></stop>
        </linearGradient>
      </defs>

      <!-- Data Nodes with Tool Logos -->
      <g
        class="data-node"
        data-target-x="200"
        data-target-y="250"
        data-speed="1.2"
      >
        <circle
          cx="500"
          cy="400"
          r="13"
          fill="white"
          stroke="#30baba"
          stroke-width="1.5"
          fill-opacity="0.95"
          opacity="0"></circle>
        <image
          href="/assets/images/apps/airflow-logo.svg"
          x="491"
          y="391"
          width="18"
          height="18"
          opacity="0"
        />
      </g>

      <g
        class="data-node"
        data-target-x="350"
        data-target-y="400"
        data-speed="0.8"
      >
        <circle
          cx="500"
          cy="400"
          r="16"
          fill="white"
          stroke="#30baba"
          stroke-width="1.5"
          fill-opacity="0.95"
          opacity="0"></circle>
        <image
          href="/assets/images/apps/jupyter.png"
          x="490"
          y="390"
          width="20"
          height="20"
          opacity="0"
        />
      </g>

      <g
        class="data-node"
        data-target-x="650"
        data-target-y="350"
        data-speed="1.0"
      >
        <circle
          cx="500"
          cy="400"
          r="14"
          fill="white"
          stroke="#30baba"
          stroke-width="1.5"
          fill-opacity="0.95"
          opacity="0"></circle>
        <image
          href="/assets/images/apps/vscode-logo.png"
          x="491"
          y="391"
          width="18"
          height="18"
          opacity="0"
        />
      </g>

      <g
        class="data-node"
        data-target-x="800"
        data-target-y="500"
        data-speed="1.3"
      >
        <circle
          cx="500"
          cy="400"
          r="13"
          fill="white"
          stroke="#30baba"
          stroke-width="1.5"
          fill-opacity="0.95"
          opacity="0"></circle>
        <image
          href="/assets/images/apps/streamlit-icon.svg"
          x="491"
          y="391"
          width="18"
          height="18"
          opacity="0"
        />
      </g>

      <g
        class="data-node"
        data-target-x="500"
        data-target-y="550"
        data-speed="0.9"
      >
        <circle
          cx="500"
          cy="400"
          r="12"
          fill="white"
          stroke="#30baba"
          stroke-width="1.5"
          fill-opacity="0.95"
          opacity="0"></circle>
        <image
          href="/assets/images/apps/python-logo.svg"
          x="492"
          y="392"
          width="16"
          height="16"
          opacity="0"
        />
      </g>

      <g
        class="data-node"
        data-target-x="250"
        data-target-y="530"
        data-speed="1.1"
      >
        <circle
          cx="500"
          cy="400"
          r="12"
          fill="white"
          stroke="#30baba"
          stroke-width="1.5"
          fill-opacity="0.95"
          opacity="0"></circle>
        <image
          href="/assets/images/apps/dbt.png"
          x="492"
          y="392"
          width="16"
          height="16"
          opacity="0"
        />
      </g>

      <g
        class="data-node"
        data-target-x="700"
        data-target-y="580"
        data-speed="1.15"
      >
        <circle
          cx="500"
          cy="400"
          r="12"
          fill="white"
          stroke="#30baba"
          stroke-width="1.5"
          fill-opacity="0.95"
          opacity="0"></circle>
        <image
          href="/assets/images/apps/dashapps.png"
          x="492"
          y="392"
          width="16"
          height="16"
          opacity="0"
        />
      </g>

      <g
        class="data-node"
        data-target-x="500"
        data-target-y="270"
        data-speed="0.95"
      >
        <circle
          cx="500"
          cy="400"
          r="13"
          fill="white"
          stroke="#30baba"
          stroke-width="1.5"
          fill-opacity="0.95"
          opacity="0"></circle>
        <image
          href="/assets/images/apps/mlflow.png"
          x="491"
          y="391"
          width="18"
          height="18"
          opacity="0"
        />
      </g>
    </svg>
  </div>

  <div class="max-w-7xl mx-auto relative z-10">
    <div class="text-center mb-8">
      <h1
        class="text-6xl max-sm:text-4xl font-bold text-gray-900 mb-6 leading-tight"
        data-aos="fade-up"
      >
        Focus on Data Logic,<br />Not Glue Code.
      </h1>
      <p
        class="text-xl max-sm:text-lg text-gray-600 mb-8 max-w-3xl mx-auto"
        data-aos="fade-up"
        data-aos-delay="100"
      >
        All your data tools, finally working together—without breaking environments. <br>
        AI ready and Open source tools.
      </p>
      <div
        class="flex items-center justify-center gap-4 mb-8 max-sm:flex-col"
        data-aos="fade-up"
        data-aos-delay="200"
      >
        <a
          href="/start-free-trail"
          class="px-8 py-3 bg-primary hover:bg-primaryHover text-white rounded-lg font-semibold transition-all duration-300"
        >
          Try it free
        </a>
        <a
          href="/book-demo"
          class="px-8 py-3 border-2 border-gray-300 hover:border-primary text-gray-900 rounded-lg font-semibold transition-all duration-300"
        >
          Talk to us
        </a>
      </div>
      <div
        class="flex items-center justify-center gap-8 text-sm text-gray-600 max-sm:flex-col max-sm:gap-4"
        data-aos="fade-up"
        data-aos-delay="300"
      >
        {
          badges.map((label) => (
            <div
              class="flex items-center gap-2"
              data-aos="fade-up"
              data-aos-delay="300"
            >
              <svg
                class="w-5 h-5 text-primary"
                fill="currentColor"
                viewBox="0 0 20 20"
              >
                <path
                  fill-rule="evenodd"
                  d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                  clip-rule="evenodd"
                />
              </svg>
              <span>{label}</span>
            </div>
          ))
        }
      </div>
    </div>

    <div class="mt-20 w-full flex flex-col items-center justify-center">
      <p class="text-center text-sm text-gray-500 mb-6">Powered by</p>
      <div class="flex items-center gap-10">
        {
          supportedBy.map((partner) => (
            <img
              src={partner.logo}
              alt={partner.name}
              class="h-[25px] max-sm:h-[30px] grayscale"
            />
          ))
        }
      </div>
    </div>
  </div>
</section>
