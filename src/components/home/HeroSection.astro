---
import { getEntry } from 'astro:content'

const Data = await getEntry('home', 'home')
const hero = Data.data?.hero || {
  title: '',
  description: '',
  subtitle: '',
  primary_cta: { text: '', href: '' },
  secondary_cta: { text: '', href: '' },
  cta_button: '',
  badges: [],
  supported_by: []
}
---

<section
  id="hero-section"
  class="relative px-[5%] pt-32 pb-24 max-sm:pt-24 max-sm:pb-16 flex flex-col items-center"
  style="font-family: Plus Jakarta Sans, sans-serif;"
>
  <!-- Background Pattern with Dataflow Animation -->
  <div class="absolute inset-0 -z-10 overflow-hidden opacity-35">
    <div
      class="absolute top-0 left-1/4 w-96 h-96 bg-primary/5 rounded-full blur-3xl"
    >
    </div>
    <div
      class="absolute top-20 right-1/4 w-96 h-96 bg-blue-500/5 rounded-full blur-3xl"
    >
    </div>
    <div
      class="absolute bottom-0 left-1/2 w-96 h-96 bg-primary/3 rounded-full blur-3xl"
    >
    </div>
    <!-- Grid Pattern -->
    <div
      class="absolute inset-0"
      style="background-image: radial-gradient(circle at 1px 1px, rgb(203 213 225 / 0.15) 1px, transparent 0); background-size: 40px 40px;"
    >
    </div>

    <!-- Animated Data Flow Nodes -->
    <svg
      id="dataflowSvg"
      class="absolute inset-0 w-full h-full opacity-40 pointer-events-auto"
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 1000 800"
      preserveAspectRatio="xMidYMid slice"
    >
      <!-- Connection Lines -->
      <line
        id="line1"
        x1="200"
        y1="250"
        x2="350"
        y2="400"
        stroke="url(#gradient1)"
        stroke-width="1.5"
        class="flow-line"
        opacity="0"></line>
      <line
        id="line2"
        x1="350"
        y1="400"
        x2="650"
        y2="350"
        stroke="url(#gradient2)"
        stroke-width="1.5"
        class="flow-line"
        opacity="0"></line>
      <line
        id="line3"
        x1="650"
        y1="350"
        x2="800"
        y2="500"
        stroke="url(#gradient3)"
        stroke-width="1.5"
        class="flow-line"
        opacity="0"></line>
      <line
        id="line4"
        x1="350"
        y1="400"
        x2="500"
        y2="550"
        stroke="url(#gradient1)"
        stroke-width="1.5"
        class="flow-line"
        opacity="0"></line>
      <line
        id="line5"
        x1="350"
        y1="400"
        x2="250"
        y2="530"
        stroke="url(#gradient2)"
        stroke-width="1.5"
        class="flow-line"
        opacity="0"></line>
      <line
        id="line6"
        x1="500"
        y1="550"
        x2="700"
        y2="580"
        stroke="url(#gradient3)"
        stroke-width="1.5"
        class="flow-line"
        opacity="0"></line>
      <line
        id="line7"
        x1="650"
        y1="350"
        x2="500"
        y2="270"
        stroke="url(#gradient1)"
        stroke-width="1.5"
        class="flow-line"
        opacity="0"></line>
      <line
        id="line8"
        x1="200"
        y1="250"
        x2="150"
        y2="380"
        stroke="url(#gradient2)"
        stroke-width="1.5"
        class="flow-line"
        opacity="0"></line>
      <line
        id="line9"
        x1="800"
        y1="500"
        x2="850"
        y2="350"
        stroke="url(#gradient3)"
        stroke-width="1.5"
        class="flow-line"
        opacity="0"></line>
      <line
        id="line10"
        x1="500"
        y1="270"
        x2="350"
        y2="180"
        stroke="url(#gradient1)"
        stroke-width="1.5"
        class="flow-line"
        opacity="0"></line>
      <line
        id="line11"
        x1="700"
        y1="580"
        x2="800"
        y2="650"
        stroke="url(#gradient2)"
        stroke-width="1.5"
        class="flow-line"
        opacity="0"></line>
      <line
        id="line12"
        x1="250"
        y1="530"
        x2="180"
        y2="650"
        stroke="url(#gradient3)"
        stroke-width="1.5"
        class="flow-line"
        opacity="0"></line>

      <!-- Gradient Definitions -->
      <defs>
        <linearGradient id="gradient1" x1="0%" y1="0%" x2="100%" y2="0%">
          <stop offset="0%" style="stop-color:rgb(48 186 186);stop-opacity:0"
          ></stop>
          <stop offset="50%" style="stop-color:rgb(48 186 186);stop-opacity:0.7"
          ></stop>
          <stop offset="100%" style="stop-color:rgb(48 186 186);stop-opacity:0"
          ></stop>
        </linearGradient>
        <linearGradient id="gradient2" x1="0%" y1="0%" x2="100%" y2="0%">
          <stop offset="0%" style="stop-color:rgb(48 186 186);stop-opacity:0"
          ></stop>
          <stop offset="50%" style="stop-color:rgb(48 186 186);stop-opacity:0.7"
          ></stop>
          <stop offset="100%" style="stop-color:rgb(48 186 186);stop-opacity:0"
          ></stop>
        </linearGradient>
        <linearGradient id="gradient3" x1="0%" y1="0%" x2="100%" y2="0%">
          <stop offset="0%" style="stop-color:rgb(48 186 186);stop-opacity:0"
          ></stop>
          <stop offset="50%" style="stop-color:rgb(48 186 186);stop-opacity:0.7"
          ></stop>
          <stop offset="100%" style="stop-color:rgb(48 186 186);stop-opacity:0"
          ></stop>
        </linearGradient>
      </defs>

      <!-- Data Nodes with Tool Logos -->
      <g
        class="data-node"
        data-target-x="200"
        data-target-y="250"
        data-speed="1.2"
        data-name="Airflow"
      >
        <circle
          cx="500"
          cy="400"
          r="13"
          fill="white"
          stroke="#30baba"
          stroke-width="1.5"
          fill-opacity="0.95"
          opacity="0"></circle>
        <image
          href="/assets/images/apps/airflow-logo.svg"
          x="491"
          y="391"
          width="18"
          height="18"
          opacity="0"
        />
      </g>

      <g
        class="data-node"
        data-target-x="350"
        data-target-y="400"
        data-speed="0.8"
        data-name="Jupyter"
      >
        <circle
          cx="500"
          cy="400"
          r="16"
          fill="white"
          stroke="#30baba"
          stroke-width="1.5"
          fill-opacity="0.95"
          opacity="0"></circle>
        <image
          href="/assets/images/apps/jupyter.png"
          x="490"
          y="390"
          width="20"
          height="20"
          opacity="0"
        />
      </g>

      <g
        class="data-node"
        data-target-x="650"
        data-target-y="350"
        data-speed="1.0"
        data-name="VS Code"
      >
        <circle
          cx="500"
          cy="400"
          r="14"
          fill="white"
          stroke="#30baba"
          stroke-width="1.5"
          fill-opacity="0.95"
          opacity="0"></circle>
        <image
          href="/assets/images/apps/vscode-logo.png"
          x="491"
          y="391"
          width="18"
          height="18"
          opacity="0"
        />
      </g>

      <g
        class="data-node"
        data-target-x="800"
        data-target-y="500"
        data-speed="1.3"
        data-name="Streamlit"
      >
        <circle
          cx="500"
          cy="400"
          r="13"
          fill="white"
          stroke="#30baba"
          stroke-width="1.5"
          fill-opacity="0.95"
          opacity="0"></circle>
        <image
          href="/assets/images/apps/streamlit-icon.svg"
          x="491"
          y="391"
          width="18"
          height="18"
          opacity="0"
        />
      </g>

      <g
        class="data-node"
        data-target-x="500"
        data-target-y="550"
        data-speed="0.9"
        data-name="Python"
      >
        <circle
          cx="500"
          cy="400"
          r="12"
          fill="white"
          stroke="#30baba"
          stroke-width="1.5"
          fill-opacity="0.95"
          opacity="0"></circle>
        <image
          href="/assets/images/apps/python-logo.svg"
          x="492"
          y="392"
          width="16"
          height="16"
          opacity="0"
        />
      </g>

      <g
        class="data-node"
        data-target-x="250"
        data-target-y="530"
        data-speed="1.1"
        data-name="dbt"
      >
        <circle
          cx="500"
          cy="400"
          r="12"
          fill="white"
          stroke="#30baba"
          stroke-width="1.5"
          fill-opacity="0.95"
          opacity="0"></circle>
        <image
          href="/assets/images/apps/dbt.png"
          x="492"
          y="392"
          width="16"
          height="16"
          opacity="0"
        />
      </g>

      <g
        class="data-node"
        data-target-x="700"
        data-target-y="580"
        data-speed="1.15"
        data-name="Dash"
      >
        <circle
          cx="500"
          cy="400"
          r="12"
          fill="white"
          stroke="#30baba"
          stroke-width="1.5"
          fill-opacity="0.95"
          opacity="0"></circle>
        <image
          href="/assets/images/apps/dashapps.png"
          x="492"
          y="392"
          width="16"
          height="16"
          opacity="0"
        />
      </g>

      <g
        class="data-node"
        data-target-x="500"
        data-target-y="270"
        data-speed="0.95"
        data-name="MLflow"
      >
        <circle
          cx="500"
          cy="400"
          r="13"
          fill="white"
          stroke="#30baba"
          stroke-width="1.5"
          fill-opacity="0.95"
          opacity="0"></circle>
        <image
          href="/assets/images/apps/mlflow.png"
          x="491"
          y="391"
          width="18"
          height="18"
          opacity="0"
        />
      </g>

      <!-- Additional Nodes -->
      <g
        class="data-node"
        data-target-x="150"
        data-target-y="380"
        data-speed="1.25"
        data-name="VS Code"
      >
        <circle
          cx="500"
          cy="400"
          r="13"
          fill="white"
          stroke="#30baba"
          stroke-width="1.5"
          fill-opacity="0.95"
          opacity="0"></circle>
        <image
          href="/assets/images/apps/vscode-logo.png"
          x="491"
          y="391"
          width="18"
          height="18"
          opacity="0"
        />
      </g>

      <g
        class="data-node"
        data-target-x="850"
        data-target-y="350"
        data-speed="0.85"
        data-name="Jupyter"
      >
        <circle
          cx="500"
          cy="400"
          r="14"
          fill="white"
          stroke="#30baba"
          stroke-width="1.5"
          fill-opacity="0.95"
          opacity="0"></circle>
        <image
          href="/assets/images/apps/jupyter.png"
          x="490"
          y="390"
          width="20"
          height="20"
          opacity="0"
        />
      </g>

      <g
        class="data-node"
        data-target-x="350"
        data-target-y="180"
        data-speed="1.05"
        data-name="Python"
      >
        <circle
          cx="500"
          cy="400"
          r="12"
          fill="white"
          stroke="#30baba"
          stroke-width="1.5"
          fill-opacity="0.95"
          opacity="0"></circle>
        <image
          href="/assets/images/apps/python-logo.svg"
          x="492"
          y="392"
          width="16"
          height="16"
          opacity="0"
        />
      </g>

      <g
        class="data-node"
        data-target-x="800"
        data-target-y="650"
        data-speed="0.92"
        data-name="Airflow"
      >
        <circle
          cx="500"
          cy="400"
          r="13"
          fill="white"
          stroke="#30baba"
          stroke-width="1.5"
          fill-opacity="0.95"
          opacity="0"></circle>
        <image
          href="/assets/images/apps/airflow-logo.svg"
          x="491"
          y="391"
          width="18"
          height="18"
          opacity="0"
        />
      </g>

      <g
        class="data-node"
        data-target-x="180"
        data-target-y="650"
        data-speed="1.18"
        data-name="dbt"
      >
        <circle
          cx="500"
          cy="400"
          r="12"
          fill="white"
          stroke="#30baba"
          stroke-width="1.5"
          fill-opacity="0.95"
          opacity="0"></circle>
        <image
          href="/assets/images/apps/dbt.png"
          x="492"
          y="392"
          width="16"
          height="16"
          opacity="0"
        />
      </g>
    </svg>
  </div>

  <div class="max-w-7xl mx-auto relative z-10 text-center">
    <div class="mb-12">
      <h1
        class="text-6xl max-sm:text-4xl font-bold text-gray-900 mb-6 leading-tight"
        data-aos="fade-up"
      >
        {(hero?.title || 'All your data tools, finally working together—without breaking environments. <br/> AI ready and Open source tools.')
          .split(/<br\s*\/?>/i)
          .map((line, i, arr) => (
            <span>
              {line}
              {i !== arr.length - 1 && <br />}
            </span>
          ))}
      </h1>
      <p
        class="text-xl max-sm:text-lg text-gray-600 mb-8 max-w-3xl mx-auto"
        data-aos="fade-up"
        data-aos-delay="100"
      >
        {
          (hero?.description || 'All your data tools, finally working together—without breaking environments. <br/> AI ready and Open source tools.')
            .split(/<br\s*\/?>/i)
            .map((line, i, arr) => (
              <span>
                {line}
                {i !== arr.length - 1 && <br />}
              </span>
            ))
        }</p>
      <div
        class="flex items-center justify-center gap-4 mb-8 max-sm:flex-col"
        data-aos="fade-up"
        data-aos-delay="200"
      >
        <a
          href={hero.primary_cta?.href || '#'}
          target={hero.primary_cta?.target || '_self'}
          class="px-8 py-3 bg-primary hover:bg-primaryHover text-white rounded-lg font-semibold transition-all duration-300"
        >
          {hero.primary_cta?.text || 'Try it free'}
        </a>
        <a
          href={hero.secondary_cta?.href || '#'}
          target={hero.secondary_cta?.target || '_self'}
          class="px-8 py-3 border-2 bg-white border-gray-300 hover:border-primary text-gray-900 rounded-lg font-semibold transition-all duration-300"
        >
          {hero.secondary_cta?.text || 'Talk to us'}
        </a>
      </div>
      <div
        class="flex items-center justify-center gap-8 text-sm text-gray-600 max-sm:flex-col max-sm:gap-4"
        data-aos="fade-up"
        data-aos-delay="300"
      >
        {
          (hero.badges || []).map((label) => (
            <div
              class="flex items-center gap-2"
              data-aos="fade-up"
              data-aos-delay="350"
            >
              <svg
                class="w-5 h-5 text-primary"
                fill="currentColor"
                viewBox="0 0 20 20"
              >
                <path
                  fill-rule="evenodd"
                  d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                  clip-rule="evenodd"
                />
              </svg>
              <span>{label}</span>
            </div>
          ))
        }
      </div>
    </div>

    
    <!-- Platform Screenshot (Full) -->
    <div 
      class="relative w-full max-w-6xl mx-auto mt-16"
      data-aos="fade-up"
      data-aos-delay="400"
    >
      <!-- Animated Arrow Pointer -->
      <div class="absolute -top-36 -right-28   max-sm:hidden z-20 pointer-animation">
        <div class="flex flex-col items-center gap-2">
          <p class="text-sm font-medium text-gray-700 text-center tracking-wide">Hover to Try Demo</p>
          <img 
            src="/assets/icons/hero-arrow.svg" 
            alt="Arrow pointing to demo" 
            class="w-16 h-auto opacity-70 -ml-2"
          />
        </div>
      </div>

      <div 
        class="relative rounded-2xl overflow-hidden shadow-2xl border-4 border-gray-200/50 group cursor-pointer"
        onclick="document.getElementById('arcadeModal').classList.remove('hidden')"
      >
        <img 
          src="/assets/images/app-screenshots/dashboard.png" 
          alt="Dataflow Platform Dashboard" 
          class="w-full h-auto block transition-all duration-500 group-hover:scale-[1.02]"
        />
        <!-- Overlay gradient -->
        <div class="absolute inset-0 bg-gradient-to-t from-black/5 to-transparent pointer-events-none"></div>
        
        <!-- Hover Overlay with "Try Dataflow Demo" -->
        <div class="absolute inset-0 bg-white/60 backdrop-blur-sm opacity-0 group-hover:opacity-100 transition-all duration-500 flex items-center justify-center">
          <div class="text-center transform scale-95 group-hover:scale-100 transition-transform duration-500">
            <div class="w-16 h-16 mx-auto mb-4 rounded-full bg-primary/10 flex items-center justify-center">
              <svg class="w-8 h-8 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"></path>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
            </div>
            <h3 class="text-2xl font-semibold text-gray-900 mb-1">Try Dataflow Demo</h3>
            <p class="text-gray-600 text-sm">Interactive walkthrough</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Powered By Section -->
     <div 
      class="mt-20 w-full flex flex-col items-center justify-center"
      data-aos="fade-up"
      data-aos-delay="500"
    >
      <p 
        class="text-center text-sm text-gray-500 mb-6 tracking-wider"
        data-aos="fade-up"
        data-aos-delay="600"
      >
        Powered by
      </p>
      <div class="flex items-center gap-10 max-sm:gap-6 flex-wrap justify-center">
        {
          (hero.supported_by || []).map((partner, index) => (
            <img
              src={partner.logo}
              alt={partner.name}
              class="h-[25px] max-sm:h-[30px] grayscale hover:grayscale-0 transition-all duration-300 opacity-60 hover:opacity-100"
              data-aos="zoom-in"
              data-aos-delay={500 + index * 100}
            />
          ))
        }
      </div>
  </div>
</section>

<style>
  @keyframes pointer-fade {
    0%, 100% {
      opacity: 0.6;
    }
    50% {
      opacity: 1;
    }
  }

  .pointer-animation {
    animation: pointer-fade 2.5s ease-in-out infinite;
  }
</style>
