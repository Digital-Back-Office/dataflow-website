---
import { getEntry } from 'astro:content'

const data = await getEntry('home', 'home')
const how_it_works = data.data.how_it_works
const steps = how_it_works.steps || []
---

<style>
  /* Wrapper to lock height and allow slide stacking */
  .step-wrapper {
    position: relative;
    height: 520px; /* adjust if content is taller */
    overflow: hidden;
  }

  /* Individual step */
  .step-container {
    position: absolute;
    inset: 0;
    transform: translateY(100%);
    opacity: 0;
    transition: transform 0.7s ease, opacity 0.5s ease;
    pointer-events: none;
  }

  /* Active step (visible) */
  .step-container.active {
    transform: translateY(0);
    opacity: 1;
    pointer-events: auto;
    z-index: 2;
  }

  /* Previous step (slides up and out) */
  .step-container.prev {
    transform: translateY(-100%);
    opacity: 0;
    z-index: 1;
  }

  .step-indicator {
    background-color: #E5E7EB;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .step-indicator.active {
    background-color: #14B8A6;
    width: 32px;
    height: 8px;
    border-radius: 4px;
  }

  .step-indicator:hover {
    background-color: #0D9488;
  }
</style>

<section class="w-full" id="how-it-works-section">
  <div class="flex flex-col gap-4 justify-center py-24 max-sm:py-16 bg-white">
    <div class="max-w-7xl mx-auto px-8 max-sm:px-6 w-full">

      <!-- Title -->
      <div class="text-center mb-20" data-aos="fade-up" data-aos-duration="700" data-aos-offset="200">
        <h2 class="text-5xl max-sm:text-3xl font-bold text-[#1A1A1A] mb-4">
          {how_it_works.title}
        </h2>
      </div>

      <!-- Steps -->
      <div class="step-wrapper w-full">
        {steps.map((step, index) => (
          <div class="step-container w-full" data-step={index}>
            <div class="flex gap-12 max-sm:gap-6 items-start max-sm:flex-col">
              
              <div class="flex-1">
                <div class="flex items-start gap-6">
                  <div class="flex-shrink-0 flex flex-col items-center">
                    <div class="w-14 h-14 max-sm:w-12 max-sm:h-12 rounded-full bg-[#14B8A6] flex items-center justify-center">
                      <span class="text-white text-3xl max-sm:text-2xl font-bold">
                        {index + 1}
                      </span>
                    </div>
                    <div class="w-[4px] h-72 bg-gradient-to-b from-[#14B8A6] via-[#d8fffc] to-white"></div>
                  </div>

                  <div class="flex-1 pt-2">
                    <h3 class="text-4xl max-sm:text-2xl font-bold text-[#1A1A1A] mb-8">
                      {step.title}
                    </h3>

                    <div class="space-y-4">
                      <p class="text-lg max-sm:text-base text-[#4A5568] leading-relaxed">
                        {step.description_1}
                      </p>
                      {step.description_2 && (
                        <p class="text-lg max-sm:text-base text-[#4A5568] leading-relaxed">
                          {step.description_2}
                        </p>
                      )}
                    </div>
                  </div>
                </div>
              </div>

              <div class="flex-1 max-lg:hidden">
                <img
                  src={step.image}
                  alt={step.title}
                  class="w-full h-auto rounded-3xl object-cover"
                />
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- Indicators -->
      <div class="flex justify-center gap-3 mt-12">
        {steps.map((_, index) => (
          <button
            class="step-indicator w-3 h-3 rounded-full"
            data-step={index}
            aria-label={`Go to step ${index + 1}`}
          ></button>
        ))}
      </div>
    </div>
  </div>

  <script is:inline>
    function initHowItWorks() {
      let currentStep = 0
      let previousStep = null

      const section = document.getElementById('how-it-works-section')
      if (!section) return

      const stepContainers = section.querySelectorAll('.step-container')
      const stepIndicators = section.querySelectorAll('.step-indicator')
      const totalSteps = stepContainers.length

      function updateStep(step) {
        if (step < 0 || step >= totalSteps || step === currentStep) return

        previousStep = currentStep
        currentStep = step

        stepContainers.forEach((container, index) => {
          container.classList.remove('active', 'prev')

          if (index === currentStep) {
            container.classList.add('active')
          } else if (index === previousStep) {
            container.classList.add('prev')
          }
        })

        stepIndicators.forEach((indicator, index) => {
          indicator.classList.toggle('active', index === currentStep)
        })
      }

      // Scroll navigation disabled (commented out per request)
      // let lastScrollTime = 0
      // section.addEventListener(
      //   'wheel',
      //   (e) => {
      //     const now = Date.now()
      //     if (now - lastScrollTime < 700) return
      //     lastScrollTime = now
      //
      //     if (e.deltaY > 0) updateStep(currentStep + 1)
      //     else updateStep(currentStep - 1)
      //   },
      //   { passive: true }
      // )

      /* Keyboard navigation */
      document.addEventListener('keydown', (e) => {
        if (e.key === 'ArrowDown') updateStep(currentStep + 1)
        if (e.key === 'ArrowUp') updateStep(currentStep - 1)
      })

      /* Indicator click navigation */
      stepIndicators.forEach((indicator, index) => {
        indicator.addEventListener('click', () => updateStep(index))
      })

      /* Init first step */
      stepContainers[0]?.classList.add('active')
      stepIndicators[0]?.classList.add('active')
    }

    document.readyState === 'loading'
      ? document.addEventListener('DOMContentLoaded', initHowItWorks)
      : initHowItWorks()
  </script>
</section>
