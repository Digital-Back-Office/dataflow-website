---
import { getEntry } from 'astro:content'

const Data = await getEntry('pricing', 'consultation')
const data = Data.data
---

<div
  class='min-h-[80vh] bg-gradient-to-b from-white from-5% via-[#30BABA95] via-50% to-white to-95% flex items-center justify-center font-helvetica-neue relative'
>
  <div class='flex gap-24 items-center max-sm:flex-col max-sm:gap-10'>
    <div class=''>
      <p class='text-4calc text-textPrimary leading-none font-normal'>
        {data.description}
      </p>
      <p class='text-4calc leading-none font-bold text-textPrimary'>
        {data.title_1}
        <br />
        {data.title_2}
      </p>
    </div>
    
    <a href={data.button.href || '#'}>
        <button
            class="min-w-[400px] max-md:min-w-[100px] px-[30px] py-[15px] max-sm:px-[20px] max-sm:py-[8px] mb-[50px] bg-white hover:bg-[#f9f9f9] font-arimo rounded-md inline-flex items-center justify-center text-lg max-sm:text-md font-semibold tracking-wide shadow-md text-[#30BABA]"
        >
           {data.button.text}
        </button>
    </a>
  </div>

