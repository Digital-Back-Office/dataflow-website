---
import { getEntry } from 'astro:content'
import CustomButton from '../common/CustomButton.astro'

const Data = await getEntry('pricing', 'consultation')
const data = Data.data
---

<section
  data-aos="fade-in" 
  data-aos-duration="850" 
  data-aos-offset="200"
  class='min-h-[70vh] bg-gradient-to-b from-white from-5% via-[#30BABA95] via-50% to-white to-95% flex items-center justify-center relative py-24 max-sm:py-16'
>
  <div class='relative max-w-6xl mx-auto px-6 max-sm:px-4 w-full'>
    <div class='overflow-hidden'>
      <div class='flex flex-col lg:flex-row items-center justify-between gap-12 p-12 max-lg:p-10 max-sm:p-6'>
        
        <!-- Left Content -->
        <div class='flex-1 space-y-6 max-lg:text-center'>
          <div class='space-y-4'>
            <p class='text-3xl text-gray-600 font-medium max-sm:text-base'>
              {data.description}
            </p>
            <h2 class='text-6xl max-lg:text-4xl max-sm:text-3xl font-black text-textDarker leading-tight'>
              {data.title_1}
              <br />
              <span class=''>{data.title_2}</span>
            </h2>
          </div>
          
          <p class='text-gray-600 text-lg max-sm:text-base max-w-xl max-lg:mx-auto'>
            Schedule a personalized demo and discover how Dataflow can transform your data operations. Our team is ready to answer your questions.
          </p>
        </div>
        
        <!-- Right CTA -->
        <div class='flex-shrink-0 flex flex-col items-center gap-4'>
          <div class='relative'>  
            <div class='relative'>
              <CustomButton 
                label={data.button?.text || "Book a Demo"}
                href="/book-demo"
                variant="primary"
                className="text-lg px-8 py-4 max-sm:px-6 max-sm:py-3 max-sm:text-base"
              />
            </div>
          </div>
          
          <div class='flex items-center gap-6 text-sm  max-sm:flex-col max-sm:gap-2'>
            <div class='flex items-center gap-2'>
              <svg class='w-5 h-5 text-primary' fill='currentColor' viewBox='0 0 20 20'>
                <path fill-rule='evenodd' d='M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z' clip-rule='evenodd'/>
              </svg>
              <span>Free consultation</span>
            </div>
            <div class='flex items-center gap-2'>
              <svg class='w-5 h-5 text-primary' fill='currentColor' viewBox='0 0 20 20'>
                <path fill-rule='evenodd' d='M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z' clip-rule='evenodd'/>
              </svg>
              <span>No commitment</span>
            </div>
          </div>
        </div>
        
      </div>
    </div>
  </div>
</section>
