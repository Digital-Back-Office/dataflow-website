---
import Layout from "./Layout.astro";

export interface Props {
  title?: string;
  meta_description?: string;
  ogImage?: string;
  pageSchema?: Record<string, unknown> | Array<Record<string, unknown>>;
}

const {
  title = "AI-ready data platform blog",
  meta_description = "Read practical insights on data engineering, AI, and modern data workflows from Dataflow.",
  ogImage,
  pageSchema,
} = Astro.props;
---

<Layout
  title={title}
  meta_description={meta_description}
  ogImage={ogImage}
  pageSchema={pageSchema}
>
  <slot />
</Layout>
