---
import Footer from '../components/common/Footer.astro'
import Header from '../components/common/Header.astro'

import '../styles/global.css'
export interface Props {
  title?: string
}

const { title = 'Dataflow | AI ready data platform' } = Astro.props
---

<script src='/src/scripts/cookie-consent.js'></script>
<!-- <script src="/src/scripts/chat-bot.js"></script> -->
<html lang='en' data-bs-theme='light'>
  <head>
    <!-- Google tag (gtag.js) -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-D5Y7ZFCM96"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-D5Y7ZFCM96');
    </script>
    <script is:inline src="https://t.contentsquare.net/uxa/96d450d7e9094.js"></script>
    <meta charset='UTF-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1.0' />
    <link rel='icon' type='image/x-icon' href='/favicon.png' />
    <!-- AOS Animations -->
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">
    <script src="https://unpkg.com/aos@2.3.1/dist/aos.js" defer></script>
    
    <!-- Import Google fonts -->
    <link rel='preconnect' href='https://fonts.googleapis.com' />
    <link rel='preconnect' href='https://fonts.gstatic.com' crossorigin />
    <link
      href='https://fonts.googleapis.com/css2?family=Helvetica+Neue:wght@400;700&family=Roboto:wght@400;700&family=Arimo:wght@400;700&display=swap'
      rel='stylesheet'
    />

    <title>{title}</title>
    <!-- Open Graph Meta Tags -->
    <meta property='og:title' content='Dataflow | AI ready data platform' />
    <meta
      property='og:description'
      content='AI ready data platform in less than 30 minutes'
    />
    <meta property='og:image' content='https://dataflow.zone/og-image.png' />
    <meta property='og:url' content='https://dataflow.zone' />
    <meta property='og:type' content='website' />
    <meta property='og:site_name' content='dataflow.zone' />
  </head>
  <body id='body'>
    <Header />
    <div class=''>
      <slot />
    </div>
    <Footer />
    <script is:inline>
      document.addEventListener('DOMContentLoaded', () => {
        if (window.AOS) {
          AOS.init();
        }
      });
    </script>
  </body>
</html>
