---
import CustomButton from '../components/common/CustomButton.astro'
import Layout from '../layouts/Layout.astro'

const meta_description = 'Page not found - Dataflow AI ready data platform'
---

<Layout title='404 - Page Not Found' meta_description={meta_description}>
  <section 
    class="relative h-screen pt-20 flex flex-col items-center justify-center bg-gradient-to-b from-white via-primary/5 to-white overflow-hidden px-6"
  >
    <!-- Decorative blur elements -->
    <div class="absolute top-20 right-20 w-96 h-96 bg-primary/10 rounded-full blur-3xl animate-pulse"></div>
    <div class="absolute bottom-20 left-20 w-96 h-96 bg-secondary/10 rounded-full blur-3xl animate-pulse" style="animation-delay: 1s;"></div>
    
    <div class="relative max-w-4xl mx-auto text-center z-10">
      <!-- 404 Number with animated gradient -->
      <div 
        class="mb-8" 
        data-aos="fade-down"
      >
        <h1 
          class="text-[80px] max-md:text-[120px] max-sm:text-[80px] font-bold leading-none bg-gradient-to-r from-primary via-secondary to-primary bg-clip-text text-transparent"
          style="background-size: 200% auto; animation: gradient-shift 3s ease infinite;"
        >
          404
        </h1>
      </div>

      <!-- Main message -->
      <div class="mb-6" data-aos="fade-up" data-aos-delay="100">
        <h2 class="text-2xl max-md:text-3xl max-sm:text-2xl font-bold text-textDarker mb-4">
          Oops! Page Not Found
        </h2>
        <p class="text-base max-sm:text-base text-gray-600 max-w-2xl mx-auto leading-relaxed">
          The page you're looking for seems to have wandered off into the data cloud. 
          Don't worry though, we can help you get back on track!
        </p>
      </div>

      <!-- Illustration/Icon -->
      <div 
        class="my-8 max-sm:my-8" 
        data-aos="zoom-in" 
        data-aos-delay="200"
      >
        <div class="relative inline-block">
          <!-- Animated rings -->
          <div class="absolute inset-0 flex items-center justify-center">
            <div class="w-64 h-64 max-sm:w-48 max-sm:h-48 border-4 border-primary/20 rounded-full animate-ping" style="animation-duration: 3s;"></div>
          </div>
          <div class="absolute inset-0 flex items-center justify-center">
            <div class="w-48 h-48 max-sm:w-36 max-sm:h-36 border-4 border-secondary/20 rounded-full animate-ping" style="animation-duration: 2s; animation-delay: 0.5s;"></div>
          </div>
          
          <!-- Center icon -->
          <div class="relative w-64 h-64 max-sm:w-48 max-sm:h-48 flex items-center justify-center">
            <div class="w-32 h-32 max-sm:w-24 max-sm:h-24 bg-gradient-to-br from-primary to-secondary rounded-2xl flex items-center justify-center shadow-lg transform hover:rotate-12 transition-transform duration-300">
              <svg class="w-16 h-16 max-sm:w-12 max-sm:h-12 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
            </div>
          </div>
        </div>
      </div>

      <!-- Action buttons -->
      <div 
        class="flex flex-col sm:flex-row gap-4 items-center justify-center mb-12" 
        data-aos="fade-up" 
        data-aos-delay="300"
      >
        <CustomButton
            label='Back to Home'
            href='/'
        />
    
      </div>

    </div>

    <!-- Floating elements for visual interest -->
    <div class="absolute top-1/4 left-10 max-sm:left-4">
      <div 
        class="w-16 h-16 max-sm:w-12 max-sm:h-12 bg-primary/10 rounded-lg transform rotate-12 animate-bounce" 
        style="animation-duration: 3s;"
      ></div>
    </div>
    <div class="absolute top-1/3 right-10 max-sm:right-4">
      <div 
        class="w-20 h-20 max-sm:w-16 max-sm:h-16 bg-secondary/10 rounded-full animate-bounce" 
        style="animation-duration: 4s; animation-delay: 1s;"
      ></div>
    </div>
    <div class="absolute bottom-1/4 right-1/4 max-sm:right-8">
      <div 
        class="w-12 h-12 max-sm:w-10 max-sm:h-10 bg-primary/10 rounded-lg transform -rotate-12 animate-bounce" 
        style="animation-duration: 3.5s; animation-delay: 0.5s;"
      ></div>
    </div>
  </section>
</Layout>

<style>
  @keyframes gradient-shift {
    0%, 100% {
      background-position: 0% 50%;
    }
    50% {
      background-position: 100% 50%;
    }
  }
</style>
