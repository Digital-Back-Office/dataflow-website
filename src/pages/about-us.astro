---
import OurJourney from '../components/company/OurJourney.astro'
import TopSection from '../components/company/TopSection.astro'
import TeamMembers from '../components/company/TeamMembers.astro'
import Layout from '../layouts/Layout.astro'
import JoinTeam from '../components/company/JoinTeam.astro'
import YourJourney from '../components/company/YourJourney.astro'
import SupportedBy from '../components/common/SupportedBy.astro'
import { getEntry } from 'astro:content'

const companyData = await getEntry('company', 'company')
const seo = companyData?.data?.seo
---

<Layout
  title={seo?.title ?? 'About Dataflow | Built by Data Engineers, for Data Engineers'}
  meta_description={seo?.description ?? "Dataflow was founded in 2023 to give engineers their time back. Learn about our mission, team and why we're building the OS for modern data teams."}
>
  <TopSection />
  <OurJourney />
  <TeamMembers />
  <JoinTeam />
  <YourJourney />
  <SupportedBy />
  <section class='px-[5%] pb-20'>
    <div class='max-w-5xl mx-auto text-center text-sm text-gray-600'>
      Explore what we build on <a href='/product/deploy-to-production' class='text-primary hover:text-primaryHover underline underline-offset-2'>Deploy to Production</a>, see plans on <a href='/pricing' class='text-primary hover:text-primaryHover underline underline-offset-2'>Pricing</a>, read engineering insights on the <a href='/blog' class='text-primary hover:text-primaryHover underline underline-offset-2'>Blog</a>, or <a href='/contact-us' class='text-primary hover:text-primaryHover underline underline-offset-2'>Contact us</a> for collaboration.
    </div>
  </section>
</Layout>
