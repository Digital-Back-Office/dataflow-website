---
import Layout from '../layouts/Layout.astro'
import TopSection from '../components/apps/TopSection.astro'

import { getEntry } from 'astro:content'
import AppSection from '../components/apps/AppSection.astro'

const Data = await getEntry('apps', 'apps')
const data1 = Data.data.section1.title
const data2 = Data.data.section2.title
const data3 = Data.data.section3.title
const data4 = Data.data.section4.title
const data5 = Data.data.section5.title
const data6 = Data.data.section6.title
const data7 = Data.data.section7.title
const data8 = Data.data.section8.title
---

<Layout title='Apps'>
  <TopSection />
  <AppSection
    title={data1}
    image={'/assets/images/apps/apache-airflow-web.webp'}
    logo={'/assets/images/apps/airflow-logo.svg'}
    link={'https://airflow.apache.org/'}
  />
  <AppSection
    title={data2}
    mirror
    image={'/assets/images/apps/jupyterhub-web.webp'}
    logo={'/assets/images/apps/jupyterlogofull.webp'}
    link={'https://jupyter.org/'}
  />
  <AppSection
    title={data3}
    image={'/assets/images/apps/streamlit-web.webp'}
    logo={'/assets/images/apps/streamlit-logo.webp'}
    link={'https://streamlit.io/'}
  />
  <AppSection
    title={data4}
    mirror
    image={'/assets/images/apps/mlflow-web.webp'}
    logo={'/assets/images/apps/mlflowlogofull.webp'}
    link={'https://mlflow.org/'}
  />

  <AppSection
    title={data6}
    image={'/assets/images/apps/vscode-web.webp'}
    logo={'/assets/images/apps/vs-code-logo.webp'}
    link={'https://code.visualstudio.com/'}
  />
  <!-- <AppSection
    title={data5}
    image={'/assets/images/apps/pytorch-web.webp'}
    logo={'/assets/images/apps/pytorchlogofull.webp'}
    link={'https://pytorch.org/'}
  /> -->

