---
import { getCollection } from 'astro:content'
import Layout from '../../layouts/Layout.astro'

export async function getStaticPaths() {
  const blogs = await getCollection('blogs')
  const paths = blogs.map((blog: any) => {
    return {
      params: {
        title: blog.slug
      },
      props: blog
    }
  })
  return paths
}

const { data, body, render } = Astro.props
const { title, date, tags, image } = data
const { Content } = await Astro.props.render()
---

<Layout title=`${title}`>
  <section class='relative overflow-hidden px-[10%] max-sm:px-[20px] pt-[10%] pb-[60px] max-sm:pb-[30px]'>
    <div class='absolute inset-0 -z-10 bg-gradient-to-b from-primary/5 via-white to-white'></div>
    <div class='max-w-full mx-auto'>
      <!-- Breadcrumb -->
      <nav class='mb-6' aria-label='breadcrumb' data-aos='fade-up' data-aos-duration='800'>
        <ol class='flex items-center space-x-2 text-sm text-gray-600'>
          <li>
            <a href='/blog' class='hover:text-primary transition-colors'>Blogs</a>
          </li>
          <li class='text-gray-400'>/</li>
          <li class='text-textblack font-medium line-clamp-1' aria-current='page'>
            {title}
          </li>
        </ol>
      </nav>

      <h1 class='display-4 mb-[16px] text-4xl md:text-5xl font-bold leading-tight' data-aos='fade-up' data-aos-delay='200'>
        {title}
      </h1>
      <div class='flex flex-wrap items-center gap-3 mb-8' data-aos='fade-up' data-aos-delay='250'>
        <time datetime={date} class='text-sm text-gray-600'>{date}</time>
        {tags && tags.length > 0 && (
          <>
            <span class='text-gray-300'>|</span>
            <div class='flex flex-wrap gap-2'>
              {tags.map((tag: string) => (
                <span class='px-2.5 py-1 bg-primary/10 text-primary rounded-full text-xs font-medium'>
                  {tag}
                </span>
              ))}
            </div>
          </>
        )}
      </div>

      {
        image && (
          <figure class='overflow-hidden rounded-2xl shadow-xl border border-gray-100' data-aos='fade-up' data-aos-delay='300'>
            <img
              src={image}
              alt='Blog Image'
              class='w-full h-[420px] object-cover'
            />
          </figure>
        )
      }
    </div>
  </section>

  <section class='px-[10%] max-sm:px-[20px] pt-0 pb-[140px] max-sm:pb-[80px]'>
    <div class='max-w-full mx-auto'>
      <!-- Blog Content -->
      <div class='bg-white/90 backdrop-blur rounded-2xl shadow-sm border border-gray-100 p-8 md:p-12' data-aos='fade-up' data-aos-delay='150'>
        <div class='prose w-full max-w-none md:prose-img:max-w-[70%] prose-img:mx-auto prose-img:rounded-xl prose-headings:scroll-mt-24 prose-h2:mt-10 prose-h3:mt-8 prose-p:leading-relaxed'>
          <Content />
        </div>
      </div>
    </div>
  </section>
</Layout>
