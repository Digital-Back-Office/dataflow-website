---
import { getCollection } from 'astro:content'
import Layout from '../../layouts/Layout.astro'
import EmailCTA from '../../components/common/EmailCTA.astro'
import SocialIcon, { type Platform } from '../../components/common/SocialIcon.astro'
import { resolveBlogAuthor } from '../../utils/blogAuthors'

export async function getStaticPaths() {
  const blogs = await getCollection('blogs')
  const paths = blogs.map((blog: any) => {
    return {
      params: {
        title: blog.slug
      },
      props: blog
    }
  })
  return paths
}

const { data, body, render } = Astro.props
const { title, date, tags, image, description } = data
const author = resolveBlogAuthor(data)
const authorInitials = author.name
  .split(' ')
  .filter(Boolean)
  .slice(0, 2)
  .map((namePart: string) => namePart.charAt(0).toUpperCase())
  .join('')
const meta_description = description ?? `Read ${title} on the Dataflow blog about data science and AI for startups.`
const { Content } = await Astro.props.render()

// Extract headings from markdown body for TOC
const headings: Array<{ depth: number; text: string; slug: string }> = []
// Match lines that start with ## or ### followed by space and text (not followed by more #)
const headingRegex = /^(#{2,3})\s+([^#\n]+)$/gm
let match
while ((match = headingRegex.exec(body)) !== null) {
  const depth = match[1].length
  const text = match[2].trim()
  // Remove markdown formatting like bold, italic, links, etc.
  const cleanText = text
    .replace(/\*\*(.+?)\*\*/g, '$1') // Remove bold
    .replace(/\*(.+?)\*/g, '$1') // Remove italic
    .replace(/\[(.+?)\]\(.+?\)/g, '$1') // Remove links
    .replace(/`(.+?)`/g, '$1') // Remove code
    .trim()
  const slug = cleanText
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/^-+|-+$/g, '')
  headings.push({ depth, text: cleanText, slug }) 
}

// Get all blogs for "Related Posts" section
const allBlogs = await getCollection('blogs')
const relatedBlogs = allBlogs
  .filter((blog) => blog.slug !== Astro.props.slug)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 3)
const siteOrigin = (Astro.site?.toString() ?? "https://dataflow.zone").replace(/\/$/, "");
const ogImage = image ? new URL(image, `${siteOrigin}/`).toString() : undefined;
const normalizedPath = Astro.url.pathname === '/' ? '/' : `${Astro.url.pathname.replace(/\/+$/, '')}/`;
const articleUrl = new URL(normalizedPath, `${siteOrigin}/`).toString();
const blogCollectionId = `${siteOrigin}/blog/#collectionpage`;
const fallbackOgImage = new URL('/og-image.png', `${siteOrigin}/`).toString();
const cleanedBodyText = body
  .replace(/```[\s\S]*?```/g, " ")
  .replace(/`[^`]*`/g, " ")
  .replace(/!\[[^\]]*\]\([^)]*\)/g, " ")
  .replace(/\[([^\]]+)\]\([^)]*\)/g, "$1")
  .replace(/<[^>]*>/g, " ")
  .replace(/[#>*_~\-]/g, " ")
  .replace(/\s+/g, " ")
  .trim();
const wordCount = cleanedBodyText ? cleanedBodyText.split(" ").length : undefined;
const encodedArticleUrl = encodeURIComponent(articleUrl);
const encodedTitle = encodeURIComponent(title);

type ShareLink = {
  icon: Platform;
  label: string;
  href: string;
};

const shareLinks: ShareLink[] = [
  {
    icon: 'x',
    label: 'X',
    href: `https://twitter.com/intent/tweet?url=${encodedArticleUrl}&text=${encodedTitle}`,
  },
  {
    icon: 'linkedin',
    label: 'LinkedIn',
    href: `https://www.linkedin.com/sharing/share-offsite/?url=${encodedArticleUrl}`,
  },
  {
    icon: 'facebook',
    label: 'Facebook',
    href: `https://www.facebook.com/sharer/sharer.php?u=${encodedArticleUrl}`,
  },
  {
    icon: 'email',
    label: 'Email',
    href: `mailto:?subject=${encodedTitle}&body=${encodedArticleUrl}`,
  },
];

const pageSchema = [
  {
    "@type": "WebPage",
    "@id": `${articleUrl}#webpage`,
    url: articleUrl,
    name: `${title} | Dataflow Blog`,
    description: meta_description,
    isPartOf: {
      "@id": `${siteOrigin}#website`,
    },
    about: {
      "@id": `${siteOrigin}#organization`,
    },
    breadcrumb: {
      "@id": `${articleUrl}#breadcrumb`,
    },
  },
  {
    "@type": ["BlogPosting", "Article"],
    "@id": `${articleUrl}#blogposting`,
    mainEntityOfPage: {
      "@id": `${articleUrl}#webpage`,
    },
    headline: title,
    description: meta_description,
    datePublished: new Date(date).toISOString(),
    dateModified: new Date(date).toISOString(),
    image: ogImage ? [ogImage] : [fallbackOgImage],
    author: {
      "@type": "Person",
      name: author.name,
    },
    publisher: {
      "@id": `${siteOrigin}#organization`,
    },
    isPartOf: {
      "@id": blogCollectionId,
    },
    inLanguage: "en",
    articleSection: tags?.length ? tags : ["Data Engineering"],
    keywords: tags?.join(", "),
    wordCount,
    url: articleUrl,
  },
];
---

<Layout
  title={`${title} | Dataflow Blog`}
  meta_description={meta_description}
  ogImage={ogImage}
  pageSchema={pageSchema}
>
  <!-- Hero Section -->
  <section class='relative overflow-hidden px-[10%] max-sm:px-[20px] pt-[10%] pb-[40px] max-sm:pb-[30px]'>
    <div class='absolute inset-0 -z-10 bg-gradient-to-b from-primary/5 via-white to-white'></div>
    <div class='max-w-full mx-auto'>
      <!-- Breadcrumb -->
      <nav class='mb-6' aria-label='breadcrumb' data-aos='fade-up' data-aos-duration='800'>
        <ol class='flex items-center space-x-2 text-sm text-gray-600'>
          <li>
            <a href='/blog' class='hover:text-primary transition-colors' title='Back to Dataflow blog'>Blogs</a>
          </li>
          <li class='text-gray-400'>/</li>
          <li class='text-textblack font-medium line-clamp-1' aria-current='page'>
            {title}
          </li>
        </ol>
      </nav>

      <h1 class='display-4 mb-[16px] text-4xl md:text-5xl font-bold leading-tight max-w-4xl' data-aos='fade-up' data-aos-delay='200'>
        {title}
      </h1>
      <div class='flex flex-wrap items-center gap-3 mb-8' data-aos='fade-up' data-aos-delay='250'>
        <span class='text-sm text-gray-600'>By <a href="#author" class='font-semibold text-textblack underline'>{author.name}</a></span>
        <span class='text-gray-300'>|</span>
        <time datetime={date} class='text-sm text-gray-600'>{date}</time>
        {tags && tags.length > 0 && (
          <>
            <span class='text-gray-300'>|</span>
            <div class='flex flex-wrap gap-2'>
              {tags.map((tag: string) => (
                <span class='px-2.5 py-1 bg-primary/10 text-primary rounded-full text-xs font-medium'>
                  {tag}
                </span>
              ))}
            </div>
          </>
        )}
      </div>
    </div>
  </section>

  <!-- Main Content - Two Column Layout -->
  <section class='px-[10%] max-sm:px-[20px] pb-[140px] max-sm:pb-[80px]'>
    <div class='max-w-[1400px] mx-auto'>
      <div class='flex flex-col lg:flex-row gap-12 items-start'>
        
        <!-- Left Column: Blog Content -->
        <div class='flex-1 w-full lg:max-w-[calc(100%-400px)]'>
          <!-- Featured Image -->
          {
            image && (
              <figure class='overflow-hidden rounded-2xl shadow-sm mb-8' data-aos='fade-up' data-aos-delay='150'>
                <img
                  src={image}
                  alt={`${title} cover image`}
                  loading='eager'
                  fetchpriority='high'
                  class='w-full min-h-[380px] max-h-[500px] object-cover'
                />
              </figure>
            )
          }
          
          <div class='bg-white/90 backdrop-blur rounded-2xl shadow-sm border border-gray-100 p-8 md:p-12' data-aos='fade-up' data-aos-delay='200'>
            <div id='blog-content' class='prose w-full max-w-none md:prose-img:max-w-[70%] prose-img:mx-auto prose-img:rounded-xl prose-headings:scroll-mt-24 prose-h2:mt-10 prose-h3:mt-8 prose-p:leading-relaxed prose-blockquote:border-primary/80 prose-li:marker:text-primary/80 prose-ol:marker:text-primary/80 prose-ul:marker:text-primary/80'>
              <Content />
            </div>
          </div>

          <div id="author" class='mt-8 rounded-2xl border border-gray-100 bg-white p-6 md:p-8 shadow-sm' data-aos='fade-up' data-aos-delay='220'>
            <div class='flex flex-col gap-5 md:flex-row md:items-start md:justify-between'>
              <div class='flex items-start gap-4'>
                {author.headshot ? (
                  <img
                    src={author.headshot}
                    alt={`${author.name} headshot`}
                    loading='lazy'
                    class='h-16 w-16 rounded-full object-cover border border-gray-200'
                  />
                ) : (
                  <div class='h-16 w-16 rounded-full bg-primary/10 border border-primary/20 text-primary font-bold flex items-center justify-center'>
                    {authorInitials}
                  </div>
                )}

                <div>
                  <p class='text-xs uppercase tracking-wide text-gray-500 font-semibold mb-1'>Written by</p>
                  <h3 class='text-xl font-bold text-textblack'>{author.name}</h3>
                  <p class='mt-2 text-sm text-gray-600 max-w-2xl'>{author.bio}</p>
                  {author.socials && author.socials.length > 0 && (
                    <div class='mt-3 flex flex-wrap items-center gap-2'>
                      {author.socials.map((social) => (
                        <a
                          href={social.url}
                          target='_blank'
                          rel='noopener noreferrer'
                          title={social.label || `Follow ${author.name} on ${social.platform}`}
                          class='inline-flex items-center gap-2 rounded-full border border-gray-200 px-3 py-1.5 text-xs font-medium text-gray-700 hover:text-primary hover:border-primary/40 transition-colors'
                        >
                          <SocialIcon platform={social.platform} className='w-3.5 h-3.5' />
                          <span>{social.label || social.platform}</span>
                        </a>
                      ))}
                    </div>
                  )}
                </div>
              </div>

              <div class='md:text-right md:pl-6'>
                <p class='text-sm uppercase tracking-wide text-gray-500 font-semibold mb-2'>Also share to</p>
                <div class='flex flex-wrap gap-2 md:justify-end'>
                  {shareLinks.map((share) => (
                    <a
                      href={share.href}
                      target='_blank'
                      rel='noopener noreferrer'
                      class='inline-flex items-center gap-2 rounded-full border border-gray-200 p-2 text-xs font-semibold text-gray-700 hover:text-primary hover:border-primary/40 transition-colors'
                      title={`Share this article on ${share.label}`}
                      aria-label={`Share this article on ${share.label}`}
                    >
                      <SocialIcon platform={share.icon} className='w-4 h-4' />
                    </a>
                  ))}
                  <button
                    type='button'
                    id='copy-link-btn'
                    class='inline-flex items-center gap-2 rounded-full border border-gray-200 p-2 text-xs font-semibold text-gray-700 hover:text-primary hover:border-primary/40 transition-colors'
                    data-copy-url={articleUrl}
                    aria-label='Copy article link'
                  >
                    <SocialIcon platform='copy' className='w-4 h-4' />
                  </button>
                </div>
              </div>
            </div>
          </div>

          <!-- CTA Section at Bottom of Content -->
          <div class='mt-12 relative overflow-hidden rounded-3xl p-10 border-2 border-primary/20 shadow-xl' data-aos='fade-up'>
            <!-- Gradient Background -->
            <div class='absolute inset-0 bg-gradient-to-br from-primary/10 via-primary/5 to-primary/10'></div>
            <!-- Decorative Elements -->
            <div class='absolute top-0 right-0 w-64 h-64 bg-primary/10 rounded-full blur-3xl'></div>
            <div class='absolute bottom-0 left-0 w-64 h-64 bg-primary/5 rounded-full blur-3xl'></div>
            <!-- Grid Pattern -->
            <div class='absolute inset-0 opacity-5 blog-cta-grid-pattern'></div>
            
            <div class='relative z-10'>
            <div class='max-w-3xl mx-auto text-center mb-8'>
              <h3 class='text-3xl font-bold text-textblack mb-4'>Ready to Transform Your Data Workflow?</h3>
              <p class='text-lg text-gray-600 mb-2'>
                Join thousands of data professionals who trust DataFlow for their data operations.
              </p>
              <p class='text-sm text-gray-500'>
                Start your free trial today and experience the power of seamless data orchestration.
              </p>
            </div>
            
            <EmailCTA 
              formId="blog-post-cta"
              pageSource="blog-post-bottom"
              placeholder="Enter your work email"
              buttonText="Get Started"
              containerClass=""
            />
            
            <div class='mt-6 flex items-center justify-center gap-8 text-sm text-gray-600'>
              <div class='flex items-center gap-2'>
                <svg class='w-5 h-5 text-primary' fill='currentColor' viewBox='0 0 20 20'>
                  <path fill-rule='evenodd' d='M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z' clip-rule='evenodd'></path>
                </svg>
                <span>No credit card required</span>
              </div>
              <div class='flex items-center gap-2'>
                <svg class='w-5 h-5 text-primary' fill='currentColor' viewBox='0 0 20 20'>
                  <path fill-rule='evenodd' d='M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z' clip-rule='evenodd'></path>
                </svg>
                <span>14-day free trial</span>
              </div>
            </div>
            </div>
          </div>
        </div>

        <!-- Right Column: Sticky Sidebar (Non-scrollable) -->
        <aside class='w-full lg:w-[360px] space-y-6 flex-shrink-0' data-aos='fade-up' data-aos-delay='250'>
          
          <!-- Table of Contents -->
          {headings.length > 0 && (
            <div id='toc-container' class='bg-white rounded-xl shadow-sm border border-gray-100 p-6 max-sm:hidden'>
              <h3 class='text-base font-bold text-textblack mb-4'>
                Table of contents
              </h3>
              <nav id='toc-nav' class='space-y-1'>
                {headings.map((heading) => (
                  <a
                    href={`#${heading.slug}`}
                    data-level={heading.depth}
                    title={heading.text}
                    class='toc-link'
                  >
                    {heading.text}
                  </a>
                ))}
              </nav>
            </div>
          )}

          <!-- Newsletter CTA -->
          <div class='bg-gradient-to-br from-primary/10 to-primary/5 rounded-xl p-6 border border-primary/20'>
            <h3 class='text-lg font-bold text-textblack mb-2'>Stay Updated</h3>
            <p class='text-sm text-gray-600 mb-4'>Get the latest articles delivered to your inbox</p>
            
            <form class='space-y-3' name='newsletter' method='POST'>
              <div class='relative'>
                <svg class='absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400' fill='none' stroke='currentColor' viewBox='0 0 24 24'>
                  <path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z'></path>
                </svg>
                <input 
                  type='email' 
                  name='email' 
                  required 
                  placeholder='Your email'
                  class='w-full pl-10 pr-4 py-2.5 border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary text-sm'
                />
              </div>
              <button 
                type='submit'
                class='w-full bg-primary hover:bg-primary/90 text-white py-2.5 rounded-lg font-semibold text-sm transition-all shadow-md hover:shadow-lg'
              >
                Subscribe
              </button>
            </form>
          </div>

          <!-- Related Blogs -->
          {relatedBlogs.length > 0 && (
            <div class='bg-white rounded-xl shadow-sm border border-gray-100 p-6'>
              <h3 class='text-base font-bold text-textblack mb-4'>
                Related Articles
              </h3>
              <div class='space-y-4'>
                {relatedBlogs.map((blog) => (
                  <a href={`/blog/${blog.slug}`} class='group block' title={blog.data.title}>
                    <div class='flex gap-3'>
                      {blog.data.image && (
                        <img 
                          src={blog.data.image} 
                          alt={blog.data.title}
                          loading='lazy'
                          class='w-20 h-20 object-cover rounded-lg flex-shrink-0'
                        />
                      )}
                      <div class='flex-1 min-w-0'>
                        <h4 class='text-sm font-semibold text-textblack group-hover:text-primary transition-colors line-clamp-2 mb-1'>
                          {blog.data.title}
                        </h4>
                        <time class='text-xs text-gray-500'>{blog.data.date}</time>
                      </div>
                    </div>
                  </a>
                ))}
              </div>
              <a 
                href='/blog' 
                title='View all Dataflow articles'
                class='mt-4 pt-4 border-t border-gray-200 text-sm font-semibold text-primary hover:text-primary/80 transition-colors flex items-center gap-1 group'
              >
                View all articles
                <svg class='w-4 h-4 group-hover:translate-x-1 transition-transform' fill='none' stroke='currentColor' viewBox='0 0 24 24'>
                  <path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M9 5l7 7-7 7'></path>
                </svg>
              </a>
            </div>
          )}

        </aside>

      </div>
    </div>
  </section>
</Layout>

<style>
  /* Make iframes (embedded videos/iframed content) responsive and full-width */
  :global(#blog-content iframe) {
    width: 100% !important;
    max-width: 100% !important;
    height: auto !important;
    aspect-ratio: 16/9;
    display: block;
    border: 0;
    border-radius: 0.5rem;
  }

  /* Ensure figure wrappers don't constrain iframe width */
  :global(#blog-content figure) {
    width: 100%;
    max-width: 100%;
  }

  /* Support common embed wrappers (if used by markdown plugins) */
  :global(#blog-content .embed, #blog-content .video-wrapper) {
    width: 100% !important;
    max-width: 100% !important;
  }

  /* Smooth scroll behavior for TOC links */
  html {
    scroll-behavior: smooth;
  }

  /* Sticky sidebar positioning - NO scrolling */
  @media (min-width: 1024px) {
    aside {
      position: sticky;
      top: 7rem;
      align-self: flex-start;
    }
  }

  /* TOC link styling - text link style */
  #toc-nav a {
    display: block;
    padding: 0.375rem 0;
    color: #6b7280;
    text-decoration: none;
    font-size: 0.875rem;
    line-height: 1.5;
    transition: all 0.2s;
    position: relative;
    border-left: 2px solid transparent;
    padding-left: 0.75rem;
  }

  #toc-nav a:hover {
    color: #30BABA;
  }

  /* Active TOC link styling */
  #toc-nav a.active {
    color: #30BABA;
    font-weight: 600;
    border-left-color: #30BABA;
  }

  /* H2 headings - larger and bolder */
  #toc-nav a[data-level="2"] {
    font-size: 0.875rem;
    font-weight: 500;
    color: #374151;
    margin-top: 0.5rem;
  }

  #toc-nav a[data-level="2"]:first-child {
    margin-top: 0;
  }

  #toc-nav a[data-level="2"]:hover {
    color: #30BABA;
  }

  #toc-nav a[data-level="2"].active {
    font-weight: 600;
  }

  /* Nested headings (h3) - indented and smaller */
  #toc-nav a[data-level="3"] {
    padding-left: 1.5rem;
    font-size: 0.8125rem;
    color: #9ca3af;
    font-weight: 400;
    margin-top: 0.125rem;
  }

  #toc-nav a[data-level="3"]:hover,
  #toc-nav a[data-level="3"].active {
    color: #30BABA;
  }

  #toc-nav a[data-level="3"].active {
    font-weight: 500;
  }

  /* On mobile, reset sticky */
  @media (max-width: 1023px) {
    aside {
      position: static;
    }
  }

  /* Prevent markdown tables from overlapping on zoom/smaller viewports */
  :global(#blog-content table) {
    display: block;
    width: 100%;
    min-width: 100%;
    max-width: 100%;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    font-size: 1rem;
  }

  :global(#blog-content th),
  :global(#blog-content td) {
    white-space: nowrap;
  }
</style>

<script is:inline define:vars={{ newsletterFormId: import.meta.env.PUBLIC_NEWSLETTER_GOOGLE_FORM_ID }}>
  // Make newsletter form ID available globally
  window.NEWSLETTER_FORM_ID = newsletterFormId;
</script>
<script is:inline src="/assets/js/newsletter.js"></script>

<script is:inline>
  document.addEventListener('DOMContentLoaded', function() {
    const copyLinkButton = document.getElementById('copy-link-btn');
    if (!copyLinkButton) return;

    const originalText = copyLinkButton.innerHTML;

    copyLinkButton.addEventListener('click', async function() {
      const linkToCopy = copyLinkButton.getAttribute('data-copy-url') || window.location.href;

      try {
        await navigator.clipboard.writeText(linkToCopy);
        copyLinkButton.innerHTML = `
        <svg class='h-4 w-4 text-primary' fill='none' stroke='currentColor' viewBox='0 0 24 24'>
          <path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M5 13l4 4L19 7'></path>
        </svg>
        `;
      } catch (error) {
        const tempInput = document.createElement('input');
        tempInput.value = linkToCopy;
        document.body.appendChild(tempInput);
        tempInput.select();
        document.execCommand('copy');
        document.body.removeChild(tempInput);
        copyLinkButton.textContent = 'Copied';
      }

      window.setTimeout(function() {
        copyLinkButton.innerHTML = originalText;
      }, 3000);
    });
  });
</script>

<script is:inline>
  // Table of Contents - Scroll Highlighting and Smooth Scroll
  document.addEventListener('DOMContentLoaded', function() {
    const content = document.getElementById('blog-content');
    const tocNav = document.getElementById('toc-nav');
    
    if (!content || !tocNav) return;

    // Get all h2 and h3 headings from content
    const headings = content.querySelectorAll('h2, h3');
    
    if (headings.length === 0) return;

    // Function to generate slug from text
    function generateSlug(text) {
      return text
        .toLowerCase()
        .replace(/[^a-z0-9]+/g, '-')
        .replace(/^-+|-+$/g, '');
    }

    // Add IDs to headings if they don't have them
    headings.forEach((heading) => {
      if (!heading.id) {
        heading.id = generateSlug(heading.textContent);
      }
    });

    // Add smooth scroll to TOC links
    const tocLinks = tocNav.querySelectorAll('a');
    tocLinks.forEach((link) => {
      link.classList.add('toc-link');
      
      link.addEventListener('click', function(e) {
        e.preventDefault();
        const targetId = this.getAttribute('href').substring(1);
        const target = document.getElementById(targetId);
        
        if (target) {
          const offset = 100; // Offset for fixed header
          const targetPosition = target.getBoundingClientRect().top + window.pageYOffset - offset;
          window.scrollTo({
            top: targetPosition,
            behavior: 'smooth'
          });
        }
      });
    });

    // Highlight active section on scroll
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          const id = entry.target.id;
          const link = tocNav.querySelector(`a[href="#${id}"]`);
          
          if (entry.isIntersecting && link) {
            // Remove active class from all links
            tocNav.querySelectorAll('a').forEach(a => a.classList.remove('active'));
            // Add active class to current link
            link.classList.add('active');
          }
        });
      },
      {
        rootMargin: '-100px 0px -66%',
        threshold: 0
      }
    );

    // Observe all headings
    headings.forEach((heading) => {
      observer.observe(heading);
    });
  });
</script>
