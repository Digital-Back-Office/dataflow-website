---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";

const blogs = await getCollection("blogs");
const POSTS_PER_PAGE = 6;

// Sort all blogs by date (newest first)
const allBlogs = blogs.sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

// Show initial page
const initialPosts = allBlogs;

// Blog category tabs configuration
const blogTabsConfig = [
  { label: "All", key: "all" },
  { label: "Product", icon: "/assets/icons/icon-news.svg", key: "product" },
  { label: "Data", icon: "/assets/icons/icon-data.svg", key: "data" },
  { label: "AI & ML", icon: "/assets/icons/icon-ai-agent.svg", key: "ai-ml" },
  { label: "Case Studies", icon: "/assets/icons/icon-resources.svg", key: "case-studies" },
];

// Newsletter subscription options
const subscriptionOptions = [
  { id: "advertising-updates", name: "advertising-updates", label: "Product Updates", checked: true },
  { id: "daily-newsletter", name: "daily-newsletter", label: "Weekly Digest", checked: false },
  { id: "week-in-review", name: "week-in-review", label: "Tips & Tutorials", checked: false },
];

// Trust indicators
const trustIndicators = [
  { icon: "M2.166 4.999A11.954 11.954 0 0110 1.944 11.954 11.954 0 0117.834 5c.11.65.166 1.32.166 2.001 0 5.225-3.34 9.67-8 11.317C5.34 16.67 2 12.225 2 7c0-.682.057-1.35.166-2.001zm11.541 3.708a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z", text: "No spam, ever" },
  { icon: "M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0116 4H4a2 2 0 00-1.997 1.884zM18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z", text: "Unsubscribe anytime" },
];

// Serialize all blogs data for JavaScript
const allBlogsJson = JSON.stringify(allBlogs.map(blog => ({
  slug: blog.slug,
  title: blog.data.title,
  description: blog.data.description,
  date: blog.data.date,
  image: blog.data.image,
  tags: blog.data.tags || [],
})));
const siteOrigin = (Astro.site?.toString() ?? "https://dataflow.zone").replace(/\/$/, "");
const normalizedPath = Astro.url.pathname === '/' ? '/' : `${Astro.url.pathname.replace(/\/+$/, '')}/`;
const blogIndexUrl = new URL(normalizedPath, `${siteOrigin}/`).toString();
const blogId = `${blogIndexUrl}#blog`;
const collectionPageId = `${blogIndexUrl}#collectionpage`;
const itemListId = `${blogIndexUrl}#itemlist`;

const pageSchema = [
  {
    "@type": "WebPage",
    "@id": `${blogIndexUrl}#webpage`,
    url: blogIndexUrl,
    name: "Dataflow Blog",
    description: "Insights on data science, AI and ML in data, and startup growth.",
    isPartOf: {
      "@id": `${siteOrigin}#website`,
    },
    about: {
      "@id": `${siteOrigin}#organization`,
    },
    mainEntity: {
      "@id": collectionPageId,
    },
    breadcrumb: {
      "@id": `${blogIndexUrl}#breadcrumb`,
    },
  },
  {
    "@type": "Blog",
    "@id": blogId,
    url: blogIndexUrl,
    name: "Dataflow Blog",
    description: "Insights on data science, AI and ML in data, and startup growth.",
    publisher: {
      "@id": `${siteOrigin}#organization`,
    },
    blogPost: allBlogs.map((post) => ({
      "@id": `${siteOrigin}/blog/${post.slug}#blogposting`,
    })),
  },
  {
    "@type": "CollectionPage",
    "@id": collectionPageId,
    url: blogIndexUrl,
    name: "Dataflow Blog",
    description: "Insights on data science, AI and ML in data, and startup growth.",
    isPartOf: {
      "@id": blogId,
    },
    mainEntity: {
      "@id": itemListId,
    },
  },
  {
    "@type": "ItemList",
    "@id": itemListId,
    itemListOrder: "https://schema.org/ItemListOrderDescending",
    numberOfItems: allBlogs.length,
    itemListElement: allBlogs.map((post, index) => ({
      "@type": "ListItem",
      position: index + 1,
      url: `${siteOrigin}/blog/${post.slug}/`,
      name: post.data.title,
    })),
  },
];
---

<Layout
  title="Dataflow Blog | Data Engineering Tutorials & Insights"
  meta_description="Practical tutorials on Python environments, Apache Airflow, Streamlit deployment, ETL pipelines and GenAI engineering. Written for data engineers and ML teams."
  pageSchema={pageSchema}
>
  <!-- Main Content -->
  <div class="px-[10%] mt-20 max-sm:px-[20px] pt-16 pb-24 max-sm:pt-12 max-sm:pb-16">
    <!-- Page Header -->
    <div
      class="flex justify-between items-center mb-12 max-sm:mb-8 max-sm:flex-col max-sm:gap-4"
      data-aos="fade-up" data-aos-duration="100"
    >
      <!-- Tabs -->
      <div class="flex-1 max-sm:w-full" data-aos="fade-up" data-aos-delay="50">
        <nav
          id="category-tabs"
          class="flex items-center gap-6 overflow-x-auto max-w-full scrollbar-hide max-sm:gap-4 scrolling-touch"
          aria-label="Blog categories"
        >
          {
            blogTabsConfig.map((t) => (
              <button
                class="blog-tab text-nowrap text-gray-400 flex items-center gap-3 py-3 px-2 text-sm transition-colors no-underline border-b-2 border-transparent hover:text-textblack"
                data-category={t.key}
                aria-pressed="false"
              >
                {t.icon && <img src={t.icon} alt={t.label} class="w-5 h-5" />}
                <span>{t.label}</span>
              </button>
            ))
          }
        </nav>
      </div>

      <!-- Search Bar -->
      <div class="w-[360px] max-sm:w-full mt-4 max-sm:mt-0" data-aos="fade-up" data-aos-delay="150">
        <div class="relative">
          <svg
            class="absolute text-gray-400 left-4 top-1/2 -translate-y-1/2 w-5 h-5"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
          </svg>
          <input
            id="search-input"
            type="text"
            placeholder="Enter keyword"
            class="w-full pl-12 pr-4 py-3 border border-gray-200 rounded-full focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all"
          />
        </div>
      </div>
    </div>

    <!-- Blog Grid -->
    <div
      id="blog-container"
      class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-16"
      data-total-posts={allBlogs.length}
      data-posts-per-page="6" 
    >
      {
        initialPosts.map((post, index) => (
          <article
            class="group bg-white rounded-2xl overflow-hidden border border-gray-100 hover:border-primary/30 hover:shadow-xl transition-all duration-300 blog-card-transition"
            data-slug={post.slug}
            data-categories={
              post.data.category
                ? post.data.category.map((tg) => tg.toLowerCase()).join(",")
                : ""
            }
            data-aos="fade-up"
            data-aos-delay={index * 50}
          >
            {post.data.image && (
              <a
                href={`/blog/${post.slug}`}
                title={post.data.title}
                class="block overflow-hidden"
              >
                <img
                  src={post.data.image}
                  alt={post.data.title}
                  loading="lazy"
                  class="w-full h-56 object-cover group-hover:scale-[1.015] transition-transform duration-300"
                />
              </a>
            )}

            <div class="p-6">
              {/* Date and Tags */}
              <div class="flex items-center gap-3 mb-4 text-sm text-gray-500">
                <time datetime={post.data.date}>{post.data.date}</time>
                {post.data.tags && post.data.tags.length > 0 && (
                  <>
                    <span class="text-gray-300">|</span>
                    <span class="px-2 py-1 bg-primary/10 text-primary rounded-md text-xs font-medium">
                      {post.data.tags[0]}
                    </span>
                  </>
                )}
              </div>

              {/* Title */}
              <h3 class="text-xl font-bold text-textblack mb-3 line-clamp-2 group-hover:text-primary transition-colors">
                <a href={`/blog/${post.slug}`} title={post.data.title}>{post.data.title}</a>
              </h3>

              {/* Description */}
              <p class="text-gray-600 text-sm line-clamp-3 mb-4">
                {post.data.description}
              </p>

              {/* Read More Link */}
              <a
                href={`/blog/${post.slug}`}
                title={`Read ${post.data.title}`}
                class="inline-flex items-center text-primary font-semibold text-sm hover:gap-2 transition-all group/link"
              >
                Read More
                <span class='sr-only'>about {post.data.title}</span>
                <svg
                  class="w-4 h-4 ml-1 group-hover/link:translate-x-1 transition-transform"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M9 5l7 7-7 7"
                  />
                </svg>
              </a>
            </div>
          </article>
        ))
      }
    </div>

    <!-- No Results Message -->
    <div id="no-results" class="hidden text-center py-20">
      <svg
        class="w-16 h-16 mx-auto mb-4 text-gray-300"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
        ></path>
      </svg>
      <h3 class="text-xl font-semibold text-gray-700 mb-2">No blogs found</h3>
      <p class="text-gray-500">Try adjusting your search or category</p>
    </div>

    <!-- Pagination -->
    <nav
      id="pagination-nav"
      class="flex justify-center items-center gap-2"
      aria-label="Blog pagination"
      data-aos="fade-up" data-aos-delay="150"
    >
      {/* Previous Button */}
      <button
        id="prev-btn"
        class="px-4 py-2 rounded-lg border border-gray-200 text-gray-700 hover:border-primary hover:text-primary transition-all disabled:opacity-50 disabled:cursor-not-allowed"
        aria-label="Previous page"
        disabled
      >
        <svg
          class="w-5 h-5"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M15 19l-7-7 7-7"
          />
        </svg>
      </button>

      {/* Page Numbers Container */}
      <div id="page-numbers" class="flex items-center gap-2">
        {/* Generated by JavaScript */}
      </div>

      {/* Next Button */}
      <button
        id="next-btn"
        class="px-4 py-2 rounded-lg border border-gray-200 text-gray-700 hover:border-primary hover:text-primary transition-all disabled:opacity-50 disabled:cursor-not-allowed"
        aria-label="Next page"
      >
        <svg
          class="w-5 h-5"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M9 5l7 7-7 7"
          />
        </svg>
      </button>
    </nav>
  </div>

  <!-- Newsletter Subscription Section -->
  <section
    class="text-textDarker relative overflow-hidden bg-gradient-to-b from-white from-5% via-primary/75 via-50% to-white to-95% py-24 max-sm:py-12"
    data-aos="fade-up" data-aos-duration="900"
  >
    <div class="relative px-[15%] max-sm:px-[20px]">
      <div class="max-w-4xl mx-auto">
        {/* Header */}
        <div class="text-center mb-10" data-aos="fade-up" data-aos-delay="100">
          <h2 class="text-4xl max-md:text-3xl max-sm:text-2xl font-bold leading-tight mb-4">
            Stay Updated with Latest Insights
          </h2>
          <p class="text-lg max-sm:text-base">
            Get the latest articles, tutorials, and updates delivered to your inbox
          </p>
        </div>

        {/* Form */}
        <form class="space-y-6" name="newsletter" method="POST" action="" data-aos="fade-up" data-aos-delay="200">
          {/* Subscription Options */}
          <div class="flex justify-center flex-wrap gap-6 max-sm:gap-4">
            {
              subscriptionOptions.map((option) => (
                <label class="flex items-center gap-2.5 text-textDarker text-sm cursor-pointer group">
                  <div class="relative">
                    <input
                      type="checkbox"
                      name={option.name}
                      checked={option.checked}
                      class="peer w-5 h-5 rounded border-2 border-gray-400 text-primary focus:ring-2 focus:ring-primary/50 focus:ring-offset-0 bg-white checked:bg-primary checked:border-primary transition-all cursor-pointer appearance-none"
                    />
                    <svg
                      class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 w-3.5 h-3.5 text-white pointer-events-none opacity-0 peer-checked:opacity-100 transition-opacity"
                      fill="currentColor"
                      viewBox="0 0 20 20"
                    >
                      <path
                        fill-rule="evenodd"
                        d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                        clip-rule="evenodd"
                      />
                    </svg>
                  </div>
                  <span class="">{option.label}</span>
                </label>
              ))
            }
          </div>

          {/* Email Input */}
          <div class="max-w-2xl mx-auto">
            <div class="flex items-stretch gap-3 p-2 bg-white backdrop-blur-sm rounded-2xl border border-white/20 shadow-xl">
              <div class="flex-1 text-gray-400 flex items-center gap-3 px-4">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                  ></path>
                </svg>
                <input
                  type="email"
                  name="email"
                  required
                  placeholder="Enter your email address"
                  class="flex-1 bg-transparent py-3 outline-none max-sm:w-full"
                />
              </div>
              <button
                type="submit"
                class="group  px-8 max-sm:px-2 py-3.5 text-white bg-primary hover:bg-primary/90 rounded-xl font-semibold transition-all whitespace-nowrap max-sm:w-max flex items-center justify-center gap-2 shadow-lg hover:shadow-primary/25"
              >
                Subscribe
                <svg
                  class="w-4 h-4 group-hover:translate-x-1 transition-transform"
                  fill="none"
                  stroke="white"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
                </svg>
              </button>
            </div>
          </div>

          {/* Terms */}
          <p class="text-center text-sm">
            By subscribing, you agree to our{" "}
            <a href="/legal/terms-and-conditions" title="Terms and Conditions" class="text-primary hover:text-primary/80 underline transition-colors">
              Terms
            </a>{" "}
            and{" "}
            <a href="/legal/privacy-policy" title="Privacy Policy" class="text-primary hover:text-primary/80 underline transition-colors">
              Privacy Policy
            </a>
          </p>
        </form>

        {/* Trust Indicators */}
        <div class="mt-10 flex items-center justify-center gap-8 text-textDarker text-sm max-sm:flex-col max-sm:gap-4" data-aos="fade-up" data-aos-delay="250">
          {
            trustIndicators.map((indicator) => (
              <div class="flex items-center gap-2">
                <svg class="w-5 h-5 text-primary" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d={indicator.icon} clip-rule="evenodd"></path>
                </svg>
                <span>{indicator.text}</span>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  article.hidden,
  article.search-hidden {
    display: none !important;
  }

  /* Hide scrollbar for category tabs */
  .scrollbar-hide {
    -ms-overflow-style: none;  /* IE and Edge */
    scrollbar-width: none;  /* Firefox */
  }
  
  .scrollbar-hide::-webkit-scrollbar {
    display: none;  /* Chrome, Safari and Opera */
  }
</style>

<script is:inline src="/assets/js/blog-manager.js"></script>

<script is:inline define:vars={{ newsletterFormId: import.meta.env.PUBLIC_NEWSLETTER_GOOGLE_FORM_ID }}>
  // Make newsletter form ID available globally
  window.NEWSLETTER_FORM_ID = newsletterFormId;
</script>
<script is:inline src="/assets/js/newsletter.js"></script>

<script is:inline define:vars={{ allBlogsJson }}>
  // Make blogs data available globally for JavaScript
  window.ALL_BLOGS = JSON.parse(allBlogsJson);
</script>
