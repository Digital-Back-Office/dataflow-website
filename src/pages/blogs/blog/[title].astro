---
import BlogLayout from '../../../layouts/BlogLayout.astro'
import { getCollection } from 'astro:content'
import Layout from '../../../layouts/Layout.astro'

export async function getStaticPaths() {
  const blogs = await getCollection('blogs')
  const paths = blogs.map((blog: any) => {
    return {
      params: {
        title: blog.slug
      },
      props: blog
    }
  })
  return paths
}

const { data, body, render } = Astro.props
const { title, date, tags, image } = data
const { Content } = await render()
---

<Layout title=`Dataflow | ${title}`>
  <section class='px-[15%] max-sm:px-[20px] py-[80px] max-sm:py-[40px] pb-[140px]'>
    <!-- Breadcrumb -->
    <nav class='mb-6' aria-label='breadcrumb'>
      <ol class='flex items-center space-x-2 text-sm text-gray-600'>
        <li>
          <a href='/' class='hover:text-primary transition-colors'>Home</a>
        </li>
        <li class='text-gray-400'>/</li>
        <li>
          <a href='/blogs' class='hover:text-primary transition-colors'>Blogs</a>
        </li>
        <li class='text-gray-400'>/</li>
        <li class='text-textblack font-medium line-clamp-1' aria-current='page'>
          {title}
        </li>
      </ol>
    </nav>

    <h1 class='display-4 mb-[20px] text-4xl font-bold'>
      {title}
    </h1>
    <div class='flex flex-wrap items-center gap-3 mb-6'>
      <time datetime={date} class='text-sm text-gray-600'>{date}</time>
      {tags && tags.length > 0 && (
        <>
          <span class='text-gray-300'>|</span>
          <div class='flex flex-wrap gap-2'>
            {tags.map((tag: string) => (
              <span class='px-2 py-1 bg-primary/10 text-primary rounded-md text-xs font-medium'>
                {tag}
              </span>
            ))}
          </div>
        </>
      )}
    </div>

    {
      image && (
        <img
          src={image}
          alt='Blog Image'
          class='w-full h-[400px]  my-[40px] mb-[50px] object-cover rounded-lg'
        />
      )
    }
    <!-- Blog Content -->
    <div class='mt-4 prose w-full max-w-none md:prose-img:max-w-[60%] prose-img:mx-auto prose-img:rounded-lg'>
      <Content />
    </div>
  </section>
</Layout>
