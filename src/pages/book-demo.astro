---
import Layout from '../layouts/Layout.astro'
import { getEntry } from 'astro:content'
const Data = await getEntry('common', 'book-demo')
const data = Data.data
const { hero, highlights, form } = data
const formFields = form?.fields || []
const termsText = form?.terms_text || ''
const termsLinkText = form?.terms_link_text || ''
const submitLabel = form?.button_text || 'Book Now'
const hiddenActionValue = form?.hidden_action_value || 'Book a demo'

// Get supported by data
const CommonData = await getEntry('common', 'common')
const supportedBy = CommonData.data.supported_by
---

<Layout title='Book a demo'>
  <!-- Hero Section with Gradient Background -->
  <div class='relative w-full bg-gradient-to-br from-[#F8FAFC] via-white to-[#F0F9FF] py-20 max-sm:py-12'>
    <div class='absolute inset-0 bg-grid-pattern opacity-5'></div>
    
    <div class='relative max-w-7xl mx-auto px-6 max-sm:px-4'>
      <!-- Page Title -->
      <div class='text-center mb-16 max-sm:mb-10' data-aos="fade-up" data-aos-duration="600">
        <h1 class='text-6xl max-lg:text-5xl max-md:text-4xl max-sm:text-3xl font-black text-textblack mb-4'>
          {hero?.title} <span class='text-primary'>{hero?.subtitle}</span>
        </h1>
        <p class='text-xl max-sm:text-lg text-gray-600 max-w-2xl mx-auto mt-4'>
          Experience the power of Dataflow with a personalized demo tailored to your needs
        </p>
      </div>

      <!-- Main Content Grid -->
      <div class='flex flex-col lg:flex-row gap-10 max-lg:gap-8 items-start'>
        
        <!-- Left Column - Benefits -->
        <div class='lg:w-2/5 space-y-6 lg:sticky lg:top-24' data-aos="fade-right" data-aos-duration="800">
          <div class='bg-white rounded-2xl p-8 max-sm:p-6 shadow-md border border-gray-100'>
            <h2 class='text-2xl font-bold text-textblack mb-6 flex items-center gap-3'>
              <span class='w-2 h-8 bg-primary rounded-full'></span>
              What to Expect
            </h2>
            
            <div class='space-y-5'>
              {highlights?.map((item, index) => (
                <div class='flex items-start gap-3 group' data-aos="fade-up" data-aos-delay={index * 100}>
                  <div class='flex-shrink-0 w-12 h-12 rounded-lg bg-gradient-to-br from-primary/10 to-primary/5 flex items-center justify-center group-hover:scale-110 transition-transform duration-300'>
                    <img
                      src={item.image}
                      width='28'
                      height='28'
                      alt={item.title}
                      class='w-7 h-7'
                    />
                  </div>
                  <div class='flex-1'>
                    <h3 class='text-base font-bold text-textblack mb-1 group-hover:text-primary transition-colors'>
                      {item.title}
                    </h3>
                    <p class='text-sm text-gray-600 leading-snug'>{item.description}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>

          <!-- Powered By Section -->
          <div class='bg-white rounded-2xl p-6 border border-gray-100 shadow-sm' data-aos="fade-up" data-aos-delay="400">
            <h2 class='text-2xl font-bold text-textblack mb-6 flex items-center gap-3'>
              <span class='w-2 h-8 bg-primary rounded-full'></span>
              Powered By
            </h2>
            <div class='grid grid-cols-3 gap-4 items-center justify-items-center'>
              {supportedBy?.incubators?.map((company) => (
                <div class='flex items-center justify-center p-2 transition-all duration-300'>
                  <img 
                    src={company.logo} 
                    alt={company.name}
                    class='h-8 max-w-full object-contain'
                    loading='lazy'
                  />
                </div>
              ))}
            </div>
          </div>
        </div>

        <!-- Right Column - Form -->
        <div
          id='formcontainer'
          data-aos="fade-left" data-aos-duration="800"
          class='lg:w-3/5 lg:flex-1 bg-white rounded-2xl shadow-xl border border-gray-100 p-8 max-sm:p-6'
        >
          <div class='mb-6'>
            <h2 class='text-2xl font-bold text-textblack mb-2'>Schedule Your Demo</h2>
            <p class='text-sm text-gray-600'>Fill out the form below and we'll get back to you shortly</p>
          </div>

          <form id='myForm' class='space-y-4'>
            <!-- Personal Information Section -->
            <div class='space-y-3'>
              <div class='flex items-center gap-2 pb-2 border-b border-gray-200'>
                <svg class='w-5 h-5 text-primary' fill='currentColor' viewBox='0 0 20 20'>
                  <path fill-rule='evenodd' d='M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z' clip-rule='evenodd'></path>
                </svg>
                <h3 class='text-sm font-semibold text-gray-700 uppercase tracking-wide'>Personal Information</h3>
              </div>
              
              <div class='grid grid-cols-1 gap-4'>
                <div class='form-group'>
                  <label class='block text-sm font-semibold text-textblack mb-1.5'>
                    Name <span class='text-red-500'>*</span>
                  </label>
                  <input
                    required
                    type='text'
                    placeholder='Your full name'
                    class='custom-input w-full border-2 border-gray-200 rounded-xl h-12 px-4 text-sm focus:border-primary focus:ring-4 focus:ring-primary/10 transition-all duration-200'
                    name='entry.1291198894'
                  />
                </div>
                
                <div class='grid sm:grid-cols-2 gap-4'>
                  <div class='form-group'>
                    <label class='block text-sm font-semibold text-textblack mb-1.5'>
                      Email <span class='text-red-500'>*</span>
                    </label>
                    <input
                      required
                      type='email'
                      placeholder='your.email@company.com'
                      class='custom-input w-full border-2 border-gray-200 rounded-xl h-12 px-4 text-sm focus:border-primary focus:ring-4 focus:ring-primary/10 transition-all duration-200'
                      name='entry.59580764'
                    />
                  </div>
                  
                  <div class='form-group'>
                    <label class='block text-sm font-semibold text-textblack mb-1.5'>
                      Phone Number <span class='text-red-500'>*</span>
                    </label>
                    <input
                      required
                      type='tel'
                      placeholder='+1 (555) 000-0000'
                      class='custom-input w-full border-2 border-gray-200 rounded-xl h-12 px-4 text-sm focus:border-primary focus:ring-4 focus:ring-primary/10 transition-all duration-200'
                      name='entry.1798038289'
                    />
                  </div>
                </div>
              </div>
            </div>

            <!-- Company Information Section -->
            <div class='space-y-3 pt-1'>
              <div class='flex items-center gap-2 pb-2 border-b border-gray-200'>
                <svg class='w-5 h-5 text-primary' fill='currentColor' viewBox='0 0 20 20'>
                  <path fill-rule='evenodd' d='M4 4a2 2 0 012-2h8a2 2 0 012 2v12a1 1 0 110 2h-3a1 1 0 01-1-1v-2a1 1 0 00-1-1H9a1 1 0 00-1 1v2a1 1 0 01-1 1H4a1 1 0 110-2V4zm3 1h2v2H7V5zm2 4H7v2h2V9zm2-4h2v2h-2V5zm2 4h-2v2h2V9z' clip-rule='evenodd'></path>
                </svg>
                <h3 class='text-sm font-semibold text-gray-700 uppercase tracking-wide'>Company Information</h3>
              </div>
              
              <div class='grid grid-cols-1 gap-3'>
                <div class='form-group'>
                  <label class='block text-sm font-semibold text-textblack mb-1.5'>
                    Company Name <span class='text-red-500'>*</span>
                  </label>
                  <input
                    required
                    type='text'
                    placeholder='Your company name'
                    class='custom-input w-full border-2 border-gray-200 rounded-xl h-12 px-4 text-sm focus:border-primary focus:ring-4 focus:ring-primary/10 transition-all duration-200'
                    name='entry.1637227755'
                  />
                </div>
                
                <div class='form-group'>
                  <label class='block text-sm font-semibold text-textblack mb-1.5'>
                    Company Size <span class='text-red-500'>*</span>
                  </label>
                  <select
                    required
                    id='options'
                    class='custom-input w-full border-2 border-gray-200 rounded-xl h-12 px-4 text-sm text-gray-500 bg-white focus:border-primary focus:ring-4 focus:ring-primary/10 transition-all duration-200 appearance-none bg-select-icon'
                    name='entry.1061557718'
                  >
                    <option value='' disabled selected>Select company size</option>
                    {formFields.find(f => f.type === 'select')?.options?.map((option) => (
                      <option value={option.value} class='text-textblack'>{option.label}</option>
                    ))}
                  </select>
                </div>
              </div>
            </div>

            <!-- Scheduling Section -->
            <div class='space-y-3 pt-1'>
              <div class='flex items-center gap-2 pb-2 border-b border-gray-200'>
                <svg class='w-5 h-5 text-primary' fill='currentColor' viewBox='0 0 20 20'>
                  <path fill-rule='evenodd' d='M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z' clip-rule='evenodd'></path>
                </svg>
                <h3 class='text-sm font-semibold text-gray-700 uppercase tracking-wide'>Schedule Your Demo</h3>
              </div>
              
              <div class='grid grid-cols-1 gap-3'>
                <div class='form-group'>
                  <label class='block text-sm font-semibold text-textblack mb-1.5'>
                    Preferred Date <span class='text-red-500'>*</span>
                  </label>
                  <input
                    type='text'
                    id='date'
                    required
                    placeholder='Select a date'
                    class='date-picker custom-input w-full border-2 border-gray-200 rounded-xl h-12 px-4 text-sm focus:border-primary focus:ring-4 focus:ring-primary/10 transition-all duration-200'
                    name='entry.800910305'
                  />
                </div>
                
                <div class='form-group'>
                  <label class='block text-sm font-semibold text-textblack mb-1.5'>
                    Available Time Slots <span class='text-red-500'>*</span>
                  </label>
                  <select
                    required
                    id='available-slots'
                    name='entry.1284317816'
                    disabled
                    class='custom-input w-full border-2 border-gray-200 rounded-xl h-12 px-4 text-sm text-gray-500 bg-white focus:border-primary focus:ring-4 focus:ring-primary/10 transition-all duration-200 disabled:bg-gray-50 disabled:cursor-not-allowed appearance-none bg-select-icon'
                  >
                    <option value='' selected disabled>
                      Select date to get available slots
                    </option>
                  </select>
                  <p class='text-xs text-gray-500 mt-1.5 flex items-center gap-1'>
                    <svg class='w-3.5 h-3.5' fill='currentColor' viewBox='0 0 20 20'>
                      <path fill-rule='evenodd' d='M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z' clip-rule='evenodd'></path>
                    </svg>
                    Select a date first to see available time slots
                  </p>
                </div>
              </div>
            </div>

            <!-- Additional Information -->
            <div class='space-y-3 pt-1'>
              <div class='flex items-center gap-2 pb-2 border-b border-gray-200'>
                <svg class='w-5 h-5 text-primary' fill='currentColor' viewBox='0 0 20 20'>
                  <path fill-rule='evenodd' d='M18 13V5a2 2 0 00-2-2H4a2 2 0 00-2 2v8a2 2 0 002 2h3l3 3 3-3h3a2 2 0 002-2zM5 7a1 1 0 011-1h8a1 1 0 110 2H6a1 1 0 01-1-1zm1 3a1 1 0 100 2h3a1 1 0 100-2H6z' clip-rule='evenodd'></path>
                </svg>
                <h3 class='text-sm font-semibold text-gray-700 uppercase tracking-wide'>Tell Us More</h3>
              </div>
              
              <div class='form-group'>
                <label class='block text-sm font-semibold text-textblack mb-1.5'>
                  How do you intend to use Dataflow? <span class='text-red-500'>*</span>
                </label>
                <textarea
                  required
                  name='entry.1056515558'
                  placeholder='Tell us about your data processing needs and what you hope to achieve with Dataflow...'
                  class='custom-input w-full border-2 border-gray-200 rounded-xl p-4 text-sm focus:border-primary focus:ring-4 focus:ring-primary/10 transition-all duration-200 resize-none'
                  rows='3'
                ></textarea>
              </div>
            </div>

            <input type='hidden' name='entry.664159867' value={hiddenActionValue} />
            
            <!-- Terms and Submit -->
            <div class='space-y-3 pt-1'>
              <div class='flex items-start gap-3 p-4 bg-gray-50 rounded-xl'>
                <input
                  type='checkbox'
                  required
                  id='terms-checkbox'
                  class='mt-1 w-4 h-4 rounded border-gray-300 text-primary focus:ring-primary focus:ring-2'
                />
                <label for='terms-checkbox' class='text-sm text-gray-600 leading-relaxed'>
                  {termsText} <a
                    href='/legal/terms-and-conditions'
                    class='text-primary hover:text-primary/80 underline underline-offset-2 font-medium'
                    >{termsLinkText}</a>
                </label>
              </div>

              <button
                type='submit'
                id='book-demo-btn'
                disabled
                class='w-full bg-gradient-to-r from-primary to-primary/90 hover:from-primary/90 hover:to-primary disabled:from-gray-300 disabled:to-gray-300 disabled:cursor-not-allowed text-white font-bold rounded-xl h-14 flex items-center justify-center gap-3 transition-all duration-300 shadow-lg hover:shadow-xl disabled:shadow-none transform hover:scale-[1.02] disabled:scale-100'
              >
                <svg class='w-5 h-5' fill='none' stroke='currentColor' viewBox='0 0 24 24'>
                  <path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z'></path>
                </svg>
                <span>{submitLabel}</span>
              </button>
            </div>
          </form>

          <!-- Success Message (Hidden by Default) -->
          <div id='thank-you-message' class='hidden text-center'>
            <div class='py-12'>
              <div class='w-20 h-20 bg-gradient-to-br from-green-400 to-green-500 rounded-full flex items-center justify-center mx-auto mb-6 animate-bounce-slow'>
                <svg class='w-10 h-10 text-white' fill='none' stroke='currentColor' viewBox='0 0 24 24'>
                  <path stroke-linecap='round' stroke-linejoin='round' stroke-width='3' d='M5 13l4 4L19 7'></path>
                </svg>
              </div>
              <h3 class='text-3xl font-bold text-textblack mb-3'>Thank You!</h3>
              <p class='text-gray-600 mb-8 max-w-sm mx-auto'>
                Your demo request has been submitted successfully. Our team will reach out to you shortly.
              </p>
              <button
                id='submit-another-form'
                class='text-primary hover:text-primary/80 font-semibold underline underline-offset-4 transition-colors'
              >
                Submit another request
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>

<link
  rel='stylesheet'
  href='https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css'
  crossorigin='anonymous'
/>
<script src='https://cdn.jsdelivr.net/npm/flatpickr'></script>

<script>
  import flatpickr from 'flatpickr'
  try {
    flatpickr('.date-picker', {
      enableTime: false,
      dateFormat: 'Y-m-d',
      minDate: 'today',
      onOpen: function (selectedDates, dateStr, instance) {
        const calendarContainer = instance.calendarContainer
        const monthElement = calendarContainer.querySelector(
          '.flatpickr-month'
        ) as HTMLElement
        const monthDropDown = calendarContainer.querySelector(
          '.flatpickr-monthDropdown-months'
        ) as HTMLElement
        const DropDownMonth = calendarContainer.querySelectorAll(
          '.flatpickr-monthDropdown-month'
        ) as NodeListOf<HTMLElement>
        const weekdays = calendarContainer.querySelectorAll(
          '.flatpickr-weekday'
        ) as NodeListOf<HTMLElement>
        const currMonth = calendarContainer.querySelector(
          '.flatpickr-current-month'
        ) as HTMLElement

        const dayContainer = calendarContainer.querySelectorAll(
          '.dayContainer'
        ) as NodeListOf<HTMLElement>

        const disabledDays = calendarContainer.querySelectorAll(
          '.flatpickr-disabled'
        ) as NodeListOf<HTMLElement>
        const selectedDate = calendarContainer.querySelectorAll(
          '.flatpickr-day.selected'
        ) as NodeListOf<HTMLElement>
        const today = calendarContainer.querySelectorAll(
          '.flatpickr-day.today'
        ) as NodeListOf<HTMLElement>

        today[0].style.borderColor = '#1dd0d5'
        today[0].style.color = '#1dd0d5'

        disabledDays.forEach((day) => {
          day.style.color = '#9c9b9a'
        })

        if (selectedDate) {
          selectedDate.forEach((date) => {
            date.style.backgroundColor = '#1dd0d5'
            today[0].style.borderColor = '#1dd0d5'
            date.style.color = '#fff'
          })
        }
        if (
          monthElement &&
          monthDropDown &&
          weekdays &&
          DropDownMonth &&
          dayContainer
        ) {
          monthElement.style.backgroundColor = '#fafafa'
          monthDropDown.style.backgroundColor = '#fafafa'
          currMonth.style.display = 'flex'
          currMonth.style.justifyContent = 'space-between'
          dayContainer[0].style.backgroundColor = '#fafafa'

          weekdays.forEach((weekday) => {
            weekday.style.backgroundColor = '#fafafa'
          })
          DropDownMonth.forEach((month) => {
            month.style.backgroundColor = '#fafafa'
          })
        }
      }
    })
  } catch (error) {
    console.log('error on flatpickr  :>> ', error)
  }
</script>

<script>
  var appScriptID = import.meta.env.PUBLIC_GOOGLE_APP_SCRIPT_ID
  var googleFormId = import.meta.env.PUBLIC_GOOGLE_FORM_ID
  document
    .getElementById('myForm')
    .addEventListener('submit', async function (event) {
      event.preventDefault()

      const name= document.querySelector('input[name="entry.1291198894"]') as HTMLInputElement
      const email = document.querySelector('input[name="entry.59580764"]') as HTMLInputElement
      const phoneNumber = document.querySelector('input[name="entry.1798038289"]') as HTMLInputElement
      const date = document.querySelector('input[name="entry.800910305"]') as HTMLInputElement
      const timeSlot = document.querySelector('select[name="entry.1284317816"]') as HTMLSelectElement
      const companyName = document.querySelector('input[name="entry.1637227755"]') as HTMLInputElement
      const companySize = document.querySelector('select[name="entry.1061557718"]') as HTMLSelectElement
      const message = document.querySelector('textarea[name="entry.1056515558"]') as HTMLInputElement


      function parseTime(timeStr, year, month, day) {
        var timeParts = timeStr.match(/(\d+):(\d+) (\w{2})/)
        var hours = parseInt(timeParts[1], 10)
        var minutes = parseInt(timeParts[2], 10)
        var period = timeParts[3] // AM or PM

        if (period === 'PM' && hours !== 12) {
          hours += 12
        } else if (period === 'AM' && hours === 12) {
          hours = 0
        }
        return new Date(year, month, day, hours, minutes)
      }

      var dateParts = date.value.split('-')
      var year = parseInt(dateParts[0], 10)
      var month = parseInt(dateParts[1], 10) - 1
      var day = parseInt(dateParts[2], 10)

      var time = timeSlot.value.split('-')
      var startTime = parseTime(time[0], year, month, day)
      var endTime = parseTime(time[1], year, month, day)

      const formData = new FormData()
      formData.append('entry.1291198894', name.value)
      formData.append('entry.59580764', email.value)
      formData.append('entry.1798038289', phoneNumber.value)
      formData.append('entry.800910305', date.value)
      formData.append('entry.1284317816', timeSlot.value)
      formData.append('entry.1637227755', companyName.value)
      formData.append('entry.1061557718', companySize.value)
      formData.append('entry.1056515558', message.value)
      formData.append('entry.664159867', 'Book a demo')
      formData.append('ScheduledBy', 'Dataflow team')
      formData.append('StartTime', startTime.toString())
      formData.append('EndTime', endTime.toString())

      const googleFormUrl =
        `https://docs.google.com/forms/u/0/d/e/${googleFormId}/formResponse`

      const googleScriptURL = `https://script.google.com/macros/s/${appScriptID}/exec`

      try {
        // const scriptResponse = await fetch(googleScriptURL, {
        //   method: 'POST',
        //   body: formData
        // })
        //   .catch((error) => {
        //     console.error('calendar error:', error)
        //     throw error
        //   })

        const formResponse = await fetch(googleFormUrl, {
          method: 'POST',
          mode: 'no-cors',
          body: formData
        }).catch((e) => {
          console.error('Error while saving to google form : ', e)
          throw e
        })

        if (formResponse.ok) {
          const form = document.getElementById('myForm') as HTMLFormElement
          const thankYouMessage = document.getElementById('thank-you-message')
          
          // Hide form and show thank you message
          form.classList.add('hidden')
          thankYouMessage.classList.remove('hidden')

          // Reset form in background
          form.reset()
        }
      } catch (error) {
        console.error('Form submission error:', error)
        alert('There was an error submitting your request. Please try again or contact us directly.')
      }
    })
  // Submit another form button handler
  document.addEventListener('click', function(e) {
    if (e.target && (e.target as HTMLElement).id === 'submit-another-form') {
      location.reload()
    }
  })
  
  document.getElementById('options').addEventListener('change', function () {
    this.style.color = '#303030'
  })

  document.getElementById('date').addEventListener('change', async function () {
    this.style.color = '#303030'

    const selectElement = document.getElementById('available-slots') as HTMLSelectElement
    const slotsContainer = document.getElementById('available-slots-container')
    const BookDemoBtn = document.getElementById('book-demo-btn') as HTMLButtonElement

    let date = (document.getElementById('date') as HTMLInputElement).value 

    let timezone = Intl.DateTimeFormat().resolvedOptions().timeZone

    var url = `https://script.google.com/macros/s/${appScriptID}/exec`

    // Show loading state
    selectElement.innerHTML = '<option value="" selected disabled>Loading available slots...</option>'
    selectElement.disabled = false
    selectElement.style.color = '#9ca3b1'

    fetch(`${url}?date=${date}&timezone=${timezone}`)
      .then((res) => res.json())
      .then((data) => {
        const availableSlots = data.availableSlots

        // Clear previous options before adding new ones
        selectElement.innerHTML = ''

        if (availableSlots.length === 0) {
          const option = document.createElement('option')
          option.value = ''
          option.textContent = 'No Available Slots'
          option.selected = true
          option.disabled = true
          option.style.color = '#9ca3b1'
          selectElement.appendChild(option)
          selectElement.disabled = true
          BookDemoBtn.disabled = true
          return
        } else {
          const option = document.createElement('option')
          option.value = ''
          option.textContent = 'Select a slot'
          option.style.color = '#9ca3b1'
          option.selected = true
          option.disabled = true
          selectElement.appendChild(option)
        }

        availableSlots.forEach((slot) => {
          let option = document.createElement('option')
          option.value = slot
          option.textContent = slot
          option.style.color = '#393939'
          selectElement.appendChild(option)
        })
        
        // Enable the dropdown for user selection
        selectElement.disabled = false
      })
      .catch((err) => {
        console.log('err here :>> ', err)
        selectElement.innerHTML = '<option value="" selected disabled>Error loading slots. Please try again.</option>'
        selectElement.disabled = true
        BookDemoBtn.disabled = true
      })
  })

  // Enable submit button when a slot is selected
  document.getElementById('available-slots').addEventListener('change', function () {
    const BookDemoBtn = document.getElementById('book-demo-btn') as HTMLButtonElement
    const selectElement = this as HTMLSelectElement
    
    if (selectElement.value) {
      BookDemoBtn.disabled = false
      selectElement.style.color = '#303030'
    } else {
      BookDemoBtn.disabled = true
    }
  })
</script>

<style>
  /* Background grid pattern */
