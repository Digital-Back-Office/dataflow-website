---
import Layout from '../layouts/Layout.astro'
import { getEntry } from 'astro:content'
const Data = await getEntry('common', 'contact')
const data = Data.data
---

<Layout title='Dataflow | Contact us'>
  <section class='min-h-screen bg-gradient-to-b from-gray-50 to-white px-[5%] py-32 max-sm:py-24' >
    <div class='max-w-7xl mx-auto'>
      <div data-aos="fade-up" data-aos-duration="850" data-aos-offset="200" class='text-center mb-16'>
        <h1 class='text-5xl max-sm:text-4xl font-bold text-gray-900 mb-6'>
          {data.title}
        </h1>
        <p class='text-xl text-gray-600 max-w-2xl mx-auto'>
          {data.description}
        </p>
      </div>

      <div class='grid lg:grid-cols-2 gap-16 items-start'>
        <!-- Left Side - Contact Info -->
        <div data-aos="fade-right" data-aos-duration="850" data-aos-offset="200" class='space-y-8'>
          <div class='bg-white rounded-2xl p-8 shadow-sm border border-gray-100'>
            <h2 class='text-2xl font-bold text-gray-900 mb-6'>Get in Touch</h2>
            <div class='space-y-6'>
              <div class='flex items-start gap-4'>
                <div class='w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center shrink-0'>
                  <svg class='w-6 h-6 text-primary' fill='none' stroke='currentColor' viewBox='0 0 24 24'>
                    <path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z'></path>
                  </svg>
                </div>
                <div>
                  <h3 class='font-semibold text-gray-900 mb-1'>Email Us</h3>
                  <a href='mailto:support@dataflow.zone' class='text-primary hover:text-primaryHover transition-colors'>
                    support@dataflow.zone
                  </a>
                </div>
              </div>

              
              <div class='flex items-start gap-4'>
                <div class='w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center shrink-0'>
                  <svg class='w-6 h-6 text-primary' fill='none' stroke='currentColor' viewBox='0 0 24 24'>
                    <path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z'></path>
                  </svg>
                </div>
                <div>
                  <h3 class='font-semibold text-gray-900 mb-1'>Response Time</h3>
                  <p class='text-gray-600'>We typically respond within 24 hours</p>
                </div>
              </div>
            </div>
          </div>

          <div class='hidden lg:block'>
            <img
              src='/assets/images/contact-us.png'
              alt='Contact Us'
              class='w-full max-w-xl mx-auto'
            />
          </div>
        </div>

        <!-- Right Side - Contact Form -->
        <div data-aos="fade-left" data-aos-duration="850" data-aos-offset="200">
          <div class='formcontainer bg-white rounded-2xl p-8 shadow-sm border border-gray-100'>
            <h3 class='text-2xl font-bold text-gray-900 mb-6'>
              {data.form.title}
            </h3>
            <form id='myForm' class='space-y-6'>
              <div>
                <label class='block text-sm font-semibold text-gray-900 mb-2'>
                  {data.form.label1}
                </label>
                <input
                  required
                  type='text'
                  placeholder={data.form.placeholder1}
                  class='w-full px-4 py-3 border border-gray-200 rounded-lg focus:ring-2 focus:ring-primary/20 focus:border-primary transition-colors'
                  name='entry.1291198894'
                />
              </div>

              <div>
                <label class='block text-sm font-semibold text-gray-900 mb-2'>
                  {data.form.label2}
                </label>
                <input
                  required
                  type='email'
                  placeholder={data.form.placeholder2}
                  class='w-full px-4 py-3 border border-gray-200 rounded-lg focus:ring-2 focus:ring-primary/20 focus:border-primary transition-colors'
                  name='entry.59580764'
                />
              </div>

              <div>
                <label class='block text-sm font-semibold text-gray-900 mb-2'>
                  {data.form.label4}
                </label>
                <input
                  required
                  type='text'
                  placeholder={data.form.placeholder4}
                  class='w-full px-4 py-3 border border-gray-200 rounded-lg focus:ring-2 focus:ring-primary/20 focus:border-primary transition-colors'
                  name='entry.1637227755'
                />
              </div>

              <div>
                <label class='block text-sm font-semibold text-gray-900 mb-2'>
                  {data.form.label5}
                </label>
                <select
                  required
                  id='options'
                  class='w-full px-4 py-3 border border-gray-200 rounded-lg focus:ring-2 focus:ring-primary/20 focus:border-primary transition-colors appearance-none bg-white'
                  name='entry.1061557718'
                  style='color: #64748b;'
                >
                  <option value='' disabled selected>Company Size</option>
                  <option value='1-10'>1-10 employees</option>
                  <option value='11-50'>11-50 employees</option>
                  <option value='51-200'>51-200 employees</option>
                  <option value='201-500'>201-500 employees</option>
                  <option value='501-1000'>501-1000 employees</option>
                  <option value='1001-5000'>1001-5000 employees</option>
                  <option value='5001-10000'>5001-10,000 employees</option>
                  <option value='10001+'>10,001+ employees</option>
                </select>
              </div>

              <input type='hidden' name='entry.664159867' value='Contact-us' />

              <div>
                <label class='block text-sm font-semibold text-gray-900 mb-2'>
                  {data.form.label3}
                </label>
                <textarea
                  required
                  name='entry.1056515558'
                  placeholder={data.form.placeholder3}
                  class='w-full px-4 py-3 border border-gray-200 rounded-lg focus:ring-2 focus:ring-primary/20 focus:border-primary transition-colors resize-none'
                  rows='4'
                ></textarea>
              </div>

              <div class='flex items-start gap-3'>
                <input
                  type='checkbox'
                  required
                  id='terms-checkbox'
                  class='mt-1 w-4 h-4 text-primary border-gray-300 rounded focus:ring-primary'
                />
                <label for='terms-checkbox' class='text-sm text-gray-600'>
                  {data.form.terms}
                  <a
                    href='/terms-and-conditions'
                    class='text-primary hover:text-primaryHover underline underline-offset-2'
                  >
                    {data.form.link}
                  </a>
                </label>
              </div>

              <button
                type='submit'
                class='w-full bg-primary hover:bg-primaryHover text-white font-semibold py-3 px-6 rounded-lg transition-all duration-200 shadow-sm hover:shadow-md'
              >
                {data.form.button}
              </button>
            </form>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
<script type='module'>
  document
    .getElementById('myForm')
    .addEventListener('submit', async function (event) {
      event.preventDefault()

      const formData = new FormData(this)
      const url =
        'https://docs.google.com/forms/u/0/d/e/1FAIpQLSeGjuyA_jjDmmT4jTY96s0CgCL_JKOJlNrTRqJ-9iqRmlEPKw/formResponse'

      try {
        await fetch(url, {
          method: 'POST',
          mode: 'no-cors',
          body: formData
        })

        const formContainer = document.querySelector('.formcontainer')
        formContainer.className = 'bg-white rounded-2xl overflow-hidden shadow-sm border border-gray-100'

        formContainer.innerHTML = `
        <div class="flex flex-col items-center justify-center p-16 text-center bg-gradient-to-br from-primary/5 to-primary/10">
          <div class="w-20 h-20 bg-primary rounded-full flex items-center justify-center mb-6">
            <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
            </svg>
          </div>
          <h3 class="text-2xl font-bold text-gray-900 mb-3">Thank You!</h3>
          <p class="text-gray-600 mb-8 max-w-md">Form submitted successfully. We will reach you shortly.</p>
          <button id="submit-another-form" class="px-6 py-3 bg-primary hover:bg-primaryHover text-white font-semibold rounded-lg transition-all duration-200">
            Submit Another Form
          </button>
        </div>
      `

        document
          .getElementById('submit-another-form')
          .addEventListener('click', function () {
            location.reload()
          })

        this.reset()
      } catch (error) {
        console.error('Form submission error:', error)
      }
    })
  
  document.getElementById('options').addEventListener('change', function () {
    this.style.color = '#1e293b'
  })
</script>

<style>
  select {
    background: url('/assets/icons/Icon-select-down.svg') no-repeat 98% 50%;
    background-size: 16px;
  }
  
  input[type='checkbox']:checked {
    accent-color: #14B8A6;
  }
</style>
