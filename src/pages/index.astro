---
import Layout from '../layouts/Layout.astro'
import Testimonial from '../components/common/Testimonial.astro'
import LandingCTA from '../components/home/LandingCTA.astro'
import SupportedBy from '../components/common/SupportedBy.astro'
import { getEntry } from 'astro:content'

const Data = await getEntry('home', 'home')
const data = Data.data
const { hero, tools, features } = data
---

<Layout title='Dataflow | AI ready data platform'>
  <!-- Hero Section -->
  <section class='relative px-[5%] pt-32 pb-20 max-sm:pt-24 max-sm:pb-16  flex items-center overflow-hidden' style='font-family: Plus Jakarta Sans, sans-serif;'>
    <!-- Background Pattern with Dataflow Animation -->
    <div class='absolute inset-0 -z-10 overflow-hidden'>
      <div class='absolute top-0 left-1/4 w-96 h-96 bg-primary/5 rounded-full blur-3xl'></div>
      <div class='absolute top-20 right-1/4 w-96 h-96 bg-blue-500/5 rounded-full blur-3xl'></div>
      <div class='absolute bottom-0 left-1/2 w-96 h-96 bg-primary/3 rounded-full blur-3xl'></div>
      <!-- Grid Pattern -->
      <div class='absolute inset-0' style='background-image: radial-gradient(circle at 1px 1px, rgb(203 213 225 / 0.15) 1px, transparent 0); background-size: 40px 40px;'></div>
      
      <!-- Animated Data Flow Nodes -->
      <svg id='dataflowSvg' class='absolute inset-0 w-full h-full opacity-40 pointer-events-auto' xmlns='http://www.w3.org/2000/svg' viewBox='0 0 1000 800' preserveAspectRatio='xMidYMid slice'>
        <!-- Connection Lines -->
        <line id='line1' x1='200' y1='250' x2='350' y2='400' stroke='url(#gradient1)' stroke-width='1.5' class='flow-line' opacity='0' />
        <line id='line2' x1='350' y1='400' x2='650' y2='350' stroke='url(#gradient2)' stroke-width='1.5' class='flow-line' opacity='0' />
        <line id='line3' x1='650' y1='350' x2='800' y2='500' stroke='url(#gradient3)' stroke-width='1.5' class='flow-line' opacity='0' />
        <line id='line4' x1='350' y1='400' x2='500' y2='550' stroke='url(#gradient1)' stroke-width='1.5' class='flow-line' opacity='0' />
        <line id='line5' x1='350' y1='400' x2='250' y2='530' stroke='url(#gradient2)' stroke-width='1.5' class='flow-line' opacity='0' />
        <line id='line6' x1='500' y1='550' x2='700' y2='580' stroke='url(#gradient3)' stroke-width='1.5' class='flow-line' opacity='0' />
        <line id='line7' x1='650' y1='350' x2='500' y2='270' stroke='url(#gradient1)' stroke-width='1.5' class='flow-line' opacity='0' />
        
        <!-- Gradient Definitions -->
        <defs>
          <linearGradient id='gradient1' x1='0%' y1='0%' x2='100%' y2='0%'>
            <stop offset='0%' style='stop-color:rgb(48 186 186);stop-opacity:0' />
            <stop offset='50%' style='stop-color:rgb(48 186 186);stop-opacity:0.7' />
            <stop offset='100%' style='stop-color:rgb(48 186 186);stop-opacity:0' />
          </linearGradient>
          <linearGradient id='gradient2' x1='0%' y1='0%' x2='100%' y2='0%'>
            <stop offset='0%' style='stop-color:rgb(48 186 186);stop-opacity:0' />
            <stop offset='50%' style='stop-color:rgb(48 186 186);stop-opacity:0.7' />
            <stop offset='100%' style='stop-color:rgb(48 186 186);stop-opacity:0' />
          </linearGradient>
          <linearGradient id='gradient3' x1='0%' y1='0%' x2='100%' y2='0%'>
            <stop offset='0%' style='stop-color:rgb(48 186 186);stop-opacity:0' />
            <stop offset='50%' style='stop-color:rgb(48 186 186);stop-opacity:0.7' />
            <stop offset='100%' style='stop-color:rgb(48 186 186);stop-opacity:0' />
          </linearGradient>
        </defs>
        
        <!-- Data Nodes with Tool Logos -->
        <!-- Node 1: Airflow -->
        <g class='data-node' data-target-x='200' data-target-y='250' data-speed='1.2'>
          <circle cx='500' cy='400' r='13' fill='white' stroke='#30baba' stroke-width='1.5' fill-opacity='0.95' opacity='0' />
          <image href='/assets/images/apps/airflow-logo.svg' x='491' y='391' width='18' height='18' opacity='0' />
        </g>
        
        <!-- Node 2: Jupyter (Center Hub) -->
        <g class='data-node' data-target-x='350' data-target-y='400' data-speed='0.8'>
          <circle cx='500' cy='400' r='16' fill='white' stroke='#30baba' stroke-width='1.5' fill-opacity='0.95' opacity='0' />
          <image href='/assets/images/apps/jupyter.png' x='490' y='390' width='20' height='20' opacity='0' />
        </g>
        
        <!-- Node 3: VS Code -->
        <g class='data-node' data-target-x='650' data-target-y='350' data-speed='1.0'>
          <circle cx='500' cy='400' r='14' fill='white' stroke='#30baba' stroke-width='1.5' fill-opacity='0.95' opacity='0' />
          <image href='/assets/images/apps/vscode-logo.png' x='491' y='391' width='18' height='18' opacity='0' />
        </g>
        
        <!-- Node 4: Streamlit -->
        <g class='data-node' data-target-x='800' data-target-y='500' data-speed='1.3'>
          <circle cx='500' cy='400' r='13' fill='white' stroke='#30baba' stroke-width='1.5' fill-opacity='0.95' opacity='0' />
          <image href='/assets/images/apps/streamlit-icon.svg' x='491' y='391' width='18' height='18' opacity='0' />
        </g>
        
        <!-- Node 5: Python -->
        <g class='data-node' data-target-x='500' data-target-y='550' data-speed='0.9'>
          <circle cx='500' cy='400' r='12' fill='white' stroke='#30baba' stroke-width='1.5' fill-opacity='0.95' opacity='0' />
          <image href='/assets/images/apps/python-logo.svg' x='492' y='392' width='16' height='16' opacity='0' />
        </g>
        
        <!-- Node 6: DBT -->
        <g class='data-node' data-target-x='250' data-target-y='530' data-speed='1.1'>
          <circle cx='500' cy='400' r='12' fill='white' stroke='#30baba' stroke-width='1.5' fill-opacity='0.95' opacity='0' />
          <image href='/assets/images/apps/dbt.png' x='492' y='392' width='16' height='16' opacity='0' />
        </g>
        
        <!-- Node 7: Dash Apps -->
        <g class='data-node' data-target-x='700' data-target-y='580' data-speed='1.15'>
          <circle cx='500' cy='400' r='12' fill='white' stroke='#30baba' stroke-width='1.5' fill-opacity='0.95' opacity='0' />
          <image href='/assets/images/apps/dashapps.png' x='492' y='392' width='16' height='16' opacity='0' />
        </g>
        
        <!-- Node 8: MLflow -->
        <g class='data-node' data-target-x='500' data-target-y='270' data-speed='0.95'>
          <circle cx='500' cy='400' r='13' fill='white' stroke='#30baba' stroke-width='1.5' fill-opacity='0.95' opacity='0' />
          <image href='/assets/images/apps/mlflow.png' x='491' y='391' width='18' height='18' opacity='0' />
        </g>
      </svg>
    </div>
    
    <div class='max-w-7xl mx-auto relative z-10'>
      <div class='text-center mb-8'>
        <h1 class='text-6xl max-sm:text-4xl font-bold text-gray-900 mb-6 leading-tight' data-aos='fade-up'>
          Focus on Data Logic,<br/>Not Glue Code.
        </h1>
        <p class='text-xl max-sm:text-lg text-gray-600 mb-8 max-w-3xl mx-auto' data-aos='fade-up' data-aos-delay='100'>
          {hero.description}
        </p>
        <div class='flex items-center justify-center gap-4 mb-8 max-sm:flex-col' data-aos='fade-up' data-aos-delay='200'>
          <a
            href='/start-free-trail'
            class='px-8 py-3 bg-primary hover:bg-primaryHover text-white rounded-lg font-semibold transition-all duration-300'
          >
            Try it free
          </a>
          <a
            href='/book-demo'
            class='px-8 py-3 border-2 border-gray-300 hover:border-primary text-gray-900 rounded-lg font-semibold transition-all duration-300'
          >
            Talk to us
          </a>
        </div>
        <div class='flex items-center justify-center gap-8 text-sm text-gray-600 max-sm:flex-col max-sm:gap-4' data-aos='fade-up' data-aos-delay='300'>
          <div class='flex items-center gap-2'>
            <svg class='w-5 h-5 text-primary' fill='currentColor' viewBox='0 0 20 20'>
              <path fill-rule='evenodd' d='M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z' clip-rule='evenodd'></path>
            </svg>
            <span>No card required</span>
          </div>
          <div class='flex items-center gap-2'>
            <svg class='w-5 h-5 text-primary' fill='currentColor' viewBox='0 0 20 20'>
              <path fill-rule='evenodd' d='M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z' clip-rule='evenodd'></path>
            </svg>
            <span>$10 free credit</span>
          </div>
        </div>
      </div>

      <div class='mt-20 w-full flex flex-col items-center justify-center'>
        <p class='text-center text-sm text-gray-500 mb-6'>Powered by</p>
         <div class="flex items-center gap-10">
            <img
              src={'/assets/images/nat-west-logo.png'}
              alt={"Nat West Logo"}
              class="h-[25px] max-sm:h-[30px] grayscale"
            />
            <img
              src={'/assets/images/nvidia-logo.png'}
              alt={"Nvidia"}
              class="h-[25px] max-sm:h-[30px] grayscale"
            />
            <img
              src={'/assets/images/barclays-logo.png'}
              alt={"Barclays Logo"}
              class="h-[25px] max-sm:h-[30px] grayscale"
            />
          </div>
      </div>

    </div>
  </section>

  <!-- Use Cases Tabs Section -->
  <section class='px-[5%] py-20 bg-gray-50 max-sm:py-12' style='font-family: Plus Jakarta Sans, sans-serif;'>
    <div class='max-w-7xl mx-auto'>
      <h2 class='text-4xl max-sm:text-3xl font-bold text-center text-gray-900 mb-12' data-aos='fade-up'>
        Built for All Data Use Cases
      </h2>
      
      <div class='flex justify-center gap-4 mb-12 max-sm:flex-wrap'>
        <button class='px-6 py-3 bg-primary text-white rounded-lg font-medium'>
          Data Integration
        </button>
        <button class='px-6 py-3 bg-white text-gray-700 rounded-lg font-medium hover:bg-gray-100 transition-colors'>
          Data Warehousing
        </button>
        <button class='px-6 py-3 bg-white text-gray-700 rounded-lg font-medium hover:bg-gray-100 transition-colors'>
          Analytics
        </button>
        <button class='px-6 py-3 bg-white text-gray-700 rounded-lg font-medium hover:bg-gray-100 transition-colors'>
          Data Publishing
        </button>
      </div>

      <div class='bg-white rounded-2xl p-12 max-sm:p-6 shadow-sm'>
        <div class='grid md:grid-cols-2 gap-12 items-center'>
          <div>
            <h3 class='text-3xl font-bold text-gray-900 mb-4'>
              Bring Data from various sources
            </h3>
            <p class='text-gray-600 mb-6'>
              Our application lets you connect through various connections sources and bring in your data effortlessly.
            </p>
            <ul class='space-y-3'>
              <li class='flex items-start gap-3'>
                <svg class='w-6 h-6 text-primary mt-0.5 flex-shrink-0' fill='currentColor' viewBox='0 0 20 20'>
                  <path fill-rule='evenodd' d='M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z' clip-rule='evenodd'></path>
                </svg>
                <span class='text-gray-700'>Amazon, Google Cloud, Oracle, and more</span>
              </li>
              <li class='flex items-start gap-3'>
                <svg class='w-6 h-6 text-primary mt-0.5 flex-shrink-0' fill='currentColor' viewBox='0 0 20 20'>
                  <path fill-rule='evenodd' d='M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z' clip-rule='evenodd'></path>
                </svg>
                <span class='text-gray-700'>Automatic and manual</span>
              </li>
            </ul>
          </div>
          <div class='bg-gradient-to-br from-primary/10 to-primary/5 rounded-xl p-8 flex items-center justify-center min-h-[300px]'>
            <img src='/assets/images/ManageAcross.svg' alt='Data Integration' class='max-w-full h-auto' />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Ship Data Apps Section -->
  <section class='px-[5%] py-32 max-sm:py-16' style='font-family: Plus Jakarta Sans, sans-serif;'>
    <div class='max-w-5xl mx-auto'>
      <div class='text-center mb-20'>
        <h2 class='text-4xl max-sm:text-3xl font-bold text-gray-900 mb-4' data-aos='fade-up'>
          Ship data apps in a single flow.
        </h2>
        <p class='text-xl text-gray-600 max-w-3xl mx-auto' data-aos='fade-up' data-aos-delay='100'>
          Dataflow removes environment chaos and glue code across notebooks, pipelines, and apps.
        </p>
      </div>

      <div class='relative'>
        <!-- Timeline line -->
        <div class='absolute left-[23px] top-0 bottom-0 w-0.5 bg-gradient-to-b from-primary via-primary to-primary max-md:hidden'></div>
        
        <div class='space-y-16'>
          <!-- Step 1: Define -->
          <div class='relative' data-aos='fade-up' data-aos-delay='200'>
            <div class='flex gap-8 max-md:flex-col'>
              <div class='flex-shrink-0'>
                <div class='w-12 h-12 bg-primary rounded-full flex items-center justify-center relative z-10'>
                  <svg class='w-6 h-6 text-white' fill='none' stroke='currentColor' viewBox='0 0 24 24'>
                    <path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2'></path>
                  </svg>
                </div>
              </div>
              <div class='flex-1 bg-white rounded-2xl p-8 shadow-sm border border-gray-100'>
                <div class='flex items-center gap-3 mb-3'>
                  <span class='text-sm font-bold text-primary bg-primary/10 px-3 py-1 rounded-full'>STEP 1</span>
                  <h3 class='text-2xl font-bold text-gray-900'>Define</h3>
                </div>
                <p class='text-gray-600 leading-relaxed'>
                  Define environment packages and connections one time. Create your data connections to databases, APIs, and cloud storage. Set up environment variables and secrets. Dataflow syncs them across your whole data stack—no manual configuration needed.
                </p>
              </div>
            </div>
          </div>

          <!-- Step 2: Develop -->
          <div class='relative' data-aos='fade-up' data-aos-delay='300'>
            <div class='flex gap-8 max-md:flex-col'>
              <div class='flex-shrink-0'>
                <div class='w-12 h-12 bg-primary rounded-full flex items-center justify-center relative z-10'>
                  <svg class='w-6 h-6 text-white' fill='none' stroke='currentColor' viewBox='0 0 24 24'>
                    <path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4'></path>
                  </svg>
                </div>
              </div>
              <div class='flex-1 bg-white rounded-2xl p-8 shadow-sm border border-gray-100'>
                <div class='flex items-center gap-3 mb-3'>
                  <span class='text-sm font-bold text-primary bg-primary/10 px-3 py-1 rounded-full'>STEP 2</span>
                  <h3 class='text-2xl font-bold text-gray-900'>Develop</h3>
                </div>
                <p class='text-gray-600 leading-relaxed'>
                  Work in a fully persistent workspace with real IDEs (VS Code, Jupyter). Access your pre-configured connections instantly in your code—no environment variables to manage. Build data pipelines, train ML models, or create analytics dashboards. Schedule jobs with Airflow using the same environment. No config files, just write code.
                </p>
              </div>
            </div>
          </div>

          <!-- Step 3: Deploy -->
          <div class='relative' data-aos='fade-up' data-aos-delay='400'>
            <div class='flex gap-8 max-md:flex-col'>
              <div class='flex-shrink-0'>
                <div class='w-12 h-12 bg-primary rounded-full flex items-center justify-center relative z-10'>
                  <svg class='w-6 h-6 text-white' fill='none' stroke='currentColor' viewBox='0 0 24 24'>
                    <path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12'></path>
                  </svg>
                </div>
              </div>
              <div class='flex-1 bg-white rounded-2xl p-8 shadow-sm border border-gray-100'>
                <div class='flex items-center gap-3 mb-3'>
                  <span class='text-sm font-bold text-primary bg-primary/10 px-3 py-1 rounded-full'>STEP 3</span>
                  <h3 class='text-2xl font-bold text-gray-900'>Deploy</h3>
                </div>
                <p class='text-gray-600 leading-relaxed'>
                  Deploy apps with one click. We use the exact same Python environment from your workspace, ensuring the app works in production exactly as it did in development. Turn notebooks into live APIs, deploy Streamlit dashboards, or publish interactive data apps—all without writing Dockerfiles or managing CI/CD pipelines.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Essential Features Bento Grid -->
  <section class='px-[5%] py-20 bg-gray-50 max-sm:py-12' style='font-family: Plus Jakarta Sans, sans-serif;'>
    <div class='max-w-7xl mx-auto'>
      <h2 class='text-4xl max-sm:text-3xl font-bold text-center text-gray-900 mb-4' data-aos='fade-up'>
        Essential Features
      </h2>
      <p class='text-center text-gray-600 mb-12' data-aos='fade-up' data-aos-delay='100'>
        Unlock the power of streamlined development and seamless collaboration.
      </p>

      <div class='grid md:grid-cols-6 gap-6 max-md:grid-cols-1'>
        {/* Feature 1: Define Once, Use Everywhere - Large Hero Card */}
        {features.filter((_, idx) => idx === 0).map((feature) => (
          <div class='md:col-span-4 bg-gradient-to-br from-primary/5 via-primary/10 to-primary/5 rounded-3xl p-10 max-md:p-8 group hover:shadow-lg transition-all duration-300' data-aos='fade-up' data-aos-delay='200'>
            <div class='flex items-start justify-between max-md:flex-col gap-6'>
              <div class='flex-1'>
                <div class='w-14 h-14 bg-primary rounded-2xl flex items-center justify-center mb-5 transition-transform duration-300'>
                  <img src={feature.icon} alt={feature.title} class='w-7 h-7 brightness-0 invert' />
                </div>
                <h3 class='text-3xl max-md:text-2xl font-bold text-gray-900 mb-4'>{feature.title}</h3>
                <p class='text-gray-700 text-lg mb-6 leading-relaxed'>{feature.description}</p>
                {feature.href && (
                  <a href={feature.href} class='inline-flex items-center gap-2 px-6 py-3 bg-primary hover:bg-primaryHover text-white rounded-lg font-semibold transition-all duration-300 group/btn'>
                    Learn more
                    <svg class='w-5 h-5 transition-transform group-hover/btn:translate-x-1' fill='none' stroke='currentColor' viewBox='0 0 24 24'>
                      <path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M9 5l7 7-7 7'></path>
                    </svg>
                  </a>
                )}
              </div>
              <div class='hidden md:block w-32 h-32 bg-primary/20 rounded-full blur-3xl absolute right-10 top-10 -z-0'></div>
            </div>
          </div>
        ))}

        {/* Feature 2: Goodbye, Dependency Hell - Tall Right Card */}
        {features.filter((_, idx) => idx === 1).map((feature) => (
          <div class='md:col-span-2 md:row-span-2 bg-white rounded-3xl p-8 border-2 border-primary/20 hover:border-primary/30 group hover:shadow-lg transition-all duration-300 flex flex-col' data-aos='fade-up' data-aos-delay='300'>
            <div class='w-12 h-12 bg-primary/10 rounded-xl flex items-center justify-center mb-5 transition-colors duration-300'>
              <img src={feature.icon} alt={feature.title} class='w-6 h-6' />
            </div>
            <h3 class='text-2xl font-bold text-gray-900 mb-4'>{feature.title}</h3>
            <p class='text-gray-600 mb-6 flex-1 leading-relaxed'>{feature.description}</p>
            
            {/* Bottom decorative element */}
            <div class='mt-auto pt-6 border-t border-gray-100'>
              <div class='flex items-center gap-2 text-xs text-gray-500'>
                <svg class='w-4 h-4 text-primary' fill='none' stroke='currentColor' viewBox='0 0 24 24'>
                  <path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z'></path>
                </svg>
                <span>Containerized & Immutable</span>
              </div>
            </div>
            
            {feature.href && (
              <a href={feature.href} class='text-primary hover:text-primaryHover font-semibold inline-flex items-center gap-2 group/link mt-4'>
                Learn more
                <svg class='w-4 h-4 transition-transform group-hover/link:translate-x-1' fill='none' stroke='currentColor' viewBox='0 0 24 24'>
                  <path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M9 5l7 7-7 7'></path>
                </svg>
              </a>
            )}
          </div>
        ))}

        {/* Feature 3: Share Apps Instantly - Bottom Left */}
        {features.filter((_, idx) => idx === 3).map((feature) => (
          <div class='md:col-span-2 bg-white rounded-3xl p-8 border border-gray-200 group hover:shadow-lg hover:border-primary/30 transition-all duration-300' data-aos='fade-up' data-aos-delay='400'>
            <div class='w-12 h-12 bg-gradient-to-br from-primary/10 to-primary/20 rounded-xl flex items-center justify-center mb-5 transition-transform duration-300'>
              <img src={feature.icon} alt={feature.title} class='w-6 h-6' />
            </div>
            <h3 class='text-xl font-bold text-gray-900 mb-3'>{feature.title}</h3>
            <p class='text-gray-600 text-sm mb-4 leading-relaxed'>{feature.description}</p>
            {feature.href && (
              <a href={feature.href} class='text-primary hover:text-primaryHover font-semibold inline-flex items-center gap-2 text-sm group/link'>
                Learn more
                <svg class='w-4 h-4 transition-transform group-hover/link:translate-x-1' fill='none' stroke='currentColor' viewBox='0 0 24 24'>
                  <path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M9 5l7 7-7 7'></path>
                </svg>
              </a>
            )}
          </div>
        ))}

        {/* Feature 4: Bring your team - Bottom Right Wide */}
        {features.filter((_, idx) => idx === 4).map((feature) => (
