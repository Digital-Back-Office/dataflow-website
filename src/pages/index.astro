---
import Layout from '../layouts/Layout.astro'
import HeroSection from '../components/home/HeroSection.astro'
import UseCasesTabs from '../components/home/UseCasesTabs.astro'
import GPUSection from '../components/home/GPUSection.astro'
import ShipDataApps from '../components/home/ShipDataApps.astro'
import EssentialFeatures from '../components/home/EssentialFeatures.astro'
import EnterpriseReady from '../components/home/EnterpriseReady.astro'
import Testimonial from '../components/common/Testimonial.astro'
import SupportSection from '../components/home/SupportSection.astro'
import DevelopersLove from '../components/home/DevelopersLove.astro'
import FinalCTA from '../components/home/FinalCTA.astro'
import SectionCallout from '../components/common/SectionCallout.astro'
import { getEntry } from 'astro:content'

const Data = await getEntry('home', 'home')
const data = Data.data
const { hero, features } = data
const seo = data.seo
const siteOrigin = (Astro.site?.toString() ?? 'https://dataflow.zone').replace(/\/$/, '')
const normalizedPath = Astro.url.pathname === '/' ? '/' : `${Astro.url.pathname.replace(/\/+$/, '')}/`
const homeUrl = new URL(normalizedPath, `${siteOrigin}/`).toString()

const pageSchema = [
  {
    '@type': 'WebPage',
    '@id': `${homeUrl}#webpage`,
    url: homeUrl,
    name: seo?.title ?? 'Dataflow | AI-Ready Data Platform for Startups / Jupyter, Airflow and Streamlit, Managed',
    description:
      seo?.description ??
      'Build, run & deploy data pipelines, ML models and Streamlit apps without DevOps. Jupyter, Airflow & VS Code in one managed Python platform. Free trial.',
    isPartOf: {
      '@id': `${siteOrigin}#website`,
    },
    about: {
      '@id': `${siteOrigin}#organization`,
    },
    mainEntity: {
      '@id': `${homeUrl}#softwareapplication`,
    },
  },
  {
    '@type': 'SoftwareApplication',
    '@id': `${homeUrl}#softwareapplication`,
    name: 'Dataflow',
    applicationCategory: 'BusinessApplication',
    applicationSubCategory: 'Data Platform',
    operatingSystem: 'Web',
    url: homeUrl,
    description:
      'AI-ready data platform to build, orchestrate, and deploy data and ML workloads using tools like Airflow, Jupyter, and VS Code.',
    offers: {
      '@type': 'Offer',
      url: `${siteOrigin}/pricing/`,
      price: '0',
      priceCurrency: 'USD',
      availability: 'https://schema.org/InStock',
    },
    publisher: {
      '@id': `${siteOrigin}#organization`,
    },
  },
]
---

<Layout
  title={seo?.title ?? 'Dataflow | AI-Ready Data Platform for Startups / Jupyter, Airflow and Streamlit, Managed'}
  meta_description={seo?.description ?? 'Build, run & deploy data pipelines, ML models and Streamlit apps without DevOps. Jupyter, Airflow & VS Code in one managed Python platform. Free trial.'}
  pageSchema={pageSchema}
>
  <HeroSection hero={hero} />
  <SectionCallout text="Built for EU compliance. Dataflow deploys on European sovereign cloud providers, making it the right choice for teams working under DORA, the EU AI Act, or GDPR requirements." className="pt-0" />
  <GPUSection />
  <UseCasesTabs />
  <ShipDataApps />
  <Testimonial />
  <EssentialFeatures features={features} />
  <EnterpriseReady />
  <SupportSection />
  <DevelopersLove />
  <FinalCTA />
</Layout>

<script src="/assets/js/hero-parallax.js" defer></script>
<script src="/assets/js/tab-switching.js" defer></script>

<style>
  section {
    scroll-margin-top: 100px;
  }
</style>
