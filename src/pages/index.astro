---
import Layout from '../layouts/Layout.astro'
import Testimonial from '../components/common/Testimonial.astro'
import LandingCTA from '../components/home/LandingCTA.astro'
import SupportedBy from '../components/common/SupportedBy.astro'
import { getEntry } from 'astro:content'

const Data = await getEntry('home', 'home')
const data = Data.data
const { hero, tools, features } = data
---

<Layout title='Dataflow | AI ready data platform'>
  <!-- Hero Section -->
  <section class='relative px-[5%] pt-32 pb-20 max-sm:pt-24 max-sm:pb-16  flex items-center overflow-hidden' style='font-family: Plus Jakarta Sans, sans-serif;'>
    <!-- Background Pattern with Dataflow Animation -->
    <div class='absolute inset-0 -z-10 overflow-hidden'>
      <div class='absolute top-0 left-1/4 w-96 h-96 bg-primary/5 rounded-full blur-3xl'></div>
      <div class='absolute top-20 right-1/4 w-96 h-96 bg-blue-500/5 rounded-full blur-3xl'></div>
      <div class='absolute bottom-0 left-1/2 w-96 h-96 bg-primary/3 rounded-full blur-3xl'></div>
      <!-- Grid Pattern -->
      <div class='absolute inset-0' style='background-image: radial-gradient(circle at 1px 1px, rgb(203 213 225 / 0.15) 1px, transparent 0); background-size: 40px 40px;'></div>
      
      <!-- Animated Data Flow Nodes -->
      <svg id='dataflowSvg' class='absolute inset-0 w-full h-full opacity-40 pointer-events-auto' xmlns='http://www.w3.org/2000/svg' viewBox='0 0 1000 800' preserveAspectRatio='xMidYMid slice'>
        <!-- Connection Lines -->
        <line id='line1' x1='200' y1='250' x2='350' y2='400' stroke='url(#gradient1)' stroke-width='1.5' class='flow-line' opacity='0' />
        <line id='line2' x1='350' y1='400' x2='650' y2='350' stroke='url(#gradient2)' stroke-width='1.5' class='flow-line' opacity='0' />
        <line id='line3' x1='650' y1='350' x2='800' y2='500' stroke='url(#gradient3)' stroke-width='1.5' class='flow-line' opacity='0' />
        <line id='line4' x1='350' y1='400' x2='500' y2='550' stroke='url(#gradient1)' stroke-width='1.5' class='flow-line' opacity='0' />
        <line id='line5' x1='350' y1='400' x2='250' y2='530' stroke='url(#gradient2)' stroke-width='1.5' class='flow-line' opacity='0' />
        <line id='line6' x1='500' y1='550' x2='700' y2='580' stroke='url(#gradient3)' stroke-width='1.5' class='flow-line' opacity='0' />
        <line id='line7' x1='650' y1='350' x2='500' y2='270' stroke='url(#gradient1)' stroke-width='1.5' class='flow-line' opacity='0' />
        
        <!-- Gradient Definitions -->
        <defs>
          <linearGradient id='gradient1' x1='0%' y1='0%' x2='100%' y2='0%'>
            <stop offset='0%' style='stop-color:rgb(48 186 186);stop-opacity:0' />
            <stop offset='50%' style='stop-color:rgb(48 186 186);stop-opacity:0.7' />
            <stop offset='100%' style='stop-color:rgb(48 186 186);stop-opacity:0' />
          </linearGradient>
          <linearGradient id='gradient2' x1='0%' y1='0%' x2='100%' y2='0%'>
            <stop offset='0%' style='stop-color:rgb(48 186 186);stop-opacity:0' />
            <stop offset='50%' style='stop-color:rgb(48 186 186);stop-opacity:0.7' />
            <stop offset='100%' style='stop-color:rgb(48 186 186);stop-opacity:0' />
          </linearGradient>
          <linearGradient id='gradient3' x1='0%' y1='0%' x2='100%' y2='0%'>
            <stop offset='0%' style='stop-color:rgb(48 186 186);stop-opacity:0' />
            <stop offset='50%' style='stop-color:rgb(48 186 186);stop-opacity:0.7' />
            <stop offset='100%' style='stop-color:rgb(48 186 186);stop-opacity:0' />
          </linearGradient>
        </defs>
        
        <!-- Data Nodes with Tool Logos -->
        <!-- Node 1: Airflow -->
        <g class='data-node' data-target-x='200' data-target-y='250' data-speed='1.2'>
          <circle cx='500' cy='400' r='13' fill='white' stroke='#30baba' stroke-width='1.5' fill-opacity='0.95' opacity='0' />
          <image href='/assets/images/apps/airflow-logo.svg' x='491' y='391' width='18' height='18' opacity='0' />
        </g>
        
        <!-- Node 2: Jupyter (Center Hub) -->
        <g class='data-node' data-target-x='350' data-target-y='400' data-speed='0.8'>
          <circle cx='500' cy='400' r='16' fill='white' stroke='#30baba' stroke-width='1.5' fill-opacity='0.95' opacity='0' />
          <image href='/assets/images/apps/jupyter.png' x='490' y='390' width='20' height='20' opacity='0' />
        </g>
        
        <!-- Node 3: VS Code -->
        <g class='data-node' data-target-x='650' data-target-y='350' data-speed='1.0'>
          <circle cx='500' cy='400' r='14' fill='white' stroke='#30baba' stroke-width='1.5' fill-opacity='0.95' opacity='0' />
          <image href='/assets/images/apps/vscode-logo.png' x='491' y='391' width='18' height='18' opacity='0' />
        </g>
        
        <!-- Node 4: Streamlit -->
        <g class='data-node' data-target-x='800' data-target-y='500' data-speed='1.3'>
          <circle cx='500' cy='400' r='13' fill='white' stroke='#30baba' stroke-width='1.5' fill-opacity='0.95' opacity='0' />
          <image href='/assets/images/apps/streamlit-icon.svg' x='491' y='391' width='18' height='18' opacity='0' />
        </g>
        
        <!-- Node 5: Python -->
        <g class='data-node' data-target-x='500' data-target-y='550' data-speed='0.9'>
          <circle cx='500' cy='400' r='12' fill='white' stroke='#30baba' stroke-width='1.5' fill-opacity='0.95' opacity='0' />
          <image href='/assets/images/apps/python-logo.svg' x='492' y='392' width='16' height='16' opacity='0' />
        </g>
        
        <!-- Node 6: DBT -->
        <g class='data-node' data-target-x='250' data-target-y='530' data-speed='1.1'>
          <circle cx='500' cy='400' r='12' fill='white' stroke='#30baba' stroke-width='1.5' fill-opacity='0.95' opacity='0' />
          <image href='/assets/images/apps/dbt.png' x='492' y='392' width='16' height='16' opacity='0' />
        </g>
        
        <!-- Node 7: Dash Apps -->
        <g class='data-node' data-target-x='700' data-target-y='580' data-speed='1.15'>
          <circle cx='500' cy='400' r='12' fill='white' stroke='#30baba' stroke-width='1.5' fill-opacity='0.95' opacity='0' />
          <image href='/assets/images/apps/dashapps.png' x='492' y='392' width='16' height='16' opacity='0' />
        </g>
        
        <!-- Node 8: MLflow -->
        <g class='data-node' data-target-x='500' data-target-y='270' data-speed='0.95'>
          <circle cx='500' cy='400' r='13' fill='white' stroke='#30baba' stroke-width='1.5' fill-opacity='0.95' opacity='0' />
          <image href='/assets/images/apps/mlflow.png' x='491' y='391' width='18' height='18' opacity='0' />
        </g>
      </svg>
    </div>
    
    <div class='max-w-7xl mx-auto relative z-10'>
      <div class='text-center mb-8'>
        <h1 class='text-6xl max-sm:text-4xl font-bold text-gray-900 mb-6 leading-tight' data-aos='fade-up'>
          Focus on Data Logic,<br/>Not Glue Code.
        </h1>
        <p class='text-xl max-sm:text-lg text-gray-600 mb-8 max-w-3xl mx-auto' data-aos='fade-up' data-aos-delay='100'>
          {hero.description}
        </p>
        <div class='flex items-center justify-center gap-4 mb-8 max-sm:flex-col' data-aos='fade-up' data-aos-delay='200'>
          <a
            href='/start-free-trail'
            class='px-8 py-3 bg-primary hover:bg-primaryHover text-white rounded-lg font-semibold transition-all duration-300'
          >
            Try it free
          </a>
          <a
            href='/book-demo'
            class='px-8 py-3 border-2 border-gray-300 hover:border-primary text-gray-900 rounded-lg font-semibold transition-all duration-300'
          >
            Talk to us
          </a>
        </div>
        <div class='flex items-center justify-center gap-8 text-sm text-gray-600 max-sm:flex-col max-sm:gap-4' data-aos='fade-up' data-aos-delay='300'>
          <div class='flex items-center gap-2'>
            <svg class='w-5 h-5 text-primary' fill='currentColor' viewBox='0 0 20 20'>
              <path fill-rule='evenodd' d='M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z' clip-rule='evenodd'></path>
            </svg>
            <span>No card required</span>
          </div>
          <div class='flex items-center gap-2'>
            <svg class='w-5 h-5 text-primary' fill='currentColor' viewBox='0 0 20 20'>
              <path fill-rule='evenodd' d='M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z' clip-rule='evenodd'></path>
            </svg>
            <span>Free consultation</span>
          </div>
        </div>
      </div>

      <div class='mt-20 w-full flex flex-col items-center justify-center'>
        <p class='text-center text-sm text-gray-500 mb-6'>Powered by</p>
         <div class="flex items-center gap-10">
            <img
              src={'/assets/images/googlecloudlogo.png'}
              alt={"Google Cloud Logo"}
              class="h-[25px] max-sm:h-[30px] grayscale"
            />
            <img
              src={'/assets/images/aws-logo.png'}
              alt={"AWS Logo"}
              class="h-[25px] max-sm:h-[30px] grayscale"
            />
            <img
              src={'/assets/images/nat-west-logo.png'}
              alt={"Nat West Logo"}
              class="h-[25px] max-sm:h-[30px] grayscale"
            />
            <img
              src={'/assets/images/nvidia-logo.png'}
              alt={"Nvidia"}
              class="h-[25px] max-sm:h-[30px] grayscale"
            />
            <img
              src={'/assets/images/barclays-logo.png'}
              alt={"Barclays Logo"}
              class="h-[25px] max-sm:h-[30px] grayscale"
            />
          </div>
      </div>

    </div>
  </section>

  <!-- Use Cases Tabs Section -->
  <section class='px-[5%] py-20 bg-gray-50 max-sm:py-12' style='font-family: Plus Jakarta Sans, sans-serif;'>
    <div class='max-w-7xl mx-auto'>
      <h2 class='text-4xl max-sm:text-3xl font-bold text-center text-gray-900 mb-12' data-aos='fade-up'>
        Built for All Data Use Cases
      </h2>
      
      <div class='flex justify-center gap-4 mb-12 max-sm:flex-wrap'>
        <button class='use-case-tab px-6 py-3 bg-primary text-white rounded-lg font-medium transition-colors' data-tab='exploration'>
          Data Exploration
        </button>
        <button class='use-case-tab px-6 py-3 bg-white text-gray-700 rounded-lg font-medium hover:bg-gray-100 transition-colors' data-tab='visualisation'>
          Data Visualisation
        </button>
        <button class='use-case-tab px-6 py-3 bg-white text-gray-700 rounded-lg font-medium hover:bg-gray-100 transition-colors' data-tab='analytics'>
          Analytics
        </button>
        <button class='use-case-tab px-6 py-3 bg-white text-gray-700 rounded-lg font-medium hover:bg-gray-100 transition-colors' data-tab='etl'>
          ETL
        </button>
      </div>

      <!-- Tab Contents -->
      <div class='tab-content-wrapper relative h-[580px] max-md:h-auto'>
        <!-- Data Exploration Tab -->
        <div class='tab-content active bg-white rounded-2xl p-12 max-sm:p-6 shadow-sm' data-content='exploration'>
          <div class='grid md:grid-cols-2 gap-12 items-center'>
            <div>
              <h3 class='text-3xl font-bold text-gray-900 mb-4'>
                Explore Your Data Interactively
              </h3>
              <p class='text-gray-600 mb-6'>
                Dive deep into your data with Jupyter notebooks and interactive tools. Query, visualize, and understand your datasets with powerful exploration capabilities.
              </p>
              <ul class='space-y-3 mb-6'>
                <li class='flex items-start gap-3'>
                  <svg class='w-6 h-6 text-primary mt-0.5 flex-shrink-0' fill='currentColor' viewBox='0 0 20 20'>
                    <path fill-rule='evenodd' d='M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z' clip-rule='evenodd'></path>
                  </svg>
                  <span class='text-gray-700'>Interactive Jupyter notebooks with persistent workspaces</span>
                </li>
                <li class='flex items-start gap-3'>
                  <svg class='w-6 h-6 text-primary mt-0.5 flex-shrink-0' fill='currentColor' viewBox='0 0 20 20'>
                    <path fill-rule='evenodd' d='M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z' clip-rule='evenodd'></path>
                  </svg>
                  <span class='text-gray-700'>Pre-configured connections to all your data sources</span>
                </li>
                <li class='flex items-start gap-3'>
                  <svg class='w-6 h-6 text-primary mt-0.5 flex-shrink-0' fill='currentColor' viewBox='0 0 20 20'>
                    <path fill-rule='evenodd' d='M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z' clip-rule='evenodd'></path>
                  </svg>
                  <span class='text-gray-700'>Real-time collaboration with your team</span>
                </li>
              </ul>
              <a href='/manage-your-data-connections' class='inline-flex items-center gap-2 px-6 py-3 bg-primary hover:bg-primaryHover text-white rounded-lg font-semibold transition-all duration-300 group/btn'>
                Learn more
                <svg class='w-5 h-5 transition-transform group-hover/btn:translate-x-1' fill='none' stroke='currentColor' viewBox='0 0 24 24'>
                  <path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M9 5l7 7-7 7'></path>
                </svg>
              </a>
            </div>
            <div class='bg-gradient-to-br from-primary/10 to-primary/5 rounded-xl p-8 flex items-center justify-center min-h-[300px]'>
              <img src='/assets/images/apps/jupyter.png' alt='Data Exploration' class='max-w-full h-auto' />
            </div>
          </div>
        </div>

        <!-- Data Visualisation Tab -->
        <div class='tab-content bg-white rounded-2xl p-12 max-sm:p-6 shadow-sm' data-content='visualisation'>
          <div class='grid md:grid-cols-2 gap-12 items-center'>
            <div>
              <h3 class='text-3xl font-bold text-gray-900 mb-4'>
                Create Stunning Visualizations
              </h3>
              <p class='text-gray-600 mb-6'>
                Build interactive dashboards and visualizations with Streamlit, Dash, and other powerful tools. Share insights with stakeholders effortlessly.
              </p>
              <ul class='space-y-3 mb-6'>
                <li class='flex items-start gap-3'>
                  <svg class='w-6 h-6 text-primary mt-0.5 flex-shrink-0' fill='currentColor' viewBox='0 0 20 20'>
                    <path fill-rule='evenodd' d='M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z' clip-rule='evenodd'></path>
                  </svg>
                  <span class='text-gray-700'>Deploy Streamlit and Dash apps with one click</span>
                </li>
                <li class='flex items-start gap-3'>
                  <svg class='w-6 h-6 text-primary mt-0.5 flex-shrink-0' fill='currentColor' viewBox='0 0 20 20'>
                    <path fill-rule='evenodd' d='M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z' clip-rule='evenodd'></path>
                  </svg>
                  <span class='text-gray-700'>Instant access to live data connections</span>
                </li>
                <li class='flex items-start gap-3'>
                  <svg class='w-6 h-6 text-primary mt-0.5 flex-shrink-0' fill='currentColor' viewBox='0 0 20 20'>
                    <path fill-rule='evenodd' d='M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z' clip-rule='evenodd'></path>
                  </svg>
                  <span class='text-gray-700'>Share dashboards via secure URLs</span>
                </li>
              </ul>
              <a href='/apps' class='inline-flex items-center gap-2 px-6 py-3 bg-primary hover:bg-primaryHover text-white rounded-lg font-semibold transition-all duration-300 group/btn'>
                Learn more
                <svg class='w-5 h-5 transition-transform group-hover/btn:translate-x-1' fill='none' stroke='currentColor' viewBox='0 0 24 24'>
                  <path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M9 5l7 7-7 7'></path>
                </svg>
              </a>
            </div>
            <div class='bg-gradient-to-br from-primary/10 to-primary/5 rounded-xl p-8 flex items-center justify-center min-h-[300px]'>
              <img src='/assets/images/apps/streamlit-icon.svg' alt='Data Visualisation' class='max-w-full h-auto' />
            </div>
          </div>
        </div>

        <!-- Analytics Tab -->
        <div class='tab-content bg-white rounded-2xl p-12 max-sm:p-6 shadow-sm' data-content='analytics'>
          <div class='grid md:grid-cols-2 gap-12 items-center'>
            <div>
              <h3 class='text-3xl font-bold text-gray-900 mb-4'>
                Advanced Analytics & ML
              </h3>
              <p class='text-gray-600 mb-6'>
                Build and deploy machine learning models with MLflow. Run complex analytics pipelines with all the tools you need in one place.
              </p>
              <ul class='space-y-3 mb-6'>
                <li class='flex items-start gap-3'>
                  <svg class='w-6 h-6 text-primary mt-0.5 flex-shrink-0' fill='currentColor' viewBox='0 0 20 20'>
                    <path fill-rule='evenodd' d='M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z' clip-rule='evenodd'></path>
                  </svg>
                  <span class='text-gray-700'>MLflow integration for model tracking and deployment</span>
                </li>
                <li class='flex items-start gap-3'>
                  <svg class='w-6 h-6 text-primary mt-0.5 flex-shrink-0' fill='currentColor' viewBox='0 0 20 20'>
                    <path fill-rule='evenodd' d='M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z' clip-rule='evenodd'></path>
                  </svg>
                  <span class='text-gray-700'>GPU support for deep learning workloads</span>
                </li>
                <li class='flex items-start gap-3'>
                  <svg class='w-6 h-6 text-primary mt-0.5 flex-shrink-0' fill='currentColor' viewBox='0 0 20 20'>
                    <path fill-rule='evenodd' d='M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z' clip-rule='evenodd'></path>
                  </svg>
                  <span class='text-gray-700'>Reproducible experiments with environment management</span>
                </li>
              </ul>
              <a href='/manage-your-data-connections' class='inline-flex items-center gap-2 px-6 py-3 bg-primary hover:bg-primaryHover text-white rounded-lg font-semibold transition-all duration-300 group/btn'>
                Learn more
                <svg class='w-5 h-5 transition-transform group-hover/btn:translate-x-1' fill='none' stroke='currentColor' viewBox='0 0 24 24'>
                  <path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M9 5l7 7-7 7'></path>
                </svg>
              </a>
            </div>
            <div class='bg-gradient-to-br from-primary/10 to-primary/5 rounded-xl p-8 flex items-center justify-center min-h-[300px]'>
              <img src='/assets/images/apps/mlflow.png' alt='Analytics' class='max-w-full h-auto' />
            </div>
          </div>
        </div>

        <!-- ETL Tab -->
        <div class='tab-content bg-white rounded-2xl p-12 max-sm:p-6 shadow-sm' data-content='etl'>
          <div class='grid md:grid-cols-2 gap-12 items-center'>
            <div>
              <h3 class='text-3xl font-bold text-gray-900 mb-4'>
                Orchestrate Data Pipelines
              </h3>
              <p class='text-gray-600 mb-6'>
                Schedule and manage ETL workflows with Airflow. Transform and load data across your entire stack with zero configuration overhead.
              </p>
              <ul class='space-y-3 mb-6'>
                <li class='flex items-start gap-3'>
                  <svg class='w-6 h-6 text-primary mt-0.5 flex-shrink-0' fill='currentColor' viewBox='0 0 20 20'>
                    <path fill-rule='evenodd' d='M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z' clip-rule='evenodd'></path>
                  </svg>
                  <span class='text-gray-700'>Native Airflow with auto-synced environments</span>
                </li>
                <li class='flex items-start gap-3'>
                  <svg class='w-6 h-6 text-primary mt-0.5 flex-shrink-0' fill='currentColor' viewBox='0 0 20 20'>
                    <path fill-rule='evenodd' d='M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z' clip-rule='evenodd'></path>
                  </svg>
                  <span class='text-gray-700'>DBT integration for data transformations</span>
                </li>
                <li class='flex items-start gap-3'>
                  <svg class='w-6 h-6 text-primary mt-0.5 flex-shrink-0' fill='currentColor' viewBox='0 0 20 20'>
                    <path fill-rule='evenodd' d='M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z' clip-rule='evenodd'></path>
                  </svg>
                  <span class='text-gray-700'>Unified connection management across all pipelines</span>
                </li>
              </ul>
              <a href='/manage-your-data-connections' class='inline-flex items-center gap-2 px-6 py-3 bg-primary hover:bg-primaryHover text-white rounded-lg font-semibold transition-all duration-300 group/btn'>
                Learn more
                <svg class='w-5 h-5 transition-transform group-hover/btn:translate-x-1' fill='none' stroke='currentColor' viewBox='0 0 24 24'>
                  <path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M9 5l7 7-7 7'></path>
                </svg>
              </a>
            </div>
            <div class='bg-gradient-to-br from-primary/10 to-primary/5 rounded-xl p-8 flex items-center justify-center min-h-[300px]'>
              <img src='/assets/images/apps/airflow-logo.svg' alt='ETL' class='max-w-full h-auto' />
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

