---
import TopSection from '../components/pricing/TopSection.astro'
import SecurityComplaince from '../components/pricing/SecurityComplaince.astro'
import Layout from '../layouts/Layout.astro'
import PricingConsulation from '../components/pricing/PricingConsulation.astro'
import Testimonial from '../components/common/Testimonial.astro'
import SupportSection from '../components/pricing/SupportSection.astro'
import { getEntry } from 'astro:content'
import FAQs from '../components/pricing/FAQs.astro'
import AdditionalSupport from '../components/pricing/AdditionalSupport.astro'
import DataTableSection from '../components/common/DataTableSection.astro'
import * as FAQContent from '../content/pricing/faq.mdx'

const { data: Help_24_7_data } = await getEntry('pricing', '24-7-help')
const { data: All_in_one_solution_data } = await getEntry(
  'pricing',
  'all-in-one-solution'
)
const siteOrigin = (Astro.site?.toString() ?? 'https://dataflow.zone').replace(/\/$/, '')
const normalizedPath = Astro.url.pathname === '/' ? '/' : `${Astro.url.pathname.replace(/\/+$/, '')}/`
const pricingUrl = new URL(normalizedPath, `${siteOrigin}/`).toString()
const faqContent = FAQContent as unknown as {
  faqs: Array<{ question: string; answer: string }>
}
const pricingComparisonColumns = ['Platform', 'Monthly cost', 'Free tier', 'EU data residency', 'Setup time', 'Airflow included']
const pricingComparisonRows = [
  {
    label: 'Dataflow',
    highlight: true,
    values: [
      'From $0, then usage-based paid plans',
      'Yes',
      'Yes, including sovereign cloud options',
      'Low',
      'Yes'
    ]
  },
  {
    label: 'Astronomer',
    values: [
      'Paid plans, typically higher for production teams',
      'Limited trial',
      'Available on selected plans and regions',
      'Medium',
      'Yes'
    ]
  },
  {
    label: 'Prefect',
    striped: true,
    values: [
      'Free open-source option, paid cloud tiers',
      'Yes',
      'Plan-dependent',
      'Medium',
      'No'
    ]
  },
  {
    label: 'Databricks',
    values: [
      'Usage-based enterprise pricing',
      'Limited trial',
      'Available in supported EU regions',
      'High',
      'No'
    ]
  }
]

const pageSchema = [
  {
    '@type': 'WebPage',
    '@id': `${pricingUrl}#webpage`,
    url: pricingUrl,
    name: 'Dataflow Pricing | Free, Startup & Enterprise Plans',
    description:
      'Start free, no credit card needed. Compare Dataflow plans for startups and enterprise teams.',
    isPartOf: {
      '@id': `${siteOrigin}#website`,
    },
    about: {
      '@id': `${siteOrigin}#organization`,
    },
    breadcrumb: {
      '@id': `${pricingUrl}#breadcrumb`,
    },
    mainEntity: {
      '@id': `${pricingUrl}#softwareapplication`,
    },
  },
  {
    '@type': 'SoftwareApplication',
    '@id': `${pricingUrl}#softwareapplication`,
    name: 'Dataflow',
    applicationCategory: 'BusinessApplication',
    applicationSubCategory: 'Data Platform',
    operatingSystem: 'Web',
    url: pricingUrl,
    description: 'Flexible pricing for startups and data teams with AI-ready data workflows.',
    offers: {
      '@type': 'Offer',
      url: pricingUrl,
      price: '0',
      priceCurrency: 'USD',
      availability: 'https://schema.org/InStock',
    },
    publisher: {
      '@id': `${siteOrigin}#organization`,
    },
  },
  {
    '@type': 'FAQPage',
    '@id': `${pricingUrl}#faq`,
    mainEntity: faqContent.faqs.map((faq) => ({
      '@type': 'Question',
      name: faq.question,
      acceptedAnswer: {
        '@type': 'Answer',
        text: faq.answer,
      },
    })),
  },
]
---

<Layout
  title='Dataflow Pricing | Free, Startup & Enterprise Plans'
  meta_description='Start free, no credit card needed. Compare Dataflow plans vs Astronomer, Prefect & Databricks. Affordable managed data platform for teams of any size.'
  pageSchema={pageSchema}
>
  <TopSection />
  <PricingConsulation />
  <AdditionalSupport />
  <SecurityComplaince />
  <Testimonial />
  <DataTableSection
    title="Dataflow vs Astronomer vs Prefect vs Databricks"
    description="Snapshot comparison for teams evaluating managed orchestration and data app delivery platforms."
    columns={pricingComparisonColumns}
    rows={pricingComparisonRows}
    minWidthClass="min-w-[900px]"
    bg="white"
  />
  <FAQs />
</Layout>
