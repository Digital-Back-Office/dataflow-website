---
import Layout from '../../layouts/Layout.astro'
import TopSection from '../../components/common/TopSection.astro'
import FeatureGrid from '../../components/common/FeatureGrid.astro'
import TwoColumnSection from '../../components/common/TwoColumnSection.astro'
import CardsWithBulletsSection from '../../components/common/CardsWithBulletsSection.astro'
import Comparison from '../../components/features/deploy-to-production/Comparison.astro'
import { getEntry } from 'astro:content'

const Data = await getEntry('features', 'deploy-to-production')
const top = Data?.data?.top_section || {}
const seo = Data?.data?.seo
const seamlessDeployment = Data?.data?.seamless_deployment || {}
const productionParity = Data?.data?.production_parity || {}
const managedSecrets = Data?.data?.managed_secrets_in_production || {}
const meta_description = top.description ?? 'Deploy applications to production seamlessly with zero environment drift and automatic scaling.'
const deployCards = [
  {
    title: 'Deploy Jupyter notebooks to production',
    bullets: [
      'Publish notebook logic as production workloads without rebuilding your environment.',
      'Use the same dependencies and secrets from development to avoid release-time regressions.',
      'Schedule and monitor notebook runs with operational controls your team can share.'
    ]
  },
  {
    title: 'Deploy Streamlit and Dash apps',
    bullets: [
      'Ship interactive apps with one click and secure URLs for internal or customer access.',
      'Keep app runtimes aligned with shared team environments to reduce breakage between contributors.',
      'Scale application compute based on demand instead of hand-managing container infrastructure.'
    ]
  },
  {
    title: 'Turn notebooks into live APIs',
    bullets: [
      'Expose validated notebook workflows as live API endpoints for product and analytics use cases.',
      'Version API deployments using immutable environments so rollbacks stay predictable.',
      'Connect APIs to pipeline schedules and shared credentials without writing custom glue services.'
    ]
  }
]
const streamlitAlternative = 'Dataflow is a practical Streamlit Cloud alternative for teams that need shared environments, native Airflow integration, and sovereign cloud deployment options. These capabilities let you move from prototype to production with fewer platform gaps across engineering, analytics, and compliance.'
---

<Layout
  title={seo?.title ?? 'Deploy to Production | One-Click Data Deployments'}
  meta_description={seo?.description ?? meta_description}
>
  <TopSection
    title={top.title}
    description={top.description}
    image={top.hero_image}
    buttonText={top.button?.label}
    buttonHref={top.button?.href}
    buttonTarget='_blank'
    imageSide="right"
    bg="white"
  />

  <CardsWithBulletsSection cards={deployCards} calloutText={streamlitAlternative} bg="white" />

  <FeatureGrid
    title={seamlessDeployment.title}
    description={seamlessDeployment.description}
    features={seamlessDeployment.features}
    button={seamlessDeployment.button}
    bg="F8FAFC"
  />

  <TwoColumnSection
    title={productionParity.title}
    description={productionParity.description}
    image={productionParity.image}
    imageSide={productionParity.imageSide}
    bg="white"
  />

  <Comparison />

  <FeatureGrid
    title={managedSecrets.title}
    description={managedSecrets.description}
    features={managedSecrets.features}
    bg="white"
  />

  <section class='px-[5%] pb-16 bg-white'>
    <div class='max-w-5xl mx-auto text-center text-sm text-gray-600'>
      Pair this with <a href='/product/shared-foundation' title='Explore shared foundation' class='text-primary hover:text-primaryHover underline underline-offset-2'>Shared Foundation</a> and <a href='/product/managed-dependencies' title='Explore managed dependencies' class='text-primary hover:text-primaryHover underline underline-offset-2'>Managed Dependencies</a>, compare rollout options on <a href='/pricing' title='Compare rollout pricing options' class='text-primary hover:text-primaryHover underline underline-offset-2'>Pricing</a>, or <a href='/book-demo' title='Book a production-readiness demo' class='text-primary hover:text-primaryHover underline underline-offset-2'>Book a Demo</a> for a production-readiness review.
    </div>
  </section>
</Layout>
