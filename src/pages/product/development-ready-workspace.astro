---
import Layout from '../../layouts/Layout.astro'
import TopSection from '../../components/common/TopSection.astro'
import CardGrid from '../../components/common/CardGrid.astro'
import TwoColumnSection from '../../components/common/TwoColumnSection.astro'
import BulletComparisonSection from '../../components/common/BulletComparisonSection.astro'
import { getEntry } from 'astro:content'

const Data = await getEntry('features', 'development-ready-workspace')
const top = Data?.data?.top_section || {}
const seo = Data?.data?.seo
const whatYouGet = Data?.data?.what_you_get || {}
const instantOnboarding = Data?.data?.instant_onboarding || {}
const computeFlexibility = Data?.data?.compute_flexibility || {}
const meta_description = top.description ?? 'Get a fully configured workspace with compute, environments, and applications ready to use in seconds.'
const colabComparisonBullets = [
  {
    title: 'Team environments',
    text: 'Dataflow gives every teammate the same managed environment instead of ad-hoc notebook-level package installs.'
  },
  {
    title: 'Persistent workspaces',
    text: 'Your files, apps, and dependencies stay available between sessions so teams do not rebuild context every day.'
  },
  {
    title: 'Pipeline integration',
    text: 'Jupyter work connects directly to Airflow orchestration and production deployment without hand-offs.'
  },
  {
    title: 'EU data residency',
    text: 'You can deploy on sovereign European cloud providers to satisfy strict governance requirements.'
  }
]
---

<Layout
  title={seo?.title ?? 'Cloud Data Science Workspace | Jupyter, VS Code & MLflow | Dataflow'}
  meta_description={seo?.description ?? 'Start building instantly. Pre-configured Jupyter notebooks, VS Code & MLflow all connected to your data sources with zero setup. Better than Google Colab.'}
>
  <TopSection
    title={top.title}
    description={top.description}
    image={top.hero_image}
    buttonText={top.button?.label}
    buttonHref={top.button?.href}
    buttonTarget='_blank'
    imageSide="right"
    bg="white"
  />

  <CardGrid
    title={whatYouGet.title}
    description={whatYouGet.description}
    features={whatYouGet.features}
    columns={2}
    bg="gray"
  />

  <TwoColumnSection
    title={instantOnboarding.title}
    description={instantOnboarding.description}
    image={instantOnboarding.image}
    buttonText={instantOnboarding.button?.label}
    buttonHref={instantOnboarding.button?.href}
    buttonTarget={instantOnboarding.button?.target ?? "_blank"}
    imageSide={instantOnboarding.imageSide}
    bg="white"
  />

  <BulletComparisonSection
    title="How Dataflow compares to Google Colab"
    bullets={colabComparisonBullets}
    paragraph="For smaller data teams that find Databricks too expensive or operationally heavy, Dataflow is a cost-effective alternative with pre-configured tooling, faster onboarding, and less platform overhead."
    cta={{ label: 'Try Dataflow Free', href: 'https://app.dataflow.zone', target: '_blank' }}
    bg="F8FAFC"
  />

  {computeFlexibility?.features && (
    <CardGrid
      title={computeFlexibility.title}
      description={computeFlexibility.description}
      features={computeFlexibility.features}
      columns={3}
      bg="white"
    />
  )}
  <section class='px-[5%] pb-16 bg-white'>
    <div class='max-w-5xl mx-auto text-center text-sm text-gray-600'>
      To harden your workflow, pair this with <a href='/product/managed-dependencies' title='Explore managed dependencies' class='text-primary hover:text-primaryHover underline underline-offset-2'>Managed Dependencies</a> and <a href='/product/deploy-to-production' title='Explore deploy to production' class='text-primary hover:text-primaryHover underline underline-offset-2'>Deploy to Production</a>, then compare options on <a href='/pricing' title='Compare pricing options' class='text-primary hover:text-primaryHover underline underline-offset-2'>Pricing</a>.
    </div>
  </section>
</Layout>
