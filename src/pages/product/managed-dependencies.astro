---
import Layout from '../../layouts/Layout.astro'
import TopSection from '../../components/common/TopSection.astro'
import CardGrid from '../../components/common/CardGrid.astro'
import FeatureGrid from '../../components/common/FeatureGrid.astro'
import TwoColumnSection from '../../components/common/TwoColumnSection.astro'
import ProcessSteps from '../../components/common/ProcessSteps.astro'
import DataTableSection from '../../components/common/DataTableSection.astro'
import { getEntry } from 'astro:content'

const Data = await getEntry('features', 'managed-dependencies')
const top = Data?.data?.top_section || {}
const seo = Data?.data?.seo
const problemSection = Data?.data?.problem_section || {}
const solutionSection = Data?.data?.solution_section || {}
const howItWorks = Data?.data?.how_it_works || {}
const keyBenefits = Data?.data?.key_benefits || {}
const meta_description = top.description ?? 'Eliminate Python dependency hell with managed, reproducible environments shared across your entire team.'
const dependencyTableColumns = ['Tool', 'Reproducibility', 'Team sharing', 'Cloud support', 'Setup time']
const dependencyTableRows = [
  {
    label: 'conda',
    values: [
      'Moderate; can drift between channels and OS builds.',
      'Manual export/import of environment files.',
      'Works in cloud VMs; extra setup in managed runtimes.',
      'Medium'
    ]
  },
  {
    label: 'venv + pip',
    striped: true,
    values: [
      'Low to moderate; lock files are often incomplete.',
      'Depends on developers reproducing local steps.',
      'Common but fragile across notebook, scheduler, and app runtimes.',
      'Medium'
    ]
  },
  {
    label: 'Docker',
    values: [
      'High when images are pinned and rebuilt consistently.',
      'Strong via registries, but requires Docker workflow knowledge.',
      'Strong across cloud providers and orchestrators.',
      'High'
    ]
  },
  {
    label: 'Dataflow',
    highlight: true,
    values: [
      'High with immutable, shared environment snapshots.',
      'Built-in team sharing across workspace and deployed workloads.',
      'Designed for managed cloud and sovereign cloud deployments.',
      'Low'
    ]
  }
]
--- 

<Layout
  title={seo?.title ?? 'Managed Python Dependencies | No More pip Errors | Dataflow'}
  meta_description={seo?.description ?? 'Say goodbye to dependency hell. Dataflow creates containerised, immutable Python environments in one click. Share across Jupyter, Airflow & VS Code seamlessly.'}
>
  <TopSection
    title={top.title}
    description={top.description}
    image={top.hero_image}
    buttonText={top.button?.label}
    buttonHref={top.button?.href}
    buttonTarget='_blank'
    imageSide="right"
    bg="white"
  />

  <DataTableSection
    title="Why pip install keeps failing and what Dataflow does instead"
    intro="Local dependency workflows break because each machine resolves packages differently and teams mix ad-hoc fixes over time. Dataflow replaces this with containerized, immutable environments that are built once and reused across Jupyter, Airflow, and deployed apps. Every run uses the same locked environment, so version conflicts and works-on-my-machine issues stop blocking delivery."
    columns={dependencyTableColumns}
    rows={dependencyTableRows}
    bg="F8FAFC"
  />
  
  <FeatureGrid
    title={problemSection.title}
    description={problemSection.description}
    features={problemSection.problems}
    bg="gray"
  />

  <TwoColumnSection
    title={solutionSection.title}
    description={solutionSection.description}
    image={solutionSection.image}
    buttonText={solutionSection.button?.label}
    buttonHref={solutionSection.button?.href}
    buttonTarget={solutionSection.button?.target ?? "_blank"}
    imageSide={solutionSection.imageSide}
    bg="white"
  />

  <ProcessSteps
    title={howItWorks.title}
    description={howItWorks.description}
    steps={howItWorks.features}
    bg="gray"
  />

  <CardGrid
    title={keyBenefits.title}
    description={keyBenefits.description}
    features={keyBenefits.features}
    columns={3}
    bg="white"
  />

  <section class='px-[5%] pb-16 bg-white'>
    <div class='max-w-5xl mx-auto text-center text-sm text-gray-600'>
      See how dependency management connects with <a href='/product/shared-foundation' title='Explore shared foundation' class='text-primary hover:text-primaryHover underline underline-offset-2'>Shared Foundation</a> and <a href='/product/deploy-to-production' title='Explore deployment features' class='text-primary hover:text-primaryHover underline underline-offset-2'>Deployment</a>, explore real-world examples in the <a href='/blog' title='Read real-world examples in the blog' class='text-primary hover:text-primaryHover underline underline-offset-2'>Blog</a>, or compare plans on <a href='/pricing' title='Compare pricing plans' class='text-primary hover:text-primaryHover underline underline-offset-2'>Pricing</a>.
    </div>
  </section>
</Layout>
