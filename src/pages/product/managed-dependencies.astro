---
import Layout from '../../layouts/Layout.astro'
import TopSection from '../../components/common/TopSection.astro'
import CardGrid from '../../components/common/CardGrid.astro'
import FeatureGrid from '../../components/common/FeatureGrid.astro'
import TwoColumnSection from '../../components/common/TwoColumnSection.astro'
import ProcessSteps from '../../components/common/ProcessSteps.astro'
import { getEntry } from 'astro:content'

const Data = await getEntry('features', 'managed-dependencies')
const top = Data?.data?.top_section || {}
const seo = Data?.data?.seo
const problemSection = Data?.data?.problem_section || {}
const solutionSection = Data?.data?.solution_section || {}
const howItWorks = Data?.data?.how_it_works || {}
const keyBenefits = Data?.data?.key_benefits || {}
const meta_description = top.description ?? 'Eliminate Python dependency hell with managed, reproducible environments shared across your entire team.'
--- 

<Layout
  title={seo?.title ?? 'Managed Python Dependencies | No More pip Errors | Dataflow'}
  meta_description={seo?.description ?? 'Say goodbye to dependency hell. Dataflow creates containerised, immutable Python environments in one click. Share across Jupyter, Airflow & VS Code seamlessly.'}
>
  <TopSection
    title={top.title}
    description={top.description}
    image={top.hero_image}
    buttonText={top.button?.label}
    buttonHref={top.button?.href}
    buttonTarget='_blank'
    imageSide="right"
    bg="white"
  />
  
  <FeatureGrid
    title={problemSection.title}
    description={problemSection.description}
    features={problemSection.problems}
    bg="gray"
  />

  <TwoColumnSection
    title={solutionSection.title}
    description={solutionSection.description}
    image={solutionSection.image}
    buttonText={solutionSection.button?.label}
    buttonHref={solutionSection.button?.href}
    buttonTarget={solutionSection.button?.target ?? "_blank"}
    imageSide={solutionSection.imageSide}
    bg="white"
  />

  <ProcessSteps
    title={howItWorks.title}
    description={howItWorks.description}
    steps={howItWorks.features}
    bg="gray"
  />

  <CardGrid
    title={keyBenefits.title}
    description={keyBenefits.description}
    features={keyBenefits.features}
    columns={3}
    bg="white"
  />

  <section class='px-[5%] pb-16 bg-white'>
    <div class='max-w-5xl mx-auto text-center text-sm text-gray-600'>
      See how dependency management connects with <a href='/product/shared-foundation' class='text-primary hover:text-primaryHover underline underline-offset-2'>Shared Foundation</a> and <a href='/product/deploy-to-production' class='text-primary hover:text-primaryHover underline underline-offset-2'>Deployment</a>, explore real-world examples in the <a href='/blog' class='text-primary hover:text-primaryHover underline underline-offset-2'>Blog</a>, or compare plans on <a href='/pricing' class='text-primary hover:text-primaryHover underline underline-offset-2'>Pricing</a>.
    </div>
  </section>
</Layout>
