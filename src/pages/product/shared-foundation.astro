---
import Benefits from '../../components/features/manage-data-efficiently/Benefits.astro'
import DataConnections from '../../components/features/manage-data-efficiently/DataConnections.astro'
import FeatureGrid from '../../components/common/FeatureGrid.astro'
import Comparison from '../../components/features/manage-data-efficiently/Comparison.astro'
import TopSection from '../../components/common/TopSection.astro'
import Layout from '../../layouts/Layout.astro'
import { getEntry } from 'astro:content'

const Data = await getEntry('features', 'manage-your-data-connections')
const top = Data?.data?.top_section || {}
const coreFeatures = Data?.data?.core_features || {}
const meta_description = top.description ?? 'Seamlessly manage your data connections across various apps and platforms with Dataflow.'
---

<Layout
  title='Shared Foundation'
  meta_description={meta_description}
>
  <TopSection
    title={top.title}
    description={top.description}
    image={top.hero_image}
    buttonText={top.button?.label}
    buttonHref={top.button?.href}
    buttonTarget='_blank'
    imageSide="right"
    bg="white"
  />
  <Comparison />
  <Benefits />
  <DataConnections />
  <FeatureGrid
    title={coreFeatures.title}
    description={coreFeatures.description}
    features={coreFeatures.features}
    button={coreFeatures.button}
    className="pl-[5%] justify-evenly"
  />
</Layout>
