---
import Layout from '../../layouts/Layout.astro'
import TopSection from '../../components/common/TopSection.astro'
import FeatureGrid from '../../components/common/FeatureGrid.astro'
import CardGrid from '../../components/common/CardGrid.astro'
import TwoColumnSection from '../../components/common/TwoColumnSection.astro'
import Comparison from '../../components/features/shared-foundation/Comparison.astro'
import { getEntry } from 'astro:content'

const Data = await getEntry('features', 'shared-foundation')
const top = Data?.data?.top_section || {}
const seo = Data?.data?.seo
const sharedPlatformLayer = Data?.data?.shared_platform_layer || {}
const builtOnManagedDeps = Data?.data?.built_on_managed_dependencies || {}
const keyBenefits = Data?.data?.key_benefits || {}
const meta_description = top.description ?? 'A common platform layer shared across all applications. Unified environments, configuration, and zero duplication.'
---

<Layout
  title={seo?.title ?? 'One Shared Python Environment for Your Whole Data Team | Dataflow'}
  meta_description={seo?.description ?? 'Define your environment once sync it automatically across notebooks, pipelines and dashboards. Manage secrets, connections & RBAC from a single foundation.'}
>
  <TopSection
    title={top.title}
    description={top.description}
    image={top.hero_image}
    buttonText={top.button?.label}
    buttonHref={top.button?.href}
    buttonTarget='_blank'
    imageSide="right"
    bg="white"
  />

  <FeatureGrid
    title={sharedPlatformLayer.title}
    description={sharedPlatformLayer.description}
    features={sharedPlatformLayer.features}
    button={sharedPlatformLayer.button}
    bg="F8FAFC"
  />

  <TwoColumnSection
    title={builtOnManagedDeps.title}
    description={builtOnManagedDeps.description}
    image={builtOnManagedDeps.image}
    imageSide={builtOnManagedDeps.imageSide}
    linkText={builtOnManagedDeps.linkText}
    linkHref={builtOnManagedDeps.link}
    linkTarget="_self"
    bg="white"
  />

  <Comparison />

  <CardGrid
    title={keyBenefits.title}
    description={keyBenefits.description}
    features={keyBenefits.features}
    columns={3}
    bg="gray"
  />

  <section class='px-[5%] pb-16 bg-white'>
    <div class='max-w-5xl mx-auto text-center text-sm text-gray-600'>
      Next steps: align with <a href='/product/managed-dependencies' class='text-primary hover:text-primaryHover underline underline-offset-2'>Managed Dependencies</a>, ship reliably using <a href='/product/deploy-to-production' class='text-primary hover:text-primaryHover underline underline-offset-2'>Deploy to Production</a>, review <a href='/pricing' class='text-primary hover:text-primaryHover underline underline-offset-2'>Pricing</a>, and <a href='/book-demo' class='text-primary hover:text-primaryHover underline underline-offset-2'>Book a Demo</a> for architecture planning.
    </div>
  </section>

</Layout>
