---
import Layout from '../../layouts/Layout.astro'

const stats = [
  { label: 'Fast approval', value: '3–5 days' },
  { label: 'Credits', value: 'Up to $1000' },
  { label: 'No card', value: '100% free' }
]

const whoFor = [
  'Students & researchers',
  'Indie developers',
  'Data teams',
  'Startups & founders',
  'Data & AI engineers'
]

const benefits = [
  'CPU & GPU compute',
  'Secure cloud storage',
  'Jupyter, Airflow, Streamlit, VS Code',
  'Browser-based environment',
  'No Setup. No Maintenance.'
]

const steps = [
  {
    title: 'Apply',
    description: 'Fill out a short application about your project and background.'
  },
  { title: 'Review', description: 'Our team reviews applications on a rolling basis.' },
  { title: 'Get Credits', description: 'Approved users receive credits directly in your account.' },
  { title: 'Refer & Earn', description: 'Invite others and unlock more credits.' }
]

const faqs = [
  {
    q: 'How much free credit will I receive?',
    a: 'Credits are allocated based on your project scope and requirements.'
  },
  { q: 'Do I need a credit card?', a: 'No. This campaign is completely free.' },
  {
    q: 'How long are credits valid?',
    a: 'Credits are valid for a limited period. Details are shared after approval.'
  },
  { q: 'Can teams or startups apply?', a: 'Yes. Individual builders and teams are welcome.' },
  {
    q: 'When will I hear back?',
    a: 'Most applications are reviewed within 3–5 business days.'
  }
]
---

<Layout title='Dataflow Credits Campaign | Variation 2'>
  <section class='relative bg-[#0d1f1f] text-white overflow-hidden'>
    <div class='absolute inset-0 opacity-30'>
      <div class='absolute -top-20 -left-10 size-72 rounded-full bg-primary/40 blur-3xl'></div>
      <div class='absolute top-20 -right-10 size-80 rounded-full bg-secondary/30 blur-3xl'></div>
    </div>
    <div class='max-w-7xl mx-auto px-[5%] pt-28 pb-20 relative'>
      <div class='grid lg:grid-cols-[1.1fr_0.9fr] gap-16 items-center'>
        <div class='space-y-8'>
          <div class='inline-flex items-center gap-2 rounded-full bg-white/10 px-4 py-2 text-sm font-semibold'>
            <span class='size-2 rounded-full bg-secondary'></span>
            Limited-Time Campaign
          </div>
          <div class='space-y-4'>
            <h1 class='text-5xl max-sm:text-4xl font-bold leading-tight'>
              Get Free Dataflow Credits
            </h1>
            <p class='text-xl text-white/80 font-semibold'>Build faster. Spend nothing.</p>
            <p class='text-white/70'>
              Run Python, ML, and data workflows instantly — without setting up infrastructure.
            </p>
          </div>
          <div class='flex flex-wrap gap-3'>
            <a
              href='#apply'
              class='px-6 py-3 rounded-lg bg-primary text-white font-semibold shadow-lg hover:bg-primaryHover transition'
            >
              Apply for Free Credits
            </a>
            <a
              href='#referral'
              class='px-6 py-3 rounded-lg border border-white/40 text-white font-semibold hover:border-white transition'
            >
              Refer & Earn More
            </a>
          </div>
          <div class='flex flex-wrap gap-3 text-sm text-white/70'>
            <span class='rounded-full border border-white/20 px-3 py-1'>No Credit Card Required</span>
            <span class='rounded-full border border-white/20 px-3 py-1'>Reviewed Applications</span>
            <span class='rounded-full border border-white/20 px-3 py-1'>Built for Builders</span>
          </div>
        </div>
        <div class='relative'>
          <div class='bg-white text-textDarker rounded-3xl p-8 shadow-2xl'>
            <p class='text-sm text-textPrimary/70'>Get up to</p>
            <p class='text-4xl font-bold text-textDarker'>$1000 credits</p>
            <p class='text-textPrimary/80 mt-3'>Apply once. Get credits. Earn more with referrals.</p>
            <div class='mt-6 grid grid-cols-3 gap-3'>
              {stats.map((stat) => (
                <div class='rounded-2xl border border-primary/10 bg-[#f7fbfb] p-3 text-center'>
                  <p class='text-sm text-textPrimary/70'>{stat.label}</p>
                  <p class='font-semibold text-textDarker'>{stat.value}</p>
                </div>
              ))}
            </div>
          </div>
          <div class='absolute -bottom-8 -left-8 hidden lg:block'>
            <div class='rounded-2xl bg-[#f7fbfb] px-4 py-3 border border-primary/10 text-textPrimary'>
              <p class='font-semibold text-textDarker'>Who is this for?</p>
              <p class='text-sm text-textPrimary/70'>Builders, teams, and students</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class='max-w-7xl mx-auto px-[5%] py-16'>
    <div class='grid lg:grid-cols-[0.9fr_1.1fr] gap-12 items-start'>
      <div class='space-y-5'>
        <p class='text-sm font-semibold text-primary uppercase tracking-wide'>What is it?</p>
        <h2 class='text-4xl font-bold text-textDarker'>Build without worrying about cloud costs</h2>
        <p class='text-textPrimary/80 leading-relaxed'>
          The Dataflow Credits Campaign is a limited-time initiative to support builders who want to experiment, learn, and ship faster.
          We’re offering free platform credits so you can focus on building — not infrastructure.
        </p>
      </div>
      <div class='grid sm:grid-cols-2 gap-4'>
        {whoFor.map((item) => (
          <div class='rounded-2xl border border-primary/10 bg-white p-5 shadow-sm'>
            <p class='font-semibold text-textDarker'>{item}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class='bg-[#f7fbfb] py-16'>
    <div class='max-w-7xl mx-auto px-[5%]'>
      <div class='flex items-center justify-between flex-wrap gap-6 mb-10'>
        <div>
          <p class='text-sm font-semibold text-primary uppercase tracking-wide'>What you get</p>
          <h2 class='text-4xl font-bold text-textDarker'>A playful stack of powerful tools</h2>
        </div>
        <div class='text-sm text-textPrimary/70 max-w-md'>
          Everything you need to run data workflows in one browser-based environment.
        </div>
      </div>
      <div class='grid md:grid-cols-2 gap-6'>
        {benefits.map((benefit, index) => (
          <div class={`rounded-3xl p-6 border border-primary/10 shadow-sm ${index % 2 === 0 ? 'bg-white' : 'bg-primary/5'}`}>
            <div class='flex items-center gap-3'>
              <span class='size-10 rounded-2xl bg-primary/10 flex items-center justify-center text-primary font-bold'>
                {index + 1}
              </span>
              <p class='text-lg font-semibold text-textDarker'>{benefit}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section id='referral' class='max-w-7xl mx-auto px-[5%] py-16'>
    <div class='grid lg:grid-cols-[1.1fr_0.9fr] gap-12 items-center'>
      <div class='space-y-5'>
        <p class='text-sm font-semibold text-primary uppercase tracking-wide'>Referral Program</p>
        <h2 class='text-4xl font-bold text-textDarker'>Earn More Credits by Referring Others</h2>
        <p class='text-textPrimary/80 leading-relaxed'>
          Share your unique referral link and earn bonus credits for every approved signup.
        </p>
        <ul class='space-y-3 text-textPrimary'>
          <li class='flex items-center gap-3'>Invite friends or teammates</li>
          <li class='flex items-center gap-3'>They apply using your referral link</li>
          <li class='flex items-center gap-3'>Both of you get extra credits</li>
          <li class='flex items-center gap-3'>No limits. No spam. Quality referrals only.</li>
        </ul>
        <a
          href='#apply'
          class='inline-flex items-center gap-2 px-6 py-3 rounded-lg bg-primary text-white font-semibold shadow-lg hover:bg-primaryHover transition'
        >
          Get My Referral Link
        </a>
      </div>
      <div class='rounded-3xl border border-primary/10 bg-white p-8 shadow-lg'>
        <h3 class='text-2xl font-bold text-textDarker mb-6'>How it works</h3>
        <div class='space-y-4'>
          {steps.map((step, index) => (
            <div class='flex gap-4'>
              <div class='size-10 rounded-full bg-primary/10 flex items-center justify-center text-primary font-bold'>
                {index + 1}
              </div>
              <div>
                <p class='font-semibold text-textDarker'>{step.title}</p>
                <p class='text-sm text-textPrimary/80'>{step.description}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section id='apply' class='bg-[#f7fbfb] py-16'>
    <div class='max-w-7xl mx-auto px-[5%] grid lg:grid-cols-[0.9fr_1.1fr] gap-12'>
      <div class='space-y-5'>
        <p class='text-sm font-semibold text-primary uppercase tracking-wide'>Application</p>
        <h2 class='text-4xl font-bold text-textDarker'>Apply for Free Credits</h2>
        <p class='text-textPrimary/80 leading-relaxed'>Share a few details and we’ll get back within 3–5 business days.</p>
      </div>
      <form class='bg-white rounded-3xl border border-primary/10 shadow-lg p-8 space-y-6'>
        <div class='grid sm:grid-cols-2 gap-4'>
          <div class='space-y-2'>
            <label class='text-sm font-semibold text-textPrimary'>Full Name</label>
            <input
              type='text'
              placeholder='Your name'
              class='w-full h-11 rounded-lg border border-gray-200 px-3 focus:outline-none focus:ring-2 focus:ring-primary/30'
            />
          </div>
          <div class='space-y-2'>
            <label class='text-sm font-semibold text-textPrimary'>Email Address</label>
            <input
              type='email'
              placeholder='you@email.com'
              class='w-full h-11 rounded-lg border border-gray-200 px-3 focus:outline-none focus:ring-2 focus:ring-primary/30'
            />
          </div>
          <div class='space-y-2'>
            <label class='text-sm font-semibold text-textPrimary'>Country</label>
            <input
              type='text'
              placeholder='Country'
              class='w-full h-11 rounded-lg border border-gray-200 px-3 focus:outline-none focus:ring-2 focus:ring-primary/30'
            />
          </div>
          <div class='space-y-2'>
            <label class='text-sm font-semibold text-textPrimary'>Role</label>
            <select class='w-full h-11 rounded-lg border border-gray-200 px-3 focus:outline-none focus:ring-2 focus:ring-primary/30'>
              <option>Student</option>
              <option>Developer</option>
              <option>Researcher</option>
              <option>Founder</option>
              <option>Other</option>
            </select>
          </div>
        </div>
        <div class='grid sm:grid-cols-2 gap-4'>
          <div class='space-y-2'>
            <label class='text-sm font-semibold text-textPrimary'>Experience Level</label>
            <select class='w-full h-11 rounded-lg border border-gray-200 px-3 focus:outline-none focus:ring-2 focus:ring-primary/30'>
              <option>Beginner</option>
              <option>Intermediate</option>
              <option>Advanced</option>
            </select>
          </div>
          <div class='space-y-2'>
            <label class='text-sm font-semibold text-textPrimary'>GitHub / Portfolio / LinkedIn (Optional)</label>
            <input
              type='text'
              placeholder='Link'
              class='w-full h-11 rounded-lg border border-gray-200 px-3 focus:outline-none focus:ring-2 focus:ring-primary/30'
            />
          </div>
        </div>
        <button type='submit' class='w-full h-12 rounded-lg bg-primary text-white font-semibold shadow-md hover:bg-primaryHover transition'>
          Submit Application
        </button>
      </form>
    </div>
  </section>

  <section class='max-w-7xl mx-auto px-[5%] py-16'>
    <div class='grid lg:grid-cols-[1.1fr_0.9fr] gap-12 items-start'>
      <div class='space-y-5'>
        <p class='text-sm font-semibold text-primary uppercase tracking-wide'>FAQ</p>
        <h2 class='text-4xl font-bold text-textDarker'>Everything you need to know</h2>
        <p class='text-textPrimary/80'>Clear answers before you apply.</p>
      </div>
      <div class='space-y-4'>
        {faqs.map((item) => (
          <details class='group rounded-2xl border border-primary/10 bg-white p-5'>
            <summary class='flex items-center justify-between cursor-pointer text-textDarker font-semibold'>
              {item.q}
              <span class='transition group-open:rotate-45 text-primary text-xl'>+</span>
            </summary>
            <p class='mt-3 text-sm text-textPrimary/80'>{item.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class='bg-gradient-to-r from-primary to-secondary py-16'>
    <div class='max-w-6xl mx-auto px-[5%] text-center text-white space-y-6'>
      <h2 class='text-4xl font-bold'>Ready to Build Without Limits?</h2>
      <p class='text-lg text-white/90'>Start experimenting, learning, and shipping — without worrying about cloud costs.</p>
      <div class='flex flex-wrap justify-center gap-4'>
        <a href='#apply' class='px-6 py-3 rounded-lg bg-white text-primary font-semibold shadow-lg'>
          Apply for Free Credits
        </a>
        <a href='#referral' class='px-6 py-3 rounded-lg border border-white/70 text-white font-semibold'>
          Refer Friends & Earn More
        </a>
      </div>
    </div>
  </section>
</Layout>
