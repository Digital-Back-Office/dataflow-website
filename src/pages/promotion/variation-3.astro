---
import Layout from '../../layouts/Layout.astro'
import PromotionCreditsForm from '../../components/promotion/PromotionCreditsForm.jsx'

const stats = [
  { label: 'Fast approval', value: '3–5 days' },
  { label: 'Credits', value: 'Up to $1000' },
  { label: 'No card', value: '100% free' }
]

const whoFor = [
  'Students & researchers',
  'Indie developers',
  'Data teams',
  'Startups & founders',
  'Data & AI engineers'
]

const benefits = [
  'CPU & GPU compute',
  'Secure cloud storage',
  'Jupyter, Airflow, Streamlit, VS Code',
  'Browser-based environment',
  'No Setup. No Maintenance.'
]

const referralSteps = [
  'Invite friends or teammates',
  'They apply using your referral link',
  'Both of you get extra credits',
  'No limits. No spam. Quality referrals only.'
]

const howItWorks = [
  {
    title: 'Apply',
    description: 'Fill out a short application about your project and background.'
  },
  { title: 'Review', description: 'Our team reviews applications on a rolling basis.' },
  { title: 'Get Credits', description: 'Approved users receive credits directly in your account.' },
  { title: 'Refer & Earn', description: 'Invite others and unlock more credits.' }
]

const faqs = [
  {
    q: 'How much free credit will I receive?',
    a: 'Credits are allocated based on your project scope and requirements.'
  },
  { q: 'Do I need a credit card?', a: 'No. This campaign is completely free.' },
  {
    q: 'How long are credits valid?',
    a: 'Credits are valid for a limited period. Details are shared after approval.'
  },
  { q: 'Can teams or startups apply?', a: 'Yes. Individual builders and teams are welcome.' },
  {
    q: 'When will I hear back?',
    a: 'Most applications are reviewed within 3–5 business days.'
  }
]
---

<Layout title='Dataflow Credits Campaign | Variation 4'>
  <section class='relative bg-[#0d1f1f] text-white overflow-hidden'>
    <div class='absolute inset-0 opacity-30'>
      <div class='absolute -top-20 -left-10 size-72 rounded-full bg-primary/40 blur-3xl'></div>
      <div class='absolute top-20 -right-10 size-80 rounded-full bg-secondary/30 blur-3xl'></div>
    </div>
    <div class='max-w-7xl mx-auto px-[5%] pt-32 pb-24 relative'>
      <div class='grid lg:grid-cols-[1.1fr_0.9fr] gap-16 items-center'>
        <div class='space-y-8'>
          <div class='inline-flex items-center gap-2 rounded-full bg-white/10 px-4 py-2 text-sm font-semibold'>
            <span class='size-2 rounded-full bg-secondary'></span>
            Limited-Time Campaign
          </div>
          <div class='space-y-4'>
            <h1 class='text-5xl max-sm:text-4xl font-bold leading-tight'>
              Get Free Dataflow Credits
            </h1>
            <p class='text-xl text-white/80 font-semibold'>Build faster. Spend nothing.</p>
            <p class='text-white/70'>
              Run Python, ML, and data workflows instantly — without setting up infrastructure.
            </p>
          </div>
          <div class='flex flex-wrap gap-3'>
            <a
              href='#apply'
              class='px-6 py-3 rounded-lg bg-primary text-white font-semibold shadow-lg hover:bg-primaryHover transition'
            >
              Apply for Free Credits
            </a>
            <a
              href='#referral'
              class='px-6 py-3 rounded-lg border border-white/40 text-white font-semibold hover:border-white transition'
            >
              Refer & Earn More
            </a>
          </div>
          <div class='flex flex-wrap gap-3 text-sm text-white/70'>
            <span class='rounded-full border border-white/20 px-3 py-1'>No Credit Card Required</span>
            <span class='rounded-full border border-white/20 px-3 py-1'>Reviewed Applications</span>
            <span class='rounded-full border border-white/20 px-3 py-1'>Built for Builders</span>
          </div>
        </div>
        <div class='relative hero-layer-stack'>
          <div class='absolute -top-16 -right-12 size-40 rounded-full bg-gradient-to-br from-primary/40 via-secondary/20 to-transparent blur-2xl'></div>
          <div class='absolute -bottom-10 -left-8 size-36 rounded-full bg-gradient-to-tr from-secondary/40 via-primary/20 to-transparent blur-2xl'></div>
          <div class='relative grid gap-5'>
            <div class='hero-layer-card rounded-3xl bg-gradient-to-br from-white via-[#f7fbfb] to-[#eefbff] text-textDarker p-8 shadow-[0_25px_60px_rgba(15,23,42,0.35)] border border-white/30'>
              <div class='flex items-center justify-between'>
                <div>
                  <p class='text-sm text-textPrimary/70'>Get up to</p>
                  <p class='text-4xl font-bold text-textDarker'>$1000 credits</p>
                </div>
                <!-- <div class='size-12 rounded-2xl bg-primary/10 flex items-center justify-center'>
                  <svg class='w-6 h-6 text-primary' fill='none' stroke='currentColor' viewBox='0 0 24 24'>
                    <path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M12 8v8m4-4H8'></path>
                  </svg>
                </div> -->
              </div>
              <p class='text-textPrimary/80 mt-3'>Apply once. Get credits. Earn more with referrals.</p>
              <div class='mt-6 grid grid-cols-3 gap-3'>
                {stats.map((stat) => (
                  <div class='rounded-2xl border border-primary/10 bg-[#f7fbfb] p-3 text-center'>
                    <p class='text-sm text-textPrimary/70'>{stat.label}</p>
                    <p class='font-semibold text-textDarker'>{stat.value}</p>
                  </div>
                ))}
              </div>
            </div>
            <div class='grid sm:grid-cols-2 gap-4'>
              <div class='hero-layer-mini rounded-2xl bg-gradient-to-br from-[#102627] via-[#0e2c2d] to-[#0b2324] px-5 py-4 border border-white/10 text-white text-sm shadow-[0_18px_40px_rgba(9,13,13,0.4)]'>
                <p class='font-semibold'>Credits for Builders</p>
                <p class='text-white/70'>Rolling reviews · Limited slots</p>
              </div>
              <div class='hero-layer-mini hero-layer-tilt rounded-2xl border border-primary/10 bg-gradient-to-br from-[#f1fffe] via-white to-[#eefbff] p-5 shadow-[0_14px_34px_rgba(48,186,186,0.25)]'>
                <p class='text-sm text-textPrimary/70'>Who it’s for</p>
                <div class='mt-3 grid grid-cols-1 gap-2 text-sm'>
                  {whoFor.slice(0, 3).map((item) => (
                    <div class='flex items-center gap-2 rounded-xl bg-white/90 px-3 py-2'>
                      <span class='size-2 rounded-full bg-primary'></span>
                      <span class='text-textPrimary'>{item}</span>
                    </div>
                  ))}
                </div>
              </div>
            </div>
          </div>
          <div class='absolute -bottom-8 -left-8 hidden lg:block'>
            <div class='rounded-2xl  bg-gradient-to-br from-[#d9fbfb] via-[#f7fbfb] to-[#d9fbfb] px-4 py-3 border border-primary/10 text-textPrimary text-sm'>
              <p class='font-semibold text-textDarker'>3–5 business days</p>
              <p class='text-textPrimary/70'>Typical review time</p>
            </div>
          </div>
          <div class='absolute -top-6 -right-2 hidden lg:block'>
            <div class='rounded-2xl bg-gradient-to-br from-[#d9fbfb] via-[#f7fbfb] to-[#d9fbfb]  px-4 py-3 border border-primary/10 text-textPrimary text-sm shadow-[0_12px_26px_rgba(48,186,186,0.1)]'>
              <p class='font-semibold text-textDarker'>Limited-time campaign</p>
              <p class='text-textPrimary/70'>Apply now</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class='max-w-7xl mx-auto px-[5%] py-16'>
    <div class='grid lg:grid-cols-[0.9fr_1.1fr] gap-12 items-start'>
      <div class='space-y-5'>
        <p class='text-sm font-semibold text-primary uppercase tracking-wide'>What is it?</p>
        <h2 class='text-4xl font-bold text-textDarker'>Build without worrying about cloud costs</h2>
        <p class='text-textPrimary/80 leading-relaxed'>
          The Dataflow Credits Campaign is a limited-time initiative to support builders who want to experiment, learn, and ship faster.
          We’re offering free platform credits so you can focus on building — not infrastructure.
        </p>
      </div>
      <div class='grid sm:grid-cols-2 gap-4'>
        {whoFor.map((item) => (
          <div class='flex items-center gap-3 rounded-2xl border border-primary/10 bg-[#f7fbfb] p-4 shadow-sm'>
            <span class='size-2 rounded-full bg-primary'></span>
            <p class='font-semibold text-textDarker'>{item}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class='bg-[#f7fbfb] py-16'>
    <div class='max-w-7xl mx-auto px-[5%]'>
      <div class='flex flex-col flex-wrap gap-6 mb-10'>
        <div>
          <p class='text-sm font-semibold text-primary uppercase tracking-wide'>What you get</p>
          <h2 class='text-4xl font-bold text-textDarker'>A playful stack of powerful tools</h2>
        </div>
        <div class='text-sm text-textPrimary/70 max-w-md'>
          Everything you need to run data workflows in one browser-based environment.
        </div>
      </div>
      <div class='grid md:grid-cols-2 gap-6'>
        {benefits.map((benefit, index) => (
          <div class='rounded-3xl p-6 border border-primary/10 shadow-sm bg-primary/5'>
            <div class='flex items-center gap-3'>
              <span class='size-10 rounded-2xl bg-primary/10 flex items-center justify-center text-primary font-bold'>
                {index + 1}
              </span>
              <p class='text-lg font-semibold text-textDarker'>{benefit}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section id='referral' class='max-w-7xl mx-auto px-[5%] py-16'>
    <div class='grid lg:grid-cols-[1.1fr_0.9fr] gap-12 items-center'>
      <div class='space-y-5'>
        <p class='text-sm font-semibold text-primary uppercase tracking-wide'>Referral Program</p>
        <h2 class='text-4xl font-bold text-textDarker'>Earn More Credits by Referring Others</h2>
        <p class='text-textPrimary/80 leading-relaxed'>
          Share your unique referral link and earn bonus credits for every approved signup.
        </p>
        <ul class='space-y-3 text-textPrimary'>
          {referralSteps.map((step, index) => (
            <li class='flex items-center gap-3'>
              <span class='size-8 rounded-full bg-primary/10 flex items-center justify-center text-primary font-semibold'>
                {index + 1}
              </span>
              {step}
            </li>
          ))}
        </ul>
        <a
          href='#apply'
          class='inline-flex items-center gap-2 px-6 py-3 rounded-lg bg-primary text-white font-semibold shadow-lg hover:bg-primaryHover transition'
        >
          Get My Referral Link
          <svg class='w-4 h-4' fill='none' stroke='currentColor' viewBox='0 0 24 24'>
            <path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M13 7l5 5m0 0l-5 5m5-5H6'></path>
          </svg>
        </a>
      </div>
      <div class='rounded-3xl border border-primary/10 bg-gradient-to-br from-primary/10 via-white to-secondary/10 p-8 shadow-lg'>
        <h3 class='text-2xl font-bold text-textDarker mb-6'>How it works</h3>
        <div class='space-y-4'>
          {howItWorks.map((step, index) => (
            <div class='flex gap-4'>
              <div class='size-10 rounded-2xl bg-white shadow flex items-center justify-center font-bold text-primary'>
                {index + 1}
              </div>
              <div>
                <p class='font-semibold text-textDarker'>{step.title}</p>
                <p class='text-sm text-textPrimary/80'>{step.description}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section id='apply' class='bg-[#f7fbfb] py-16'>
    <div class='max-w-7xl mx-auto px-[5%] grid lg:grid-cols-[0.75fr_1.25fr] gap-12'>
      <div class='space-y-6'>
        <p class='text-sm font-semibold text-primary uppercase tracking-wide'>Application</p>
        <h2 class='text-4xl font-bold text-textDarker'>Apply for Free Credits</h2>
        <p class='text-textPrimary/80 leading-relaxed'>Share a few details and we’ll get back within 3–5 business days.</p>
      </div>
      <PromotionCreditsForm client:load />
    </div>
  </section>

  <section class='bg-white py-16'>
    <div class='max-w-5xl mx-auto px-[5%] text-center space-y-4'>
      <p class='text-sm font-semibold text-primary uppercase tracking-wide'>FAQ</p>
      <h2 class='text-4xl font-bold text-textDarker'>Questions, answered</h2>
      <p class='text-textPrimary/80'>Everything you need to know before applying.</p>
    </div>
    <div class='max-w-3xl mx-auto px-[5%] mt-10 space-y-4'>
      {faqs.map((item) => (
        <details class='faq-card rounded-2xl border border-primary/10 bg-white p-5 text-left'>
          <summary class='flex items-center justify-between cursor-pointer text-textDarker font-semibold'>
            {item.q}
            <span class='transition-transform duration-300 text-primary text-xl'>+</span>
          </summary>
          <div class='faq-content'>
            <div class='faq-inner'>
              <p class='mt-3 text-sm text-textPrimary/80'>{item.a}</p>
            </div>
          </div>
        </details>
      ))}
    </div>
  </section>

  <section class='bg-[#f7fbfb] py-16'>
    <div class='max-w-7xl mx-auto px-[5%]'>
      <div class='rounded-3xl bg-gradient-to-br from-primary/10 via-[#f4fcfc] to-secondary/10 p-10 text-center text-textDarker shadow-[0_20px_50px_rgba(48,186,186,0.22)] border-1 border-textPrimary/20'>
        <p class='text-md tracking-wide text-textPrimary/60'>Ready to build without limits?</p>
        <h2 class='text-4xl font-bold mt-3'>Start shipping with Dataflow Credits</h2>
        <p class='text-textPrimary/70 mt-3 max-w-2xl mx-auto'>
          Apply for free credits today or invite a friend to unlock bonus credits together.
        </p>
        <div class='flex flex-wrap justify-center gap-4 mt-8'>
          <a href='#apply' class='px-6 py-3 rounded-lg bg-primary text-white font-semibold shadow-lg'>
            Apply for Free Credits
          </a>
          <a href='#referral' class='px-6 py-3 rounded-lg bg-white text-primary font-semibold shadow'>
            Refer Friends & Earn More
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .hero-layer-stack {
    perspective: 1200px;
    transform-style: preserve-3d;
  }

  .hero-layer-card {
    transform: translateZ(0) rotateX(1.2deg) rotateY(-1.8deg);
    transform-style: preserve-3d;
    will-change: transform;
  }

  .hero-layer-mini {
    transform: translateZ(0) translateY(-8px);
    transform-style: preserve-3d;
  }

  .hero-layer-tilt {
    transform: translateZ(0) rotateX(1.4deg) rotateY(1.8deg);
  }

  details.faq-card summary::-webkit-details-marker {
    display: none;
  }

  details.faq-card .faq-content {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.6s ease;
  }

  details.faq-card .faq-inner {
    overflow: hidden;
    opacity: 0;
    transition: opacity 0.5s ease;
  }

  details.faq-card[open] .faq-content {
    grid-template-rows: 1fr;
  }

  details.faq-card[open] .faq-inner {
    opacity: 1;
  }

  details.faq-card[open] summary span {
    transform: rotate(45deg);
  }
</style>
