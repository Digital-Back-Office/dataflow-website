---
import Layout from '../layouts/Layout.astro'
import TopSection from '../components/features/run-data-on-any-cloud/TopSection.astro'
import CoreCapabilities from '../components/features/run-data-on-any-cloud/CoreCapabilities.astro'
import PrivateCloud from '../components/features/run-data-on-any-cloud/PrivateCloud.astro'
import { getEntry } from 'astro:content'
import Section from '../components/features/run-data-on-any-cloud/Section.astro'
import Benefits from '../components/features/run-data-on-any-cloud/Benefits.astro'
const Data = await getEntry('features', 'run-data-on-any-cloud')
const data = Data?.data?.cloud_providers || {}
const cloud_providers = data?.cloud_providers || []
const meta_description =
  'Upgrade your data management and processing capabilities by using our service, which enables Dataflow on any cloud platform'
---

<Layout
  title='Dataflow | Run Data on any cloud'
  meta_description={meta_description}
>
  <TopSection />
  <Benefits />
  <CoreCapabilities />
  {
    cloud_providers.map((provider, idx) => (
      <Section
        mirror={idx % 2 !== 0}
        logo={provider.logo}
        title={provider.title}
        image={provider.image}
        link={provider.link}
      />
    ))
  }
  <PrivateCloud />
</Layout>
