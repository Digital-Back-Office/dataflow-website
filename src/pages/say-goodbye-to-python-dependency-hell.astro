---
import Layout from '../layouts/Layout.astro'
import TopSection from '../components/features/say-goodbye-to-python-dependency-hell/TopSection.astro'
import DependencyManagement from '../components/features/say-goodbye-to-python-dependency-hell/DependencyManagement.astro'
import TwoColumnSection from '../components/common/TwoColumnSection.astro'
import { getEntry } from 'astro:content'
const meta_description =
  'Effortlessly manage and resolve Python dependencies with Dataflow platform.'
const Data = await getEntry('features', 'python-dependency-hell')
const two_column_section = Data.data.section
---

<Layout
  title='Dataflow | Say Goodbye to Python Dependency Hell'
  meta_description={meta_description}
>
  <TopSection />
  <TwoColumnSection
    title={two_column_section.title}
    description={two_column_section.description}
    image={two_column_section.image}
    buttonText={two_column_section.button.label}
    buttonHref={two_column_section.button.href}
    imageSide={two_column_section.imageSide}
    bg="white"
  />
  <DependencyManagement />
</Layout>
