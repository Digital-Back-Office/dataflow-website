---
import Layout from '../../layouts/Layout.astro'
import TopSection from '../../components/common/TopSection.astro'
import TwoColumnSection from '../../components/common/TwoColumnSection.astro'
import CardsWithBulletsSection from '../../components/common/CardsWithBulletsSection.astro'
import { getEntry } from 'astro:content'
import Testimonial from '../../components/common/Testimonial.astro'
import CTASection from '../../components/common/CTASection.astro'
import CustomButton from '../../components/common/CustomButton.astro'

const Data = await getEntry('enterprise', 'enterprise')
const top = Data?.data?.top_section || {}
const seo = Data?.data?.seo
const meta_description = top.description ?? 'Enterprise'
const sections = Data?.data?.sections || []
const sectionCta = Data?.data?.section_cta || {}
const cta = Data?.data?.cta_section || {}
const enterpriseComplianceCards = [
	{
		title: 'DORA compliance',
		bullets: [
			'Deploy on self-hosted or sovereign cloud infrastructure to keep operational control in your hands.',
			'Standardize production environments and access boundaries across internal teams and vendors.',
			'Reduce platform risk by using auditable, repeatable workflows for critical data operations.'
		]
	},
	{
		title: 'EU AI Act readiness',
		bullets: [
			'Track model and pipeline activity with audit logs that support internal and external review.',
			'Maintain data lineage visibility from ingestion through transformation and production outputs.',
			'Use reproducible environments to document and repeat high-risk AI workflows consistently.'
		]
	},
	{
		title: 'GDPR-native deployment',
		bullets: [
			'Run workloads on European providers such as Civo, IONOS, and Cleura for stronger residency control.',
			'Keep secrets and credentials centrally managed with role-based access across teams.',
			'Support privacy governance requirements without adding custom deployment complexity.'
		]
	}
]
---

<Layout
	title={seo?.title ?? 'Enterprise Data Platform | Secure, Scalable & Governed | Dataflow'}
	meta_description={seo?.description ?? 'Built for enterprise data teams. RBAC permissions, audit logs, SSO, dedicated support and scalable GPU compute. Get a custom demo for your organisation.'}
>
	<TopSection
		title={top.title}
		description={top.description}
		image={top.hero_image}
		buttonText={top.button?.label}
		buttonHref={top.button?.href}
		imageSide="right"
		bg="white"
	/>
	{
		sections.map((sec, idx) => (
			<TwoColumnSection
				title={sec.title}
				description={sec.description}
				image={sec.image}
				imageSide={sec.imageSide ?? 'right'}
			/>
		))
	}

	<CardsWithBulletsSection
		title="Compliance foundations for EU-regulated enterprises"
		cards={enterpriseComplianceCards}
		bg="F8FAFC"
	/>
	
	{sectionCta && sectionCta.label && (
		<div class='flex justify-center py-16 bg-white'>
			<CustomButton
				label={sectionCta.label}
				href={sectionCta.href}
				target='_blank'
				variant="primary"
				className="px-8 py-3 text-lg font-medium"
			/>
		</div>
	)}
	
	<Testimonial />
	<CTASection
		title={cta.title}
		description={cta.description}
		buttonText={cta.button?.text}
		formId="enterpriseCtaForm"
		pageSource="enterprise-cta"
		note={cta.note}
	/>
	<section class='px-[5%] pb-16 bg-white'>
		<div class='max-w-5xl mx-auto text-center text-sm text-gray-600'>
			Explore related capabilities in <a href='/product/deploy-to-production' title='Explore deploy to production features' class='text-primary hover:text-primaryHover underline underline-offset-2'>Deploy to Production</a> and <a href='/product/shared-foundation' title='Explore shared foundation features' class='text-primary hover:text-primaryHover underline underline-offset-2'>Shared Foundation</a>, compare options on <a href='/pricing' title='Compare pricing options' class='text-primary hover:text-primaryHover underline underline-offset-2'>Pricing</a>, or schedule a tailored walkthrough on <a href='/book-demo' title='Book an enterprise demo' class='text-primary hover:text-primaryHover underline underline-offset-2'>Book Demo</a>.
		</div>
	</section>
</Layout>