---
import Layout from '../../layouts/Layout.astro'
import TopSection from '../../components/common/TopSection.astro'
import TwoColumnSection from '../../components/common/TwoColumnSection.astro'
import SectionCallout from '../../components/common/SectionCallout.astro'
import { getEntry } from 'astro:content'
import Testimonial from '../../components/common/Testimonial.astro'
import CTASection from '../../components/common/CTASection.astro'
import Card from '../../components/blog/Card.astro'

const Data = await getEntry('startups-smes', 'startups-smes')
const top = Data?.data?.top_section || {}
const seo = Data?.data?.seo
const meta_description = top.description ?? 'Data Infrastructure for Startups and SMEs'
const sections = Data?.data?.sections || []
const cta = Data?.data?.cta_section || {}
---

<Layout
	title={seo?.title ?? 'Data Platform for Startups & Small Teams | Scale Fast | Dataflow'}
	meta_description={seo?.description ?? 'Go from zero to a production data stack in under 30 minutes. No DevOps hire needed. Dataflow gives startups and SMEs enterprise-grade tools at startup prices.'}
>
	<TopSection
		title={top.title}
		description={top.description}
		image={top.hero_image}
		buttonText={top.button?.label}
		buttonHref={top.button?.href}
		imageSide="right"
		bg="white"
	/>
	{
		sections.map((sec, idx) => (
			<TwoColumnSection
				title={sec.title}
				description={sec.description}
				image={sec.image}
				imageSide={sec.imageSide ?? 'right'}
			/>
		))
	}
	<SectionCallout text="Sovereign deployment options give startups built-in compliance support for EU AI Act high-risk classifications while keeping day-to-day delivery simple." />
	<Testimonial />
	<CTASection
		title={cta.title}
		description={cta.description}
		buttonText={cta.button?.text}
		formId="startupsCtaForm"
		pageSource="startups-smes-cta"
		note={cta.note}
	/>
	<section class='px-[5%] pb-16 bg-white'>
		<div class='max-w-5xl mx-auto text-center text-sm text-gray-600'>
			For growing teams, start with <a href='/product/shared-foundation' title='Explore shared foundation' class='text-primary hover:text-primaryHover underline underline-offset-2'>Shared Foundation</a> and <a href='/product/managed-dependencies' title='Explore managed dependencies' class='text-primary hover:text-primaryHover underline underline-offset-2'>Managed Dependencies</a>, then review <a href='/pricing' title='Review startup pricing' class='text-primary hover:text-primaryHover underline underline-offset-2'>Pricing</a> or <a href='/book-demo' title='Book a startup demo' class='text-primary hover:text-primaryHover underline underline-offset-2'>Book a Demo</a> for implementation guidance.
		</div>
	</section>
</Layout>
